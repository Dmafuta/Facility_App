@page "/{TenantSlug}/access/passes"
@page "/access/passes"
@layout MainLayout
@attribute [Authorize(Policy = "CanManageAccess")]
@inject IAccessPassService PassSvc
@inject NavigationManager Nav

<PageTitle>Access Passes — FacilityApp</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Access Passes</h4>
        <small class="text-muted">Gate &amp; parking passes issued to visitors</small>
    </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <input class="form-control form-control-sm" placeholder="Search pass number, visitor, vehicle…"
                       @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
            </div>
            <div class="col-auto">
                <select class="form-select form-select-sm" @bind="_status" @bind:after="LoadAsync">
                    <option value="">All Passes</option>
                    <option value="active">Active</option>
                    <option value="expired">Expired</option>
                    <option value="revoked">Revoked</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_items.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-card-checklist display-4 d-block mb-2"></i>
        No passes found.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Pass #</th>
                        <th>Visitor</th>
                        <th>Type</th>
                        <th>Vehicle</th>
                        <th>Bay</th>
                        <th>Valid From</th>
                        <th>Valid Until</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pass in _items)
                    {
                        <tr>
                            <td><code class="fw-semibold">@pass.PassNumber</code></td>
                            <td>@pass.Visit.Visitor.FullName</td>
                            <td>
                                <span class="badge @PassTypeBadge(pass.PassType)">
                                    <i class="bi @PassTypeIcon(pass.PassType) me-1"></i>@pass.PassType
                                </span>
                            </td>
                            <td>@(pass.VehicleRegistration ?? "—")</td>
                            <td>@(pass.ParkingBay ?? "—")</td>
                            <td class="text-nowrap">@pass.ValidFrom.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            <td class="text-nowrap">
                                @(pass.ValidUntil.HasValue
                                    ? pass.ValidUntil.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                    : "Open-ended")
                            </td>
                            <td>@PassStatusBadge(pass)</td>
                            <td>
                                @if (!pass.IsRevoked)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => PromptRevoke(pass.Id, pass.PassNumber)">
                                        <i class="bi bi-x-circle me-1"></i>Revoke
                                    </button>
                                }
                                else
                                {
                                    <small class="text-muted">@pass.RevokedReason</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (_totalPages > 1)
    {
        <nav class="mt-3 d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @((_page-1)*_pageSize+1)–@(Math.Min(_page*_pageSize,_total)) of @_total</small>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(_page==1?"disabled":"")">
                    <button class="page-link" @onclick="PrevPage">‹</button>
                </li>
                @for (var i = 1; i <= _totalPages; i++)
                {
                    var p = i;
                    <li class="page-item @(_page==p?"active":"")">
                        <button class="page-link" @onclick="() => GoToPage(p)">@p</button>
                    </li>
                }
                <li class="page-item @(_page==_totalPages?"disabled":"")">
                    <button class="page-link" @onclick="NextPage">›</button>
                </li>
            </ul>
        </nav>
    }
}

<!-- Revoke Modal -->
@if (_revokePassId.HasValue)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Revoke Pass @_revokePassNumber</h5>
                    <button class="btn-close" @onclick="CancelRevoke"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason (optional)</label>
                    <input class="form-control" @bind="_revokeReason" placeholder="e.g. Visit ended early" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelRevoke">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmRevoke">Revoke Pass</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<FacilityApp.Data.Models.AccessPass> _items = [];
    private bool _loading = true;
    private string? _search;
    private string? _status = "active";
    private int _page = 1, _pageSize = 25, _total, _totalPages;

    private Guid? _revokePassId;
    private string? _revokePassNumber;
    private string? _revokeReason;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        (_items, _total) = await PassSvc.GetPassesAsync(_status, _search, _page, _pageSize);
        _totalPages = (int)Math.Ceiling(_total / (double)_pageSize);
        _loading = false;
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadAsync(); }
    }

    private void PromptRevoke(Guid id, string number)
    {
        _revokePassId     = id;
        _revokePassNumber = number;
        _revokeReason     = null;
    }
    private void CancelRevoke() { _revokePassId = null; }
    private async Task ConfirmRevoke()
    {
        await PassSvc.RevokeAsync(_revokePassId!.Value, _revokeReason);
        _revokePassId = null;
        await LoadAsync();
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadAsync(); } }
    private async Task GoToPage(int p) { _page = p; await LoadAsync(); }

    private static string PassTypeBadge(FacilityApp.Data.Models.PassType t) => t switch
    {
        FacilityApp.Data.Models.PassType.Gate    => "bg-primary",
        FacilityApp.Data.Models.PassType.Parking => "bg-warning text-dark",
        _                                        => "bg-info text-dark"
    };
    private static string PassTypeIcon(FacilityApp.Data.Models.PassType t) => t switch
    {
        FacilityApp.Data.Models.PassType.Gate    => "bi-door-open",
        FacilityApp.Data.Models.PassType.Parking => "bi-p-square",
        _                                        => "bi-shield-check"
    };

    private static MarkupString PassStatusBadge(FacilityApp.Data.Models.AccessPass p)
    {
        if (p.IsRevoked) return new MarkupString("<span class='badge bg-danger'>Revoked</span>");
        if (p.ValidUntil.HasValue && p.ValidUntil.Value <= DateTime.UtcNow)
            return new MarkupString("<span class='badge bg-secondary'>Expired</span>");
        return new MarkupString("<span class='badge bg-success'>Active</span>");
    }
}
