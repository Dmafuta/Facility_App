@page "/{TenantSlug}/visitors"
@page "/visitors"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IVisitorService VisitorSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject GateContext GateCtx
@implements IDisposable

<PageTitle>Visitors — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>Visitors</h4>
        <small class="text-muted">All visitor activity for @TenantCtx.TenantName</small>
    </div>
    <div class="d-flex gap-2">
        <a href="@(TenantCtx.RouteBase)/visitors/preregister" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-person-plus me-1"></i>Pre-register
        </a>
        <a href="@(TenantCtx.RouteBase)/visitors/checkin" class="btn btn-primary btn-sm">
            <i class="bi bi-person-check me-1"></i>Check In
        </a>
    </div>
</div>

<!-- Tab bar -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-0">
        <ul class="nav nav-tabs border-0">
            @foreach (var (key, label) in Tabs)
            {
                <li class="nav-item">
                    <button class="nav-link @(_activeTab == key ? "active" : "")"
                            @onclick="() => SetTabAsync(key)">
                        @label
                    </button>
                </li>
            }
        </ul>
    </div>

    <!-- Search -->
    <div class="card-body border-bottom py-2 px-3">
        <div class="d-flex gap-2">
            <input class="form-control form-control-sm"
                   placeholder="Search by name, email, phone, company or purpose…"
                   value="@_search"
                   @oninput="OnSearchInputAsync" />
            @if (!string.IsNullOrEmpty(_search))
            {
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearSearchAsync">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>
    </div>

    <!-- Confirmation modal -->
    @if (_confirmId.HasValue)
    {
        <div class="modal-backdrop-custom" @onclick="DismissConfirm"></div>
        <div class="modal-panel card shadow-lg" style="max-width: 380px;">
            <div class="card-body px-4 py-4">
                <h6 class="fw-bold mb-2">
                    <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                    @(_confirmAction == "cancel" ? "Cancel Visit?" : "Mark as No-Show?")
                </h6>
                <p class="text-muted small mb-4">
                    @if (_confirmAction == "cancel")
                    {
                        <span>Are you sure you want to cancel this visit? This cannot be undone.</span>
                    }
                    else
                    {
                        <span>Mark this visitor as a no-show? This cannot be undone.</span>
                    }
                </p>
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="DismissConfirm">Back</button>
                    <button class="btn btn-sm @(_confirmAction == "cancel" ? "btn-danger" : "btn-warning")"
                            @onclick="ExecuteConfirmedAsync" disabled="@_busy">
                        @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Confirm
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Table -->
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-5 text-muted">
                <div class="spinner-border spinner-border-sm me-2"></div>Loading…
            </div>
        }
        else if (_visits is null || _visits.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-x fs-1 d-block mb-2 opacity-25"></i>
                No visits found for this filter.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Visitor</th>
                            <th>Company</th>
                            <th>Host</th>
                            <th>Purpose</th>
                            <th>Scheduled</th>
                            <th>Check-in</th>
                            <th class="text-center">Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var visit in _visits)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (visit.Visitor.PhotoUrl is not null)
                                        {
                                            <img src="@visit.Visitor.PhotoUrl" alt="@visit.Visitor.FullName"
                                                 class="visitor-avatar" style="object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div class="visitor-avatar">
                                                @(visit.Visitor.FullName.Length > 0
                                                    ? visit.Visitor.FullName[0].ToString().ToUpper()
                                                    : "?")
                                            </div>
                                        }
                                        <div>
                                            <a href="@(TenantCtx.RouteBase)/visitors/@visit.Id" class="fw-medium text-decoration-none text-body">@visit.Visitor.FullName</a>
                                            <small class="text-muted d-block">@visit.Visitor.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted small">
                                    @(visit.Visitor.Company ?? "—")
                                </td>
                                <td class="small">
                                    @(visit.Host?.FullName ?? "—")
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@visit.Purpose</span>
                                </td>
                                <td class="small">
                                    <div class="fw-medium">@visit.ScheduledAt.ToLocalTime().ToString("MMM d, h:mm tt")</div>
                                </td>
                                <td class="small text-muted">
                                    @if (visit.CheckedInAt.HasValue)
                                    {
                                        @visit.CheckedInAt.Value.ToLocalTime().ToString("h:mm tt")
                                        @if (visit.EntryEntrance is not null)
                                        {
                                            <div style="font-size:0.7rem;">
                                                <i class="bi bi-door-open me-1"></i>@visit.EntryEntrance.Name
                                                @if (visit.ExitEntrance is not null && visit.ExitEntrance.Id != visit.EntryEntrance.Id)
                                                {
                                                    <span class="text-muted"> → @visit.ExitEntrance.Name</span>
                                                }
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <text>—</text>
                                    }
                                </td>
                                <td class="text-center">
                                    @((MarkupString)StatusBadge(visit.Status))
                                </td>
                                <td class="text-end pe-3">
                                    @if (visit.Status == VisitStatus.Scheduled)
                                    {
                                        <div class="d-flex gap-1 justify-content-end">
                                            <button class="btn btn-sm btn-success"
                                                    @onclick="() => CheckInAsync(visit.Id)"
                                                    disabled="@_busy">
                                                <i class="bi bi-person-check me-1"></i>Check In
                                            </button>
                                            <button class="btn btn-sm btn-warning"
                                                    @onclick="() => PromptNoShow(visit.Id)"
                                                    disabled="@_busy"
                                                    title="Mark as no-show">
                                                <i class="bi bi-person-x"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => PromptCancel(visit.Id)"
                                                    disabled="@_busy"
                                                    title="Cancel">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                    else if (visit.Status == VisitStatus.CheckedIn)
                                    {
                                        <div class="d-flex gap-1 justify-content-end">
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => CheckOutAsync(visit.Id)"
                                                    disabled="@_busy">
                                                <i class="bi bi-box-arrow-right me-1"></i>Check Out
                                            </button>
                                            <a class="btn btn-sm btn-outline-primary"
                                               href="@(TenantCtx.RouteBase)/visitors/@visit.Id/badge"
                                               target="_blank" title="Print Badge">
                                                <i class="bi bi-printer"></i>
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-3 py-2 border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                <small class="text-muted">
                    Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _total)) of @_total result@(_total == 1 ? "" : "s")
                </small>
                @if (TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_page == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => GoToPageAsync(_page - 1)">&laquo;</button>
                            </li>
                            @for (var p = Math.Max(1, _page - 2); p <= Math.Min(TotalPages, _page + 2); p++)
                            {
                                var pg = p;
                                <li class="page-item @(pg == _page ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPageAsync(pg)">@pg</button>
                                </li>
                            }
                            <li class="page-item @(_page == TotalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => GoToPageAsync(_page + 1)">&raquo;</button>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        }
    </div>
</div>

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private static readonly (string Key, string Label)[] Tabs =
    [
        ("today",    "Today"),
        ("upcoming", "Upcoming"),
        ("active",   "Active"),
        ("history",  "History"),
        ("all",      "All"),
    ];

    private List<Visit>? _visits;
    private string _activeTab = "today";
    private string _search    = "";
    private bool   _loading   = true;
    private bool   _busy;

    private const int PageSize = 25;
    private int _page  = 1;
    private int _total = 0;
    private int TotalPages => (int)Math.Ceiling(_total / (double)PageSize);

    // Search debounce
    private CancellationTokenSource? _searchCts;

    // Confirmation state
    private Guid?   _confirmId;
    private string? _confirmAction;

    // Toast
    private string? _toast;
    private string  _toastType = "success";

    private void ShowToast(string message, string type = "success")
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await VisitorSvc.GetVisitsAsync(_activeTab, _search, _page, PageSize);
        _visits = result.Items;
        _total  = result.Total;
        _loading = false;
    }

    private async Task SetTabAsync(string tab)
    {
        _activeTab = tab;
        _search    = "";
        _page      = 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || page > TotalPages) return;
        _page = page;
        await LoadAsync();
    }

    private async Task ClearSearchAsync()
    {
        _search = "";
        _page   = 1;
        await LoadAsync();
    }

    private async Task OnSearchInputAsync(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;
        try
        {
            await Task.Delay(300, token);
            _page = 1;
            await LoadAsync();
        }
        catch (OperationCanceledException) { }
    }

    private async Task CheckInAsync(Guid visitId)
    {
        _busy = true;
        await VisitorSvc.CheckInAsync(visitId, GateCtx.IsSelected ? GateCtx.EntranceId : null);
        await LoadAsync();
        _busy = false;
    }

    private async Task CheckOutAsync(Guid visitId)
    {
        _busy = true;
        var visit = _visits?.FirstOrDefault(v => v.Id == visitId);
        await VisitorSvc.CheckOutAsync(visitId, GateCtx.IsSelected ? GateCtx.EntranceId : null);
        await LoadAsync();
        _busy = false;
        var name = visit?.Visitor.FullName ?? "Visitor";
        ShowToast(GateCtx.IsSelected
            ? $"{name} checked out at {GateCtx.EntranceName}."
            : $"{name} checked out.");
    }

    private void PromptCancel(Guid id)  { _confirmId = id; _confirmAction = "cancel"; }
    private void PromptNoShow(Guid id)  { _confirmId = id; _confirmAction = "noshow"; }
    private void DismissConfirm()       { _confirmId = null; _confirmAction = null; }

    private async Task ExecuteConfirmedAsync()
    {
        if (_confirmId is null) return;
        _busy = true;
        if (_confirmAction == "cancel")      await VisitorSvc.CancelAsync(_confirmId.Value);
        else if (_confirmAction == "noshow") await VisitorSvc.MarkNoShowAsync(_confirmId.Value);
        DismissConfirm();
        await LoadAsync();
        _busy = false;
    }

    public void Dispose() => _searchCts?.Dispose();

    private static string StatusBadge(VisitStatus s) => s switch
    {
        VisitStatus.Scheduled  => "<span class=\"badge bg-primary\">Scheduled</span>",
        VisitStatus.CheckedIn  => "<span class=\"badge bg-success\">Checked In</span>",
        VisitStatus.CheckedOut => "<span class=\"badge bg-secondary\">Checked Out</span>",
        VisitStatus.Cancelled  => "<span class=\"badge bg-danger\">Cancelled</span>",
        VisitStatus.NoShow     => "<span class=\"badge bg-warning text-dark\">No Show</span>",
        _                      => "<span class=\"badge bg-light text-dark\">Unknown</span>"
    };
}
