@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="superadmin-page">
    <nav class="superadmin-nav">
        <div class="superadmin-brand">
            <i class="bi bi-buildings me-2"></i>
            <span class="fw-bold">FacilityApp</span>
            <span class="badge bg-danger ms-2" style="font-size:.65rem;vertical-align:middle;">SUPER ADMIN</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <NavLink href="/superadmin/tenants" class="nav-link text-white" ActiveClass="fw-bold">
                <i class="bi bi-grid me-1"></i>Tenants
            </NavLink>
            <button class="btn btn-sm btn-outline-light" @onclick="ToggleThemeAsync" title="Toggle theme">
                <i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i>
            </button>
        </div>
    </nav>

    <main class="superadmin-main">
        @Body
    </main>
</div>

<style>
    .superadmin-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .superadmin-nav {
        background: #212529;
        padding: .75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #fff;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .superadmin-brand { font-size: 1rem; color: #fff; }

    .superadmin-main {
        flex: 1;
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
    }
</style>

@code {
    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var theme = await JS.InvokeAsync<string>("themeManager.init");
        _isDark = theme == "dark";
        StateHasChanged();
    }

    private async Task ToggleThemeAsync()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("themeManager.setTheme", _isDark ? "dark" : "light");
    }
}
