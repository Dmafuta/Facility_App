@page "/{TenantSlug}/forgot-password"
@page "/forgot-password"
@layout AuthLayout
@inject UserManager<ApplicationUser> UserManager
@inject IEmailService EmailSvc
@inject NavigationManager Nav
@inject TenantContext TenantCtx

<PageTitle>Forgot Password — FacilityApp</PageTitle>

<div class="auth-split">

    <!-- Left branding panel -->
    <div class="auth-brand d-none d-lg-flex">
        <div class="deco-circle"></div>
        <div class="brand-inner">
            <div class="brand-logo mb-4"><i class="bi bi-buildings"></i></div>
            <h1 class="brand-title">FacilityApp</h1>
            <p class="brand-subtitle">Password Recovery</p>

            <hr class="brand-divider my-4" />

            <ul class="brand-features list-unstyled">
                <li>
                    <div class="feat-icon"><i class="bi bi-lock-fill"></i></div>
                    <span>Enter your email to receive a secure reset link</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-envelope-fill"></i></div>
                    <span>Check your inbox — the link expires in 24 hours</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-shield-check-fill"></i></div>
                    <span>Your account stays secure throughout the process</span>
                </li>
            </ul>

            <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year FacilityApp. All rights reserved.</p>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-wrap">

            <!-- Mobile logo -->
            <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                <div class="mobile-logo"><i class="bi bi-buildings"></i></div>
                <div>
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">FacilityApp</div>
                    <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;">Password Recovery</div>
                </div>
            </div>

            <div class="login-card">
                @if (_sent)
                {
                    <div class="text-center py-2">
                        <div class="mb-3" style="font-size:3.5rem;line-height:1;">
                            <i class="bi bi-envelope-check-fill text-success"></i>
                        </div>
                        <h4 class="fw-bold mb-2">Check your inbox</h4>
                        <p class="text-muted small mb-4">If an account exists for that address, we've sent a password reset link. Check your spam folder if it doesn't arrive within a few minutes.</p>
                        <a href="@(TenantCtx.RouteBase)/login" class="btn-signin d-inline-flex align-items-center justify-content-center gap-2" style="text-decoration:none;">
                            <i class="bi bi-arrow-left"></i> Back to Sign In
                        </a>
                    </div>
                }
                else
                {
                    <h2 class="form-heading">Forgot password?</h2>
                    <p class="form-subheading">Enter your staff email and we'll send you a reset link.</p>

                    @if (_error is not null)
                    {
                        <div class="alert alert-danger alert-signin d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                            <span>@_error</span>
                        </div>
                    }

                    <EditForm Model="_form" OnValidSubmit="HandleAsync" FormName="forgot-password">
                        <DataAnnotationsValidator />

                        <div class="mb-4">
                            <label class="field-label">Email Address</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-envelope field-icon"></i>
                                <InputText @bind-Value="_form.Email"
                                           class="form-control"
                                           style="padding-left:2.4rem;"
                                           placeholder="you@facility.com"
                                           autocomplete="email" />
                            </div>
                            <ValidationMessage For="() => _form.Email" class="text-danger small mt-1" />
                        </div>

                        <button type="submit" class="btn-signin" disabled="@_busy">
                            @if (_busy)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Sending…</span>
                            }
                            else
                            {
                                <i class="bi bi-envelope me-2"></i>
                                <span>Send Reset Link</span>
                            }
                        </button>
                    </EditForm>

                    <hr class="form-divider" />

                    <p class="text-center small text-muted mb-0">
                        Remembered it?
                        <a href="@(TenantCtx.RouteBase)/login" class="link-em">Back to Sign In</a>
                    </p>
                }
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private ForgotForm _form = new();
    private bool _busy;
    private bool _sent;
    private string? _error;

    private async Task HandleAsync()
    {
        _busy = true; _error = null;
        try
        {
            var user = await UserManager.FindByEmailAsync(_form.Email);
            if (user is not null)
            {
                var token     = await UserManager.GeneratePasswordResetTokenAsync(user);
                var encoded   = Uri.EscapeDataString(token);
                var resetLink = Nav.ToAbsoluteUri(
                    $"{TenantCtx.RouteBase}/reset-password?email={Uri.EscapeDataString(_form.Email)}&token={encoded}").ToString();
                await EmailSvc.SendPasswordResetAsync(user.Email!, user.FullName, resetLink);
            }
            // Always show success to avoid user enumeration
            _sent = true;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private sealed class ForgotForm
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";
    }
}
