@inject NavigationManager Nav
@inject TenantContext TenantCtx
@inject GateContext GateCtx
@inject IUnitRequestService UnitRequestSvc
@inject IMaintenanceService MaintenanceSvc
@inject IIncidentService IncidentSvc
@inject IParkingService ParkingSvc
@inject IParcelService ParcelSvc

<div class="top-row ps-3 navbar navbar-dark" style="@BrandingStyle">
    <div class="container-fluid d-flex align-items-center">
        @if (!string.IsNullOrEmpty(TenantCtx.LogoUrl))
        {
            <img src="@TenantCtx.LogoUrl" alt="Logo"
                 style="height:28px;width:auto;object-fit:contain;margin-right:8px;border-radius:4px;" />
        }
        else
        {
            <i class="bi bi-buildings me-2 text-white fs-5"></i>
        }
        <AuthorizeView Roles="Admin,Manager,Receptionist,Security">
            <Authorized>
                <a class="navbar-brand fw-bold" href="@($"{TenantCtx.RouteBase}/dashboard")">FacilityApp</a>
            </Authorized>
            <NotAuthorized>
                <a class="navbar-brand fw-bold" href="@($"{TenantCtx.RouteBase}/resident")">FacilityApp</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">

    @if (!string.IsNullOrEmpty(TenantCtx.TenantName))
    {
        <div class="px-3 py-2">
            <small class="text-white-50 text-uppercase fw-semibold" style="font-size:0.65rem;letter-spacing:0.08em;">Facility</small>
            <div class="text-white fw-semibold" style="font-size:0.85rem;">@TenantCtx.TenantName</div>
        </div>
    }

    <AuthorizeView Roles="Admin,Manager,Receptionist,Security">
        @if (GateCtx.IsSelected)
        {
            <div class="px-3 pb-2 d-flex align-items-center justify-content-between">
                <div>
                    <small class="text-white-50 text-uppercase fw-semibold" style="font-size:0.65rem;letter-spacing:0.08em;">Your Gate</small>
                    <div class="text-white fw-semibold" style="font-size:0.85rem;">
                        <i class="bi bi-door-open me-1"></i>@GateCtx.EntranceName
                    </div>
                </div>
                <a href="@($"{TenantCtx.RouteBase}/select-gate")" class="text-white-50 small" title="Switch gate">
                    <i class="bi bi-arrow-repeat"></i>
                </a>
            </div>
        }
    </AuthorizeView>

    <!-- ── STAFF NAVIGATION ─────────────────────────────────────── -->
    <AuthorizeView Roles="Admin,Manager,Receptionist,Security">
        <nav class="nav flex-column mt-1">

            <!-- Dashboard — always visible -->
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/dashboard")" Match="NavLinkMatch.All">
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                </NavLink>
            </div>

            <!-- Accordion wrapper — enforces one-open-at-a-time -->
            <div id="nav-accordion">

                <!-- ── Access Control ── -->
                <div class="nav-folder">
                    <button class="nav-folder-btn @(!IsOpen("access") ? "collapsed" : "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#folder-access"
                            aria-expanded="@IsOpen("access").ToString().ToLower()"
                            aria-controls="folder-access"
                            onclick="event.stopPropagation()">
                        <i class="bi bi-shield-lock me-2"></i>
                        <span class="flex-grow-1">Access Control</span>
                        <i class="bi bi-chevron-right nav-chevron"></i>
                    </button>
                    <div id="folder-access"
                         class="collapse @(IsOpen("access") ? "show" : "")"
                         data-bs-parent="#nav-accordion">
                        <div class="nav-folder-children">
                            <AuthorizeView Policy="CanCheckInVisitors" Context="_ci">
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/check-in")">
                                        <i class="bi bi-qr-code-scan me-2"></i>Check-In
                                    </NavLink>
                                </div>
                            </AuthorizeView>
                            <div class="nav-item">
                                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/visitors")">
                                    <i class="bi bi-people me-2"></i>Visitors
                                </NavLink>
                            </div>
                            <AuthorizeView Policy="CanManageAccess" Context="_ac">
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/access/passes")">
                                        <i class="bi bi-card-checklist me-2"></i>Passes
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/access/blacklist")">
                                        <i class="bi bi-person-x me-2"></i>Blacklist
                                    </NavLink>
                                </div>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>

                <!-- ── Operations ── -->
                <div class="nav-folder">
                    <button class="nav-folder-btn @(!IsOpen("operations") ? "collapsed" : "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#folder-operations"
                            aria-expanded="@IsOpen("operations").ToString().ToLower()"
                            aria-controls="folder-operations"
                            onclick="event.stopPropagation()">
                        <i class="bi bi-grid me-2"></i>
                        <span class="flex-grow-1">Operations</span>
                        @if (_vehiclesInsideCount + _pendingParcelCount + _openMaintenanceCount > 0)
                        {
                            <span class="folder-badge me-1">@(_vehiclesInsideCount + _pendingParcelCount + _openMaintenanceCount)</span>
                        }
                        <i class="bi bi-chevron-right nav-chevron"></i>
                    </button>
                    <div id="folder-operations"
                         class="collapse @(IsOpen("operations") ? "show" : "")"
                         data-bs-parent="#nav-accordion">
                        <div class="nav-folder-children">
                            <AuthorizeView Policy="CanAccessParking" Context="_park">
                                <div class="nav-item">
                                    <NavLink class="nav-link d-flex align-items-center justify-content-between"
                                             href="@($"{TenantCtx.RouteBase}/parking")">
                                        <span><i class="bi bi-p-circle me-2"></i>Parking</span>
                                        @if (_vehiclesInsideCount > 0)
                                        {
                                            <span class="badge bg-success ms-1">@_vehiclesInsideCount</span>
                                        }
                                    </NavLink>
                                </div>
                            </AuthorizeView>
                            <div class="nav-item">
                                <NavLink class="nav-link d-flex align-items-center justify-content-between"
                                         href="@($"{TenantCtx.RouteBase}/parcels")">
                                    <span><i class="bi bi-box-seam me-2"></i>Parcels</span>
                                    @if (_pendingParcelCount > 0)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">@_pendingParcelCount</span>
                                    }
                                </NavLink>
                            </div>
                            <div class="nav-item">
                                <NavLink class="nav-link d-flex align-items-center justify-content-between"
                                         href="@($"{TenantCtx.RouteBase}/maintenance")">
                                    <span><i class="bi bi-tools me-2"></i>Maintenance</span>
                                    @if (_openMaintenanceCount > 0)
                                    {
                                        <span class="badge bg-primary ms-1">@_openMaintenanceCount</span>
                                    }
                                </NavLink>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Residents ── -->
                <AuthorizeView Policy="CanManageUnits" Context="_resFolder">
                    <div class="nav-folder">
                        <button class="nav-folder-btn @(!IsOpen("residents") ? "collapsed" : "")"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#folder-residents"
                                aria-expanded="@IsOpen("residents").ToString().ToLower()"
                                aria-controls="folder-residents"
                                onclick="event.stopPropagation()">
                            <i class="bi bi-house-door me-2"></i>
                            <span class="flex-grow-1">Residents</span>
                            @if (_pendingRequestCount > 0)
                            {
                                <span class="folder-badge me-1">@_pendingRequestCount</span>
                            }
                            <i class="bi bi-chevron-right nav-chevron"></i>
                        </button>
                        <div id="folder-residents"
                             class="collapse @(IsOpen("residents") ? "show" : "")"
                             data-bs-parent="#nav-accordion">
                            <div class="nav-folder-children">
                                <AuthorizeView Policy="CanManageUsers" Context="_mu2">
                                    <div class="nav-item">
                                        <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/admin/users")">
                                            <i class="bi bi-person-lines-fill me-2"></i>Users
                                        </NavLink>
                                    </div>
                                </AuthorizeView>
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/admin/units")">
                                        <i class="bi bi-house-door me-2"></i>Units
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink class="nav-link d-flex align-items-center justify-content-between"
                                             href="@($"{TenantCtx.RouteBase}/admin/unit-requests")">
                                        <span><i class="bi bi-house-check me-2"></i>Unit Requests</span>
                                        @if (_pendingRequestCount > 0)
                                        {
                                            <span class="badge bg-warning text-dark ms-1">@_pendingRequestCount</span>
                                        }
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>
                </AuthorizeView>

                <!-- ── Communications ── -->
                <AuthorizeView Policy="CanManageUsers" Context="_commsFolder">
                    <div class="nav-folder">
                        <button class="nav-folder-btn @(!IsOpen("communications") ? "collapsed" : "")"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#folder-communications"
                                aria-expanded="@IsOpen("communications").ToString().ToLower()"
                                aria-controls="folder-communications"
                                onclick="event.stopPropagation()">
                            <i class="bi bi-megaphone me-2"></i>
                            <span class="flex-grow-1">Communications</span>
                            <i class="bi bi-chevron-right nav-chevron"></i>
                        </button>
                        <div id="folder-communications"
                             class="collapse @(IsOpen("communications") ? "show" : "")"
                             data-bs-parent="#nav-accordion">
                            <div class="nav-folder-children">
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/admin/announcements")">
                                        <i class="bi bi-megaphone me-2"></i>Announcements
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/admin/documents")">
                                        <i class="bi bi-folder2-open me-2"></i>Documents
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>
                </AuthorizeView>

                <!-- ── Management ── -->
                <div class="nav-folder">
                    <button class="nav-folder-btn @(!IsOpen("management") ? "collapsed" : "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#folder-management"
                            aria-expanded="@IsOpen("management").ToString().ToLower()"
                            aria-controls="folder-management"
                            onclick="event.stopPropagation()">
                        <i class="bi bi-briefcase me-2"></i>
                        <span class="flex-grow-1">Management</span>
                        @if (_openIncidentCount > 0)
                        {
                            <span class="folder-badge folder-badge-danger me-1">@_openIncidentCount</span>
                        }
                        <i class="bi bi-chevron-right nav-chevron"></i>
                    </button>
                    <div id="folder-management"
                         class="collapse @(IsOpen("management") ? "show" : "")"
                         data-bs-parent="#nav-accordion">
                        <div class="nav-folder-children">
                            <AuthorizeView Policy="CanViewReports" Context="_rp2">
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/reports")">
                                        <i class="bi bi-bar-chart-line me-2"></i>Reports
                                    </NavLink>
                                </div>
                            </AuthorizeView>
                            <div class="nav-item">
                                <NavLink class="nav-link d-flex align-items-center justify-content-between"
                                         href="@($"{TenantCtx.RouteBase}/incidents")">
                                    <span><i class="bi bi-exclamation-triangle me-2"></i>Incidents</span>
                                    @if (_openIncidentCount > 0)
                                    {
                                        <span class="badge bg-danger ms-1">@_openIncidentCount</span>
                                    }
                                </NavLink>
                            </div>
                            <div class="nav-item">
                                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/facilities")">
                                    <i class="bi bi-building me-2"></i>Facilities
                                </NavLink>
                            </div>
                            <AuthorizeView Policy="CanManageUsers" Context="_mu3">
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/admin/entrances")">
                                        <i class="bi bi-door-open me-2"></i>Entrances
                                    </NavLink>
                                </div>
                            </AuthorizeView>
                            <AuthorizeView Roles="Admin" Context="_adm2">
                                <div class="nav-item">
                                    <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/admin/audit-log")">
                                        <i class="bi bi-journal-text me-2"></i>Audit Log
                                    </NavLink>
                                </div>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>

            </div><!-- /#nav-accordion -->

            <!-- Settings — standalone -->
            <div class="nav-item px-3 mt-1">
                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/settings")">
                    <i class="bi bi-gear me-2"></i>Settings
                </NavLink>
            </div>

        </nav>
    </AuthorizeView>

    <!-- ── RESIDENT NAVIGATION ──────────────────────────────────── -->
    <AuthorizeView Roles="Occupant">
        <nav class="nav flex-column mt-1">
            <div class="nav-section-label px-3 mb-1">
                <small class="text-white-50 text-uppercase fw-semibold" style="font-size:0.65rem;letter-spacing:0.08em;">Resident Portal</small>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident")" Match="NavLinkMatch.All">
                    <i class="bi bi-house me-2"></i>My Dashboard
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/visitors/preregister")">
                    <i class="bi bi-person-plus me-2"></i>Pre-register Visit
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/maintenance")">
                    <i class="bi bi-tools me-2"></i>Maintenance
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/vehicles")">
                    <i class="bi bi-car-front me-2"></i>My Vehicles
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"{TenantCtx.RouteBase}/resident/parcels")">
                    <i class="bi bi-box-seam me-2"></i>My Parcels
                </NavLink>
            </div>
        </nav>
    </AuthorizeView>

    <!-- ── Auth section ─────────────────────────────────────────── -->
    <div class="nav-auth-section mt-auto px-3 py-3">
        <AuthorizeView>
            <Authorized>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="user-nav-avatar">
                        @(context.User.Identity?.Name?.FirstOrDefault().ToString().ToUpperInvariant() ?? "?")
                    </div>
                    <div class="flex-grow-1 min-w-0">
                        <div class="text-white small fw-medium text-truncate">@context.User.Identity?.Name</div>
                        <small class="text-white-50" style="font-size:0.7rem;">Signed in</small>
                    </div>
                </div>
                <AuthorizeView Roles="Admin,Manager,Receptionist,Security" Context="staffCtx">
                    <Authorized>
                        <form method="post" action="@(TenantCtx.RouteBase)/api/logout">
                            <AntiForgeryToken />
                            <button type="submit" class="btn btn-sm btn-outline-light w-100">
                                <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <form method="post" action="@(TenantCtx.RouteBase)/api/resident/logout">
                            <AntiForgeryToken />
                            <button type="submit" class="btn btn-sm btn-outline-light w-100">
                                <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                            </button>
                        </form>
                    </NotAuthorized>
                </AuthorizeView>
            </Authorized>
            <NotAuthorized>
                <a href="@($"{TenantCtx.RouteBase}/login")" class="btn btn-sm btn-outline-light w-100">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                </a>
            </NotAuthorized>
        </AuthorizeView>
    </div>

</div>

@code {
    private int _pendingRequestCount;
    private int _openMaintenanceCount;
    private int _openIncidentCount;
    private int _vehiclesInsideCount;
    private int _pendingParcelCount;
    private string? _openGroup;

    protected override async Task OnInitializedAsync()
    {
        DetectCurrentGroup();

        if (TenantCtx.IsResolved)
        {
            _pendingRequestCount  = await UnitRequestSvc.GetPendingCountAsync();
            _openMaintenanceCount = await MaintenanceSvc.GetOpenCountAsync();
            _openIncidentCount    = await IncidentSvc.GetOpenCountAsync();
            _vehiclesInsideCount  = await ParkingSvc.GetCurrentlyInsideCountAsync();
            _pendingParcelCount   = await ParcelSvc.GetPendingCountAsync();
        }
    }

    private void DetectCurrentGroup()
    {
        var path = new Uri(Nav.Uri).AbsolutePath.ToLowerInvariant();
        _openGroup = path switch
        {
            var p when p.Contains("/check-in")   || p.Contains("/visitors")  || p.Contains("/access/")        => "access",
            var p when p.Contains("/parking")    || p.Contains("/parcels")   || p.Contains("/maintenance")    => "operations",
            var p when p.Contains("/admin/users") || p.Contains("/admin/units") || p.Contains("/admin/unit-requests") => "residents",
            var p when p.Contains("/admin/announcements") || p.Contains("/admin/documents")                   => "communications",
            var p when p.Contains("/reports")    || p.Contains("/incidents") || p.Contains("/admin/audit")
                    || p.Contains("/admin/entrances") || p.Contains("/facilities")                            => "management",
            _ => null
        };
    }

    private bool IsOpen(string name) => _openGroup == name;

    private string BrandingStyle =>
        !string.IsNullOrEmpty(TenantCtx.PrimaryColour)
            ? $"background: linear-gradient(180deg, {TenantCtx.PrimaryColour} 0%, color-mix(in srgb, {TenantCtx.PrimaryColour} 60%, #000) 100%) !important;"
            : "";
}

<style>
    /* ── Folder button ────────────────────────────────────────── */
    .nav-folder {
        margin: 1px 0;
    }

    .nav-folder-btn {
        display: flex;
        align-items: center;
        width: calc(100% - 1.5rem);
        margin: 0 0.75rem;
        padding: 0.42rem 0.65rem;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, .7);
        font-size: 0.875rem;
        cursor: pointer;
        border-radius: 6px;
        transition: background .15s, color .15s;
        text-align: left;
    }

    .nav-folder-btn:hover {
        background: rgba(255, 255, 255, .09);
        color: #fff;
    }

    .nav-folder-btn[aria-expanded="true"] {
        background: rgba(255, 255, 255, .12);
        color: #fff;
    }

    /* ── Chevron — driven by aria-expanded set by Bootstrap ──── */
    .nav-chevron {
        font-size: 0.68rem;
        flex-shrink: 0;
        transition: transform .2s ease;
    }

    .nav-folder-btn[aria-expanded="true"] .nav-chevron {
        transform: rotate(90deg);
    }

    /* ── Children container ──────────────────────────────────── */
    .nav-folder-children {
        margin: 2px 0.75rem 4px 2rem;
        padding-left: 0.5rem;
        border-left: 2px solid rgba(255, 255, 255, .12);
    }

    .nav-folder-children .nav-item {
        margin: 1px 0;
    }

    .nav-folder-children .nav-link {
        padding: 0.38rem 0.6rem;
        font-size: 0.845rem;
        border-radius: 5px;
        color: rgba(255, 255, 255, .65);
    }

    .nav-folder-children .nav-link:hover,
    .nav-folder-children .nav-link.active {
        color: #fff;
        background: rgba(255, 255, 255, .09);
    }

    /* ── Folder badge ────────────────────────────────────────── */
    .folder-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        font-size: 0.65rem;
        font-weight: 700;
        border-radius: 9px;
        background: rgba(99, 102, 241, .75);
        color: #fff;
    }

    .folder-badge-danger {
        background: rgba(220, 38, 38, .75);
    }
</style>
