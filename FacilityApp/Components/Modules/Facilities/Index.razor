@page "/{TenantSlug}/facilities"
@page "/facilities"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanManageUnits")]
@inject IFacilityService FacilitySvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx

<PageTitle>Facilities — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-building me-2 text-primary"></i>Facilities</h4>
        <small class="text-muted">Manage rooms, amenity spaces and common areas</small>
    </div>
    <button class="btn btn-primary" @onclick="OpenAdd">
        <i class="bi bi-plus-lg me-1"></i>Add Facility
    </button>
</div>

@if (_loadError is not null)
{
    <div class="alert alert-danger mt-4">
        <i class="bi bi-exclamation-triangle me-2"></i>@_loadError
    </div>
}
else if (_facilities is null)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
    </div>
}
else
{
    <!-- Summary -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-primary">@_facilities.Count</div>
                <div class="text-muted small">Total</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-success">@_facilities.Count(f => f.IsActive)</div>
                <div class="text-muted small">Active</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary">@_facilities.Count(f => !f.IsActive)</div>
                <div class="text-muted small">Inactive</div>
            </div>
        </div>
    </div>

    @if (_facilities.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-building fs-1 d-block mb-2 opacity-25"></i>
            No facilities yet. Click <strong>Add Facility</strong> to get started.
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Name</th>
                            <th>Location</th>
                            <th class="text-center">Capacity</th>
                            <th class="text-center">Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in _facilities)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">@f.Name</td>
                                <td class="text-muted small">@(f.Location ?? "—")</td>
                                <td class="text-center small">
                                    @(f.Capacity.HasValue ? f.Capacity.Value.ToString() : "—")
                                </td>
                                <td class="text-center">
                                    @if (f.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-ghost" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <button class="dropdown-item" @onclick="() => OpenEdit(f)">
                                                    <i class="bi bi-pencil me-2"></i>Edit
                                                </button>
                                            </li>
                                            <li>
                                                <button class="dropdown-item" @onclick="() => ToggleAsync(f)">
                                                    <i class="bi bi-@(f.IsActive ? "pause" : "play") me-2"></i>
                                                    @(f.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </li>
                                            <li><hr class="dropdown-divider" /></li>
                                            <li>
                                                <button class="dropdown-item text-danger"
                                                        @onclick="() => OpenDelete(f)">
                                                    <i class="bi bi-trash me-2"></i>Delete
                                                </button>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<!-- Add / Edit Modal -->
@if (_showForm)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-panel card shadow-lg">
        <div class="card-header border-0 pb-0 pt-4 px-4">
            <h5 class="fw-bold mb-0">@(_editing is null ? "Add Facility" : "Edit Facility")</h5>
        </div>
        <div class="card-body px-4">
            <EditForm Model="_form" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />

                @if (_error is not null)
                {
                    <div class="alert alert-danger py-2 small">@_error</div>
                }

                <div class="mb-3">
                    <label class="form-label fw-medium small">Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_form.Name" placeholder="e.g. Conference Room A" />
                    <ValidationMessage For="() => _form.Name" class="text-danger small" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-medium small">Location</label>
                    <InputText class="form-control" @bind-Value="_form.Location" placeholder="e.g. Block A, Ground Floor" />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-medium small">Capacity</label>
                    <InputNumber class="form-control" @bind-Value="_form.Capacity" placeholder="Max occupants" />
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editing is null ? "Add" : "Save Changes")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Delete Confirm Modal -->
@if (_deleteTarget is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-panel card shadow-lg" style="max-width: 420px;">
        <div class="card-body px-4 py-4">
            <h5 class="fw-bold mb-2"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Facility?</h5>
            <p class="text-muted mb-4">
                Are you sure you want to delete <strong>@_deleteTarget.Name</strong>? This cannot be undone.
            </p>
            @if (_error is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">@_error</div>
            }
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-outline-secondary" @onclick="CloseModals">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Facility>? _facilities;
    private bool  _showForm;
    private bool  _saving;
    private string? _error;
    private string? _loadError;
    private Facility? _editing;
    private Facility? _deleteTarget;
    private FacilityForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!TenantCtx.IsResolved)
            {
                var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
                if (tenant is not null)
                {
                    TenantCtx.TenantId   = tenant.Id;
                    TenantCtx.TenantSlug = tenant.Slug;
                    TenantCtx.TenantName = tenant.Name;
                    TenantCtx.IsResolved = true;
                }
            }
            await LoadAsync();
        }
        catch (Exception)
        {
            _loadError = "Failed to load facilities. Please refresh the page.";
        }
    }

    private async Task LoadAsync() => _facilities = await FacilitySvc.GetAllAsync();

    private void OpenAdd()
    {
        _editing = null; _form = new(); _error = null; _showForm = true;
    }

    private void OpenEdit(Facility f)
    {
        _editing = f;
        _form    = new FacilityForm { Name = f.Name, Location = f.Location, Capacity = f.Capacity };
        _error   = null;
        _showForm = true;
    }

    private void OpenDelete(Facility f) { _deleteTarget = f; _error = null; }

    private async Task SaveAsync()
    {
        _saving = true; _error = null;
        try
        {
            if (_editing is null)
                await FacilitySvc.CreateAsync(_form.Name, _form.Location, _form.Capacity);
            else
                await FacilitySvc.UpdateAsync(_editing.Id, _form.Name, _form.Location, _form.Capacity);
            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        _saving = true; _error = null;
        try
        {
            await FacilitySvc.DeleteAsync(_deleteTarget.Id);
            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ToggleAsync(Facility f)
    {
        try
        {
            await FacilitySvc.ToggleActiveAsync(f.Id);
            await LoadAsync();
        }
        catch (Exception)
        {
            _error = "Failed to update facility status. Please try again.";
        }
    }

    private void CloseModals() { _showForm = false; _deleteTarget = null; }

    private sealed class FacilityForm
    {
        [Required(ErrorMessage = "Name is required.")]
        [MaxLength(100)]
        public string Name { get; set; } = "";

        [MaxLength(200)]
        public string? Location { get; set; }

        [Range(1, 10000, ErrorMessage = "Capacity must be between 1 and 10,000.")]
        public int? Capacity { get; set; }
    }
}
