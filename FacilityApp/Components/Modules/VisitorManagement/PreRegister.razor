@page "/{TenantSlug}/visitors/preregister"
@page "/visitors/preregister"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IVisitorService VisitorSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx

<PageTitle>Pre-register Visit — @TenantCtx.TenantName</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-person-plus me-2 text-primary"></i>Pre-register Visit</h4>
        <small class="text-muted">Schedule a visitor in advance</small>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <EditForm Model="_form" OnValidSubmit="SubmitAsync" FormName="preregister">
            <DataAnnotationsValidator />

            @if (_error is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@_error
                </div>
            }
            @if (_success is not null)
            {
                <div class="alert alert-success mb-3">
                    <i class="bi bi-check-circle me-2"></i><strong>Visit scheduled!</strong>
                    <div class="mt-1 small">@_success</div>
                    <div class="mt-2">
                        <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-sm btn-outline-success me-2">View All Visits</a>
                        <button type="button" class="btn btn-sm btn-success" @onclick="RegisterAnother">Register Another</button>
                    </div>
                </div>
            }

            @if (_success is null)
            {
                <!-- Visitor Details -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold"><i class="bi bi-person me-2 text-primary"></i>Visitor Details</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Full Name <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.FullName" placeholder="Jane Doe" />
                                <ValidationMessage For="() => _form.FullName" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Email Address <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.Email" placeholder="jane@example.com" autocomplete="off" />
                                <ValidationMessage For="() => _form.Email" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Phone <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.Phone" placeholder="+1 555 000 0000" />
                                <ValidationMessage For="() => _form.Phone" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Company</label>
                                <InputText class="form-control" @bind-Value="_form.Company" placeholder="Acme Corp (optional)" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Visit Details -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar-event me-2 text-primary"></i>Visit Details</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-medium small">Purpose <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_form.Purpose"
                                           placeholder="e.g. Meeting, Maintenance, Delivery, Personal" />
                                <ValidationMessage For="() => _form.Purpose" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Host (optional)</label>
                                <InputSelect class="form-select" @bind-Value="_form.HostUserId">
                                    <option value="">— No host —</option>
                                    @if (_hosts is not null)
                                    {
                                        @foreach (var h in _hosts)
                                        {
                                            <option value="@h.Id">@h.FullName (@h.UserType)</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-medium small">Date <span class="text-danger">*</span></label>
                                <InputDate class="form-control" @bind-Value="_form.VisitDate" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-medium small">Time <span class="text-danger">*</span></label>
                                <input type="time" class="form-control" @bind="_visitTime" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-calendar-plus me-2"></i>
                        }
                        Schedule Visit
                    </button>
                    <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-outline-secondary">Cancel</a>
                </div>
            }
        </EditForm>
    </div>

    <!-- Info panel -->
    <div class="col-lg-5">
        <div class="card border-0 bg-light">
            <div class="card-body py-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>About Pre-registration</h6>
                <ul class="list-unstyled small text-muted mb-0">
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>The visit is saved with <strong>Scheduled</strong> status.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Security or reception staff will check the visitor in on arrival.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>If the visitor's email is already on record, their details are updated.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Pre-registered visits appear on the dashboard's <strong>Upcoming Visits</strong> panel.</li>
                    <li><i class="bi bi-check2 text-success me-2"></i>You can cancel from the <strong>Visitors</strong> list if plans change.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private PreRegForm _form = new();
    private TimeOnly _visitTime = new TimeOnly(10, 0);
    private List<ApplicationUser>? _hosts;
    private string? _error;
    private string? _success;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
        _hosts = await VisitorSvc.GetHostsAsync();
    }

    private async Task SubmitAsync()
    {
        _busy  = true;
        _error = null;

        try
        {
            var scheduledLocal = _form.VisitDate.ToDateTime(_visitTime);
            var scheduledAt    = DateTime.SpecifyKind(scheduledLocal, DateTimeKind.Local).ToUniversalTime();

            if (scheduledAt < DateTime.UtcNow)
            {
                _error = "Scheduled date and time cannot be in the past.";
                _busy  = false;
                return;
            }

            var hostId = string.IsNullOrEmpty(_form.HostUserId) ? null : _form.HostUserId;
            await VisitorSvc.PreRegisterAsync(
                _form.FullName, _form.Email, _form.Phone, _form.Company,
                _form.Purpose, hostId, scheduledAt);

            var hostName = _hosts?.FirstOrDefault(h => h.Id == _form.HostUserId)?.FullName;
            _success = $"{_form.FullName} is scheduled to visit on {scheduledAt.ToLocalTime():MMM d, yyyy} at {scheduledAt.ToLocalTime():h:mm tt}"
                     + (hostName is not null ? $", hosted by {hostName}." : ".");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void RegisterAnother()
    {
        _form      = new PreRegForm();
        _visitTime = new TimeOnly(10, 0);
        _success   = null;
        _error     = null;
    }

    private sealed class PreRegForm
    {
        [Required(ErrorMessage = "Full name is required.")]
        [MaxLength(100)]
        public string FullName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Phone number is required.")]
        [MaxLength(30)]
        public string Phone { get; set; } = "";

        [MaxLength(100)]
        public string? Company { get; set; }

        [Required(ErrorMessage = "Purpose is required.")]
        [MaxLength(100)]
        public string Purpose { get; set; } = "";

        public string? HostUserId { get; set; }

        public DateOnly VisitDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(1));
    }
}
