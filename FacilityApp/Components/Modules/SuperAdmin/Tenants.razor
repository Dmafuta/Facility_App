@page "/superadmin/tenants"
@rendermode InteractiveServer
@layout SuperAdminLayout
@attribute [Authorize(Roles = "SuperAdmin")]
@inject AppDbContext Db
@inject NavigationManager Nav

@using FacilityApp.Data.Models

<PageTitle>Tenants — Super Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-grid me-2 text-primary"></i>All Tenants</h4>
        <small class="text-muted">Manage all facilities in this installation</small>
    </div>
    <a href="/superadmin/tenants/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Tenant
    </a>
</div>

@if (_tenants is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_tenants.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-buildings fs-1 d-block mb-2 opacity-25"></i>
        No tenants yet. <a href="/superadmin/tenants/create">Create the first one</a>.
    </div>
}
else
{
    <!-- Plan summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary">@_tenants.Count(t => t.Plan == TenantPlan.Starter)</div>
                <div class="text-muted small">Starter</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-warning">@_tenants.Count(t => t.Plan == TenantPlan.Professional)</div>
                <div class="text-muted small">Professional</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-primary">@_tenants.Count</div>
                <div class="text-muted small">Total</div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>Slug</th>
                        <th>Plan</th>
                        <th class="text-center">Status</th>
                        <th>Custom Domain</th>
                        <th>Created</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _tenants)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@t.Name</td>
                            <td><code class="small">@t.Slug</code></td>
                            <td>
                                @if (t.Plan == TenantPlan.Professional)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-star-fill me-1"></i>Professional
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Starter</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (t.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @if (!string.IsNullOrEmpty(t.CustomDomain))
                                {
                                    <a href="https://@t.CustomDomain" target="_blank" class="text-decoration-none">
                                        <i class="bi bi-globe me-1"></i>@t.CustomDomain
                                    </a>
                                }
                                else { <span>—</span> }
                            </td>
                            <td class="text-muted small">@t.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                            <td class="text-end pe-3">
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    <a href="/@t.Slug/dashboard" target="_blank"
                                       class="btn btn-sm btn-outline-primary" title="Open tenant portal">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                    <button class="btn btn-sm @(t.Plan == TenantPlan.Professional ? "btn-outline-secondary" : "btn-outline-warning")"
                                            @onclick="() => TogglePlanAsync(t)"
                                            title="@(t.Plan == TenantPlan.Professional ? "Downgrade to Starter" : "Upgrade to Professional")">
                                        @if (t.Plan == TenantPlan.Professional)
                                        {
                                            <i class="bi bi-arrow-down-circle me-1"></i><span class="d-none d-md-inline">Downgrade</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star me-1"></i><span class="d-none d-md-inline">Upgrade</span>
                                        }
                                    </button>
                                    <button class="btn btn-sm @(t.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            @onclick="() => ToggleActiveAsync(t)"
                                            title="@(t.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi bi-@(t.IsActive ? "pause" : "play")"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 text-muted small">@_tenants.Count tenant(s) total</div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    private List<Tenant>? _tenants;
    private string? _toast;
    private string _toastType = "success";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            _tenants = await Db.Tenants
                .IgnoreQueryFilters()
                .Where(t => !t.IsSystem)
                .OrderBy(t => t.Name)
                .ToListAsync();
        }
        catch (Exception)
        {
            _tenants = [];
            ShowToast("Failed to load tenants. Please refresh.", "danger");
        }
    }

    private async Task TogglePlanAsync(Tenant t)
    {
        try
        {
            t.Plan = t.Plan == TenantPlan.Professional ? TenantPlan.Starter : TenantPlan.Professional;
            await Db.SaveChangesAsync();
            var action = t.Plan == TenantPlan.Professional ? "upgraded to Professional" : "downgraded to Starter";
            ShowToast($"{t.Name} {action}.", t.Plan == TenantPlan.Professional ? "warning" : "secondary");
        }
        catch (Exception)
        {
            ShowToast("Failed to update plan. Please try again.", "danger");
        }
    }

    private async Task ToggleActiveAsync(Tenant t)
    {
        try
        {
            t.IsActive = !t.IsActive;
            await Db.SaveChangesAsync();
            ShowToast($"{t.Name} {(t.IsActive ? "activated" : "deactivated")}.", t.IsActive ? "success" : "warning");
        }
        catch (Exception)
        {
            t.IsActive = !t.IsActive; // revert
            ShowToast("Failed to update tenant status. Please try again.", "danger");
        }
    }

    private void ShowToast(string message, string type)
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }
}
