@page "/{TenantSlug}/resident/vehicles"
@page "/resident/vehicles"
@layout ResidentLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject IParkingService ParkingSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState

@using FacilityApp.Data.Models

<PageTitle>My Vehicles — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-car-front me-2 text-primary"></i>My Vehicles</h4>
        <small class="text-muted">Register your vehicles and view your access tags</small>
    </div>
    @if (!_showForm)
    {
        <button class="btn btn-primary" @onclick="() => _showForm = true">
            <i class="bi bi-plus-lg me-1"></i>Register Vehicle
        </button>
    }
</div>

@if (_showForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-2 text-primary"></i>Register New Vehicle</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-medium">Plate Number <span class="text-danger">*</span></label>
                    <input class="form-control text-uppercase" placeholder="e.g. ABC 123" @bind="_plate" maxlength="20" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">Make <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="e.g. Toyota" @bind="_make" maxlength="60" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">Model <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="e.g. Corolla" @bind="_model" maxlength="60" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">Colour <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="e.g. Silver" @bind="_colour" maxlength="40" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">Vehicle Type</label>
                    <select class="form-select" @bind="_vehicleType">
                        @foreach (var t in Enum.GetValues<VehicleType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-medium">Notes <span class="text-muted fw-normal">(optional)</span></label>
                    <input class="form-control" placeholder="Any extra details" @bind="_notes" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger mt-3 mb-0">@_formError</div>
            }
        </div>
        <div class="card-footer bg-white border-top d-flex gap-2 justify-content-end">
            <button class="btn btn-outline-secondary" @onclick="CancelForm" disabled="@_busy">Cancel</button>
            <button class="btn btn-primary" @onclick="RegisterAsync" disabled="@_busy">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Register Vehicle
            </button>
        </div>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_vehicles.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-car-front fs-1 d-block mb-2 opacity-25"></i>
        <p class="mb-2">No vehicles registered yet.</p>
        <button class="btn btn-primary" @onclick="() => _showForm = true">
            <i class="bi bi-plus-lg me-1"></i>Register Your First Vehicle
        </button>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var v in _vehicles)
        {
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="mb-0 fw-bold">@v.PlateNumber</h5>
                                <div class="text-muted small">@v.Make @v.Model · @v.Colour · @v.Type</div>
                            </div>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteAsync(v.Id)"
                                    disabled="@_busy"
                                    title="Remove vehicle">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>

                        @if (v.Tag is not null)
                        {
                            <div class="border rounded p-3 mt-3 @(v.Tag.Status == TagStatus.Active ? "border-success bg-success bg-opacity-10" : "border-warning bg-warning bg-opacity-10")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold fs-5">@v.Tag.TagNumber</div>
                                        <small class="text-muted">Access Tag</small>
                                    </div>
                                    @((MarkupString)TagStatusBadge(v.Tag.Status))
                                </div>
                                @if (v.Tag.ExpiresAt.HasValue)
                                {
                                    var expired = v.Tag.ExpiresAt.Value < DateTime.UtcNow;
                                    <div class="mt-2 small @(expired ? "text-danger fw-medium" : "text-muted")">
                                        <i class="bi bi-calendar @(expired ? "text-danger" : "") me-1"></i>
                                        @(expired ? "Expired" : "Expires") @v.Tag.ExpiresAt.Value.ToLocalTime().ToString("MMMM d, yyyy")
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(v.Tag.Notes))
                                {
                                    <div class="mt-1 small text-muted">@v.Tag.Notes</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="border rounded p-3 mt-3 border-secondary bg-light text-center">
                                <i class="bi bi-tag text-muted fs-4 d-block mb-1"></i>
                                <div class="text-muted small">No access tag issued yet.</div>
                                <div class="text-muted" style="font-size:0.75rem;">Contact the facility office to request a tag.</div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(v.Notes))
                        {
                            <div class="mt-2 text-muted small"><i class="bi bi-info-circle me-1"></i>@v.Notes</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Vehicle> _vehicles = [];
    private bool _loading = true;
    private bool _busy;
    private bool _showForm;
    private string _userId = "";

    private string _plate = "";
    private string _make = "";
    private string _model = "";
    private string _colour = "";
    private VehicleType _vehicleType = VehicleType.Car;
    private string _notes = "";
    private string _formError = "";

    private string? _toast;
    private string _toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId  = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (!string.IsNullOrEmpty(_userId))
            _vehicles = await ParkingSvc.GetVehiclesForResidentAsync(_userId);

        _loading = false;
    }

    private async Task RegisterAsync()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_plate))  { _formError = "Plate number is required."; return; }
        if (string.IsNullOrWhiteSpace(_make))   { _formError = "Make is required."; return; }
        if (string.IsNullOrWhiteSpace(_model))  { _formError = "Model is required."; return; }
        if (string.IsNullOrWhiteSpace(_colour)) { _formError = "Colour is required."; return; }

        _busy = true;
        try
        {
            await ParkingSvc.RegisterVehicleAsync(_userId, _plate, _make, _model, _colour, _vehicleType, _notes);
            _vehicles = await ParkingSvc.GetVehiclesForResidentAsync(_userId);
            CancelForm();
            ShowToast("Vehicle registered successfully.", "success");
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(Guid id)
    {
        _busy = true;
        try
        {
            await ParkingSvc.DeleteVehicleAsync(id);
            _vehicles = await ParkingSvc.GetVehiclesForResidentAsync(_userId);
            ShowToast("Vehicle removed.", "warning");
        }
        catch (Exception ex) { ShowToast(ex.Message, "danger"); }
        finally { _busy = false; }
    }

    private void CancelForm()
    {
        _showForm    = false;
        _plate       = "";
        _make        = "";
        _model       = "";
        _colour      = "";
        _vehicleType = VehicleType.Car;
        _notes       = "";
        _formError   = "";
    }

    private void ShowToast(string message, string type)
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }

    private static string TagStatusBadge(TagStatus s) => s switch
    {
        TagStatus.Active    => "<span class=\"badge bg-success\">Active</span>",
        TagStatus.Suspended => "<span class=\"badge bg-warning text-dark\">Suspended</span>",
        TagStatus.Revoked   => "<span class=\"badge bg-danger\">Revoked</span>",
        TagStatus.Expired   => "<span class=\"badge bg-secondary\">Expired</span>",
        _                   => "<span class=\"badge bg-light text-dark\">—</span>"
    };
}
