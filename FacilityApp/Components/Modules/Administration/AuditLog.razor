@page "/{TenantSlug}/admin/audit-log"
@page "/admin/audit-log"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanManageUsers")]
@inject IAuditService AuditSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx

<PageTitle>Audit Log — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2 text-primary"></i>Audit Log</h4>
        <small class="text-muted">Track all actions performed in this facility</small>
    </div>
</div>

<!-- Search bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input class="form-control" placeholder="Search by user, action or entity…"
                           @bind="_search" @bind:event="oninput"
                           @onkeyup="OnSearchKeyUp" />
                    @if (!string.IsNullOrEmpty(_search))
                    {
                        <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    }
                </div>
            </div>
            <div class="col-auto ms-auto">
                <small class="text-muted">@_total total entries</small>
            </div>
        </div>
    </div>
</div>

@if (_logs is null)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
    </div>
}
else if (_logs.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-journal fs-1 d-block mb-2 opacity-25"></i>
        No audit log entries found.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in _logs)
                    {
                        <tr>
                            <td class="ps-3 text-muted small text-nowrap">
                                @log.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")
                            </td>
                            <td>
                                <span class="fw-medium small">@log.UserName</span>
                            </td>
                            <td>
                                <span class="badge @ActionBadgeClass(log.Action)">@log.Action</span>
                            </td>
                            <td class="small text-muted">
                                @log.EntityType
                                @if (log.EntityId is not null)
                                {
                                    <br /><code class="small" style="font-size:0.7rem;">@log.EntityId[..Math.Min(8, log.EntityId.Length)]…</code>
                                }
                            </td>
                            <td class="small text-muted" style="max-width:300px;white-space:normal;">
                                @(log.Details ?? "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-3 small text-muted">
            <span>Showing @((_page - 1) * PageSize + 1)–@(Math.Min(_page * PageSize, _total)) of @_total</span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPageAsync(_page - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @for (int p = Math.Max(1, _page - 2); p <= Math.Min(TotalPages, _page + 2); p++)
                    {
                        var pg = p;
                        <li class="page-item @(pg == _page ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPageAsync(pg)">@pg</button>
                        </li>
                    }
                    <li class="page-item @(_page >= TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPageAsync(_page + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        </div>
    }
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<FacilityApp.Data.Models.AuditLog>? _logs;
    private int _total;
    private int _page = 1;
    private string _search = "";
    private const int PageSize = 50;
    private int TotalPages => (int)Math.Ceiling(_total / (double)PageSize);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!TenantCtx.IsResolved)
            {
                var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
                if (tenant is not null)
                {
                    TenantCtx.TenantId   = tenant.Id;
                    TenantCtx.TenantSlug = tenant.Slug;
                    TenantCtx.TenantName = tenant.Name;
                    TenantCtx.IsResolved = true;
                }
            }
            await LoadAsync();
        }
        catch (Exception)
        {
            _logs = [];
        }
    }

    private async Task LoadAsync()
    {
        try
        {
            var result = await AuditSvc.GetLogsAsync(_search, _page, PageSize);
            _logs  = result.Items;
            _total = result.Total;
        }
        catch (Exception)
        {
            _logs = [];
        }
    }

    private async Task GoToPageAsync(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadAsync(); }
    }

    private async Task ClearSearch()
    {
        _search = ""; _page = 1;
        await LoadAsync();
    }

    private static string ActionBadgeClass(string action) => action.ToLower() switch
    {
        "checkin"     => "bg-success-subtle text-success",
        "checkout"    => "bg-primary-subtle text-primary",
        "preregister" => "bg-info-subtle text-info",
        "walkin"      => "bg-success-subtle text-success",
        "cancel"      => "bg-secondary-subtle text-secondary",
        "delete"      => "bg-danger-subtle text-danger",
        "create"      => "bg-primary-subtle text-primary",
        "update"      => "bg-warning-subtle text-warning-emphasis",
        _             => "bg-light text-dark border"
    };
}
