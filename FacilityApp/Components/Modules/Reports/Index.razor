@page "/{TenantSlug}/reports"
@page "/reports"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanViewReports")]
@inject IReportService ReportSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject NavigationManager Nav

<PageTitle>Reports — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-bar-chart-line me-2 text-primary"></i>Reports</h4>
        <small class="text-muted">Visitor analytics for @TenantCtx.TenantName</small>
    </div>
</div>

<!-- Date range -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="d-flex flex-wrap align-items-end gap-3">
            <div>
                <label class="form-label fw-medium small mb-1">From</label>
                <InputDate class="form-control form-control-sm" @bind-Value="_from" />
            </div>
            <div>
                <label class="form-label fw-medium small mb-1">To</label>
                <InputDate class="form-control form-control-sm" @bind-Value="_to" />
            </div>
            <button class="btn btn-primary btn-sm" @onclick="LoadAsync" disabled="@_loading">
                @if (_loading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                else { <i class="bi bi-arrow-clockwise me-1"></i> }
                Apply
            </button>
            <div class="ms-auto">
                <a href="@(TenantCtx.RouteBase)/api/reports/export?from=@_from.ToString("yyyy-MM-dd")&to=@_to.ToString("yyyy-MM-dd")"
                   class="btn btn-outline-secondary btn-sm" target="_blank">
                    <i class="bi bi-download me-1"></i>Export CSV
                </a>
            </div>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading report…</p>
    </div>
}
else if (_stats is not null)
{
    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        @{
            var cards = new[]
            {
                ("Total Visits",    _stats.TotalVisits.ToString(),            "bi-calendar-event",  "primary"),
                ("Check-in Rate",   $"{_stats.CheckInRate}%",                 "bi-person-check",    "success"),
                ("Avg / Day",       _stats.AvgPerDay.ToString("0.0"),         "bi-graph-up",        "info"),
                ("No-shows",        _stats.TotalNoShow.ToString(),            "bi-person-x",        "warning"),
                ("Cancelled",       _stats.TotalCancelled.ToString(),         "bi-x-circle",        "danger"),
                ("Currently Inside",_stats.TotalCheckedIn.ToString(),         "bi-door-open",       "secondary"),
            };
        }
        @foreach (var (label, value, icon, color) in cards)
        {
            <div class="col-xl-2 col-md-4 col-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="report-label">@label</p>
                                <h3 class="report-value text-@color">@value</h3>
                            </div>
                            <div class="report-icon bg-@color bg-opacity-10 text-@color">
                                <i class="bi @icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-4 mb-4">
        <!-- Daily breakdown -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold">
                        <i class="bi bi-calendar-range me-2 text-primary"></i>Daily Breakdown
                    </h6>
                </div>
                <div class="card-body p-0">
                    @if (_stats.DailyBreakdown.Count == 0)
                    {
                        <div class="text-center py-4 text-muted">No visit data in this period.</div>
                    }
                    else
                    {
                        <div class="table-responsive" style="max-height: 360px; overflow-y: auto;">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th class="ps-3">Date</th>
                                        <th class="text-center">Total</th>
                                        <th class="text-center">Checked In</th>
                                        <th class="text-center">No-show</th>
                                        <th>Rate</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var maxTotal = _stats.DailyBreakdown.Max(d => d.Total);
                                        maxTotal = maxTotal == 0 ? 1 : maxTotal;
                                    }
                                    @foreach (var d in _stats.DailyBreakdown)
                                    {
                                        var rate = d.Total == 0 ? 0 : d.CheckedIn * 100 / d.Total;
                                        var barW = d.Total * 100 / maxTotal;
                                        <tr>
                                            <td class="ps-3 small">@d.Date.ToString("ddd, MMM d")</td>
                                            <td class="text-center fw-bold">@d.Total</td>
                                            <td class="text-center text-success">@d.CheckedIn</td>
                                            <td class="text-center text-warning">@d.NoShow</td>
                                            <td style="width: 160px;">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="progress flex-grow-1" style="height:8px;">
                                                        <div class="progress-bar bg-success" style="width:@barW%"></div>
                                                    </div>
                                                    <small class="text-muted" style="width:30px;">@rate%</small>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Hourly distribution -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold">
                        <i class="bi bi-clock me-2 text-info"></i>Peak Hours
                    </h6>
                    <small class="text-muted">Based on check-in time</small>
                </div>
                <div class="card-body p-0">
                    @if (_stats.HourlyBreakdown.Count == 0)
                    {
                        <div class="text-center py-4 text-muted small">No check-in data yet.</div>
                    }
                    else
                    {
                        var maxHour = _stats.HourlyBreakdown.Max(h => h.Count);
                        maxHour = maxHour == 0 ? 1 : maxHour;
                        <div style="max-height: 360px; overflow-y: auto;">
                            @foreach (var h in _stats.HourlyBreakdown.OrderByDescending(x => x.Count).Take(12))
                            {
                                var barPct = h.Count * 100 / maxHour;
                                var label  = DateTime.Today.AddHours(h.Hour).ToString("h tt");
                                <div class="px-3 py-2 border-bottom d-flex align-items-center gap-3">
                                    <span class="small text-muted" style="width:48px;">@label</span>
                                    <div class="progress flex-grow-1" style="height: 10px;">
                                        <div class="progress-bar bg-info" style="width:@barPct%"></div>
                                    </div>
                                    <span class="small fw-bold" style="width: 24px;">@h.Count</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Top visitors -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-semibold">
                <i class="bi bi-person-lines-fill me-2 text-success"></i>Top Visitors
            </h6>
        </div>
        <div class="card-body p-0">
            @if (_stats.TopVisitors.Count == 0)
            {
                <div class="text-center py-4 text-muted">No visitor data in this period.</div>
            }
            else
            {
                var maxVisits = _stats.TopVisitors.Max(v => v.Visits);
                maxVisits = maxVisits == 0 ? 1 : maxVisits;
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">#</th>
                                <th>Visitor</th>
                                <th>Email</th>
                                <th>Visits</th>
                                <th style="width: 200px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < _stats.TopVisitors.Count; i++)
                            {
                                var v   = _stats.TopVisitors[i];
                                var pct = v.Visits * 100 / maxVisits;
                                <tr>
                                    <td class="ps-3 text-muted small">@(i + 1)</td>
                                    <td class="fw-medium">@v.FullName</td>
                                    <td class="text-muted small">@v.Email</td>
                                    <td class="fw-bold text-success">@v.Visits</td>
                                    <td>
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-success" style="width:@pct%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private ReportStats? _stats;
    private bool _loading = true;
    private DateOnly _from = DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
    private DateOnly _to   = DateOnly.FromDateTime(DateTime.Today);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!TenantCtx.IsResolved)
            {
                var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
                if (tenant is not null)
                {
                    TenantCtx.TenantId   = tenant.Id;
                    TenantCtx.TenantSlug = tenant.Slug;
                    TenantCtx.TenantName = tenant.Name;
                    TenantCtx.IsResolved = true;
                }
            }
            await LoadAsync();
        }
        catch (Exception)
        {
            _loading = false;
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _stats = await ReportSvc.GetStatsAsync(_from, _to);
        }
        catch (Exception)
        {
            // stats remains null — page shows empty state
        }
        finally
        {
            _loading = false;
        }
    }
}
