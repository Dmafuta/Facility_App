@page "/{TenantSlug}/admin/users"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanManageUsers")]
@inject UserManager<ApplicationUser> UserManager
@inject AppDbContext Db
@inject ITenantService TenantService
@inject TenantContext TenantCtx

<PageTitle>User Management — @TenantCtx.TenantName</PageTitle>

@if (loading)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="px-2 py-3">

        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-people-fill me-2 text-primary"></i>User Management
                </h4>
                <small class="text-muted">Manage residents, home-owners, and staff for @TenantCtx.TenantName</small>
            </div>
            <button class="btn btn-primary" @onclick="ShowAddStaff">
                <i class="bi bi-person-plus me-2"></i>Add Staff Member
            </button>
        </div>

        <!-- Add Staff Form -->
        @if (showStaffForm)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
                    <h6 class="mb-0 fw-semibold">
                        <i class="bi bi-person-badge me-2 text-primary"></i>New Staff Account
                    </h6>
                    <button class="btn-close" @onclick="HideStaffForm"></button>
                </div>
                <div class="card-body">
                    @if (formErrors.Count > 0)
                    {
                        <div class="alert alert-danger py-2 small">
                            @foreach (var e in formErrors)
                            {
                                <div><i class="bi bi-exclamation-circle me-1"></i>@e</div>
                            }
                        </div>
                    }
                    @if (formSuccess is not null)
                    {
                        <div class="alert alert-success py-2 small">
                            <i class="bi bi-check-circle me-2"></i>@formSuccess
                        </div>
                    }

                    <EditForm Model="staffInput" OnValidSubmit="CreateStaffAsync" FormName="create-staff">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Full Name</label>
                                <InputText @bind-Value="staffInput.FullName" class="form-control" placeholder="Jane Doe" />
                                <ValidationMessage For="() => staffInput.FullName" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium small">Email Address</label>
                                <InputText @bind-Value="staffInput.Email" class="form-control" placeholder="jane@facility.com" />
                                <ValidationMessage For="() => staffInput.Email" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium small">Staff Role</label>
                                <InputSelect @bind-Value="staffInput.Role" class="form-select">
                                    <option value="@Program.RoleReceptionist">Receptionist — Front desk check-in</option>
                                    <option value="@Program.RoleSecurity">Security — Check-in/out visitors</option>
                                    <option value="@Program.RoleManager">Manager — Operations &amp; reports</option>
                                    <option value="@Program.RoleAdmin">Admin — Full access</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium small">Password</label>
                                <InputText type="password" @bind-Value="staffInput.Password" class="form-control" placeholder="Min. 8 characters" />
                                <ValidationMessage For="() => staffInput.Password" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium small">Confirm Password</label>
                                <InputText type="password" @bind-Value="staffInput.ConfirmPassword" class="form-control" placeholder="Repeat password" />
                                <ValidationMessage For="() => staffInput.ConfirmPassword" class="text-danger small" />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary me-2" disabled="@saving">
                                    @if (saving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-check me-1"></i>
                                    }
                                    Create Staff Account
                                </button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="HideStaffForm">Cancel</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        }

        <!-- Filter Tabs -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-0">
                <ul class="nav nav-tabs border-0">
                    @foreach (var tab in tabs)
                    {
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == tab ? "active" : "")"
                                    @onclick="() => { activeTab = tab; _usersPage = 1; }">
                                @tab
                                <span class="badge bg-secondary ms-1 small">@CountForTab(tab)</span>
                            </button>
                        </li>
                    }
                </ul>
            </div>
            <div class="card-body p-0">
                @{
                    var filtered = FilteredUsers();
                }
                @if (!filtered.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-people fs-1 d-block mb-2"></i>
                        No @activeTab.ToLower() found.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">User</th>
                                    <th>Type</th>
                                    <th>Role</th>
                                    <th>Joined</th>
                                    <th class="text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in filtered)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="user-avatar-sm @AvatarClass(row.UserType)">
                                                    @(row.FullName.FirstOrDefault().ToString().ToUpperInvariant())
                                                </div>
                                                <div>
                                                    <div class="fw-medium">@row.FullName</div>
                                                    <small class="text-muted">@row.Email</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@((MarkupString)UserTypeBadge(row.UserType))</td>
                                        <td>
                                            @if (row.Roles.Any())
                                            {
                                                @foreach (var role in row.Roles)
                                                {
                                                    <span class="badge bg-light text-dark border me-1">@role</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                        <td>
                                            <small class="text-muted">@row.CreatedAt.ToString("MMM d, yyyy")</small>
                                        </td>
                                        <td class="text-end pe-3">
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => OpenEditRoles(row)">
                                                <i class="bi bi-pencil me-1"></i>Edit Roles
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                @if (UsersTotalPages > 1)
                {
                    <div class="px-3 py-2 border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <small class="text-muted">
                            Showing @((_usersPage - 1) * UsersPageSize + 1)–@(Math.Min(_usersPage * UsersPageSize, TabUsersTotal)) of @TabUsersTotal
                        </small>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item @(_usersPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => _usersPage--">&laquo;</button>
                                </li>
                                @for (var p = Math.Max(1, _usersPage - 2); p <= Math.Min(UsersTotalPages, _usersPage + 2); p++)
                                {
                                    var pg = p;
                                    <li class="page-item @(pg == _usersPage ? "active" : "")">
                                        <button class="page-link" @onclick="() => _usersPage = pg">@pg</button>
                                    </li>
                                }
                                <li class="page-item @(_usersPage == UsersTotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => _usersPage++">&raquo;</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            </div>
        </div>

        <!-- Edit Roles Modal -->
        @if (editTarget is not null)
        {
            <div class="modal-backdrop-custom" @onclick="CloseEditRoles"></div>
            <div class="modal-panel card border-0 shadow-lg">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
                    <div>
                        <h6 class="mb-0 fw-semibold">Edit Roles</h6>
                        <small class="text-muted">@editTarget.FullName</small>
                    </div>
                    <button class="btn-close" @onclick="CloseEditRoles"></button>
                </div>
                <div class="card-body">
                    @if (editTarget.UserType == UserType.Staff)
                    {
                        <p class="text-muted small mb-3">Assign a staff role to control access level.</p>
                        @foreach (var role in staffRoles)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="role_@role"
                                       checked="@editTarget.Roles.Contains(role)"
                                       @onchange="e => ToggleRole(editTarget, role, (bool)e.Value!)" />
                                <label class="form-check-label" for="role_@role">
                                    <strong>@role</strong>
                                    <small class="text-muted ms-2">@RoleDescription(role)</small>
                                </label>
                            </div>
                        }
                    }
                    else if (editTarget.UserType == UserType.HomeOwner)
                    {
                        <p class="text-muted small mb-3">
                            Assign the <strong>Occupant</strong> role if this home-owner also lives in their unit.
                        </p>
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="role_occupant"
                                   checked="@editTarget.Roles.Contains(Program.RoleOccupant)"
                                   @onchange="e => ToggleRole(editTarget, Program.RoleOccupant, (bool)e.Value!)" />
                            <label class="form-check-label" for="role_occupant">
                                <strong>Occupant</strong>
                                <small class="text-muted ms-2">Lives in their unit — can pre-register visitors</small>
                            </label>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small">
                            Residents are always Occupants and can pre-register visitors. No additional roles to assign.
                        </p>
                    }
                    @if (editMessage is not null)
                    {
                        <div class="alert alert-success py-2 small mt-3">
                            <i class="bi bi-check-circle me-1"></i>@editMessage
                        </div>
                    }
                </div>
                <div class="card-footer bg-white border-top text-end">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseEditRoles">Close</button>
                </div>
            </div>
        }

    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = string.Empty;

    private bool loading = true;
    private bool showStaffForm;
    private bool saving;
    private string? formSuccess;
    private string? editMessage;
    private List<string> formErrors = [];
    private List<UserRow> allUsers = [];
    private UserRow? editTarget;
    private string activeTab = "All";
    private static readonly string[] tabs = ["All", "Staff", "Home Owners", "Residents"];
    private static readonly string[] staffRoles = [Program.RoleAdmin, Program.RoleManager, Program.RoleReceptionist, Program.RoleSecurity];

    private int _usersPage = 1;
    private const int UsersPageSize = 25;

    private StaffInput staffInput = new();

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantService.ResolveBySlugAsync(TenantSlug);
            if (tenant is null) { loading = false; return; }

            TenantCtx.TenantId   = tenant.Id;
            TenantCtx.TenantSlug = tenant.Slug;
            TenantCtx.TenantName = tenant.Name;
            TenantCtx.IsResolved = true;
        }

        await LoadUsersAsync();
        loading = false;
    }

    private async Task LoadUsersAsync()
    {
        var users   = UserManager.Users.ToList();
        var userIds = users.Select(u => u.Id).ToList();

        // Fetch all user-role mappings in a single query (no N+1)
        var userRoles = await Db.UserRoles
            .Where(ur => userIds.Contains(ur.UserId))
            .Join(Db.Roles, ur => ur.RoleId, r => r.Id,
                  (ur, r) => new { ur.UserId, r.Name })
            .ToListAsync();

        var rolesByUser = userRoles
            .GroupBy(ur => ur.UserId)
            .ToDictionary(g => g.Key, g => g.Select(ur => ur.Name!).ToList());

        allUsers = users.Select(u => new UserRow
        {
            Id        = u.Id,
            FullName  = u.FullName,
            Email     = u.Email ?? string.Empty,
            UserType  = u.UserType,
            Roles     = rolesByUser.TryGetValue(u.Id, out var r) ? r : [],
            CreatedAt = u.CreatedAt
        })
        .OrderBy(r => r.UserType)
        .ThenBy(r => r.FullName)
        .ToList();
    }

    private async Task CreateStaffAsync()
    {
        saving = true;
        formErrors.Clear();
        formSuccess = null;

        var user = new ApplicationUser
        {
            UserName = staffInput.Email,
            Email    = staffInput.Email,
            FullName = staffInput.FullName,
            TenantId = TenantCtx.TenantId,
            UserType = UserType.Staff
        };

        var result = await UserManager.CreateAsync(user, staffInput.Password);
        if (!result.Succeeded)
        {
            formErrors.AddRange(result.Errors.Select(e => e.Description));
            saving = false;
            return;
        }

        await UserManager.AddToRoleAsync(user, staffInput.Role);
        formSuccess = $"{staffInput.FullName} was created as {staffInput.Role}.";
        staffInput = new StaffInput();
        await LoadUsersAsync();
        saving = false;
    }

    private async Task ToggleRole(UserRow row, string role, bool add)
    {
        editMessage = null;
        var user = await UserManager.FindByIdAsync(row.Id);
        if (user is null) return;

        if (add)
            await UserManager.AddToRoleAsync(user, role);
        else
            await UserManager.RemoveFromRoleAsync(user, role);

        row.Roles = (await UserManager.GetRolesAsync(user)).ToList();
        editMessage = $"Role '{role}' {(add ? "granted" : "removed")}.";
    }

    private IEnumerable<UserRow> TabUsers() => activeTab switch
    {
        "Staff"       => allUsers.Where(u => u.UserType == UserType.Staff),
        "Home Owners" => allUsers.Where(u => u.UserType == UserType.HomeOwner),
        "Residents"   => allUsers.Where(u => u.UserType == UserType.Resident),
        _             => allUsers
    };

    private IEnumerable<UserRow> FilteredUsers() =>
        TabUsers().Skip((_usersPage - 1) * UsersPageSize).Take(UsersPageSize);

    private int TabUsersTotal => TabUsers().Count();
    private int UsersTotalPages => (int)Math.Ceiling(TabUsersTotal / (double)UsersPageSize);

    private int CountForTab(string tab) => tab switch
    {
        "Staff"       => allUsers.Count(u => u.UserType == UserType.Staff),
        "Home Owners" => allUsers.Count(u => u.UserType == UserType.HomeOwner),
        "Residents"   => allUsers.Count(u => u.UserType == UserType.Resident),
        _             => allUsers.Count
    };

    private void ShowAddStaff()  { showStaffForm = true; formErrors.Clear(); formSuccess = null; }
    private void HideStaffForm() { showStaffForm = false; staffInput = new StaffInput(); }
    private void OpenEditRoles(UserRow row) { editTarget = row; editMessage = null; }
    private void CloseEditRoles() { editTarget = null; }

    private static string AvatarClass(UserType t) => t switch
    {
        UserType.Staff     => "bg-primary text-white",
        UserType.HomeOwner => "bg-success text-white",
        UserType.Resident  => "bg-info text-white",
        _                  => "bg-secondary text-white"
    };

    private static string UserTypeBadge(UserType t) => t switch
    {
        UserType.Staff     => "<span class=\"badge bg-primary\">Staff</span>",
        UserType.HomeOwner => "<span class=\"badge bg-success\">Home Owner</span>",
        UserType.Resident  => "<span class=\"badge bg-info text-dark\">Resident</span>",
        _                  => "<span class=\"badge bg-secondary\">Unknown</span>"
    };

    private static string RoleDescription(string role) => role switch
    {
        Program.RoleAdmin        => "Full access to all settings and users",
        Program.RoleManager      => "Operations, reports, visitor management",
        Program.RoleReceptionist => "Front desk check-in and pre-registration",
        Program.RoleSecurity     => "Check-in/out visitors at entrance",
        _                        => string.Empty
    };

    private sealed class UserRow
    {
        public string Id       { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Email    { get; set; } = string.Empty;
        public UserType UserType { get; set; }
        public List<string> Roles { get; set; } = [];
        public DateTime CreatedAt { get; set; }
    }

    private sealed class StaffInput
    {
        [Required(ErrorMessage = "Full name is required.")]
        public string FullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email.")]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Role { get; set; } = Program.RoleReceptionist;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm the password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
