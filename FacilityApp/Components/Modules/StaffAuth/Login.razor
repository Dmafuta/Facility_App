@page "/{TenantSlug}/login"
@page "/login"
@layout AuthLayout
@rendermode InteractiveServer
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ITenantService TenantService
@inject TenantContext TenantCtx
@inject NavigationManager Nav

<PageTitle>Staff Sign In — FacilityApp</PageTitle>

<div class="auth-split">

    <!-- Left branding panel -->
    <div class="auth-brand d-none d-lg-flex">
        <div class="deco-circle"></div>
        <div class="brand-inner">
            <div class="brand-logo mb-4">
                <i class="bi bi-buildings"></i>
            </div>
            <h1 class="brand-title">FacilityApp</h1>
            <p class="brand-subtitle">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "Staff Portal")</p>

            <hr class="brand-divider my-4" />

            <ul class="brand-features list-unstyled">
                <li>
                    <div class="feat-icon"><i class="bi bi-person-badge-fill"></i></div>
                    <span>Visitor check-in &amp; pre-registration</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-house-check-fill"></i></div>
                    <span>Unit &amp; occupant management</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-bar-chart-fill"></i></div>
                    <span>Real-time dashboards &amp; reports</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-shield-lock-fill"></i></div>
                    <span>Role-based access control</span>
                </li>
            </ul>

            <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year FacilityApp. All rights reserved.</p>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-wrap">

            <!-- Mobile logo -->
            <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                <div class="mobile-logo"><i class="bi bi-buildings"></i></div>
                <div>
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">FacilityApp</div>
                    <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;">
                        @(TenantCtx.IsResolved ? TenantCtx.TenantName : "Staff Portal")
                    </div>
                </div>
            </div>

            <!-- Form card -->
            <div class="login-card">
                <h2 class="form-heading">Welcome back</h2>
                <p class="form-subheading">Sign in with your staff credentials to continue.</p>

                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger alert-signin d-flex align-items-center gap-2" role="alert">
                        <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                        <span>@errorMessage</span>
                    </div>
                }

                <EditForm Model="Input" OnValidSubmit="HandleLoginAsync" FormName="login" method="post">
                    <DataAnnotationsValidator />
                    <AntiForgeryToken />

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="field-label" for="emailInput">Email address</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-envelope field-icon"></i>
                            <InputText id="emailInput"
                                       @bind-Value="Input.Email"
                                       class="form-control"
                                       style="padding-left:2.4rem;"
                                       placeholder="staff@denvic.co.ke"
                                       autocomplete="email" />
                        </div>
                        <ValidationMessage For="() => Input.Email" class="text-danger small mt-1" />
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="field-label mb-0" for="passwordInput">Password</label>
                            <a href="@(TenantCtx.RouteBase)/forgot-password" class="link-em" style="font-size:0.8rem;">
                                Forgot password?
                            </a>
                        </div>
                        <div class="input-icon-wrap">
                            <i class="bi bi-lock field-icon"></i>
                            <InputText id="passwordInput"
                                       type="@(_showPassword ? "text" : "password")"
                                       @bind-Value="Input.Password"
                                       class="form-control"
                                       style="padding-left:2.4rem;padding-right:2.75rem;"
                                       placeholder="••••••••"
                                       autocomplete="current-password" />
                            <button type="button" class="btn-pw-toggle"
                                    @onclick="() => _showPassword = !_showPassword"
                                    tabindex="-1"
                                    title="@(_showPassword ? "Hide password" : "Show password")">
                                <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        <ValidationMessage For="() => Input.Password" class="text-danger small mt-1" />
                    </div>

                    <!-- Remember me -->
                    <div class="mb-4">
                        <div class="form-check">
                            <InputCheckbox @bind-Value="Input.RememberMe" class="form-check-input" id="rememberMe" />
                            <label class="form-check-label text-muted" for="rememberMe">
                                Keep me signed in for 14 days
                            </label>
                        </div>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn-signin" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Signing in…</span>
                        }
                        else
                        {
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            <span>Sign In</span>
                        }
                    </button>
                </EditForm>
            </div>

            <!-- Staff notice -->
            <div class="staff-notice">
                <i class="bi bi-info-circle me-1"></i>
                This portal is for <strong>authorised staff only</strong>.
                Contact your administrator if you need access.
                Residents should use the <a href="@(TenantCtx.RouteBase)/resident/login" class="link-em">resident portal</a>.
            </div>

        </div>
    </div>

</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = string.Empty;

    [SupplyParameterFromForm]
    private LoginInput Input { get; set; } = new();

    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private string? errorMessage;
    private bool isSubmitting;
    private bool _showPassword;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantService.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
    }

    private async Task HandleLoginAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        if (!TenantCtx.IsResolved)
        {
            errorMessage = "Facility not found. Check the URL and try again.";
            isSubmitting = false;
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(
            Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);

        if (result.Succeeded)
        {
            // Enforce staff-only access
            var user = await UserManager.FindByEmailAsync(Input.Email);
            if (user is null || user.UserType != UserType.Staff)
            {
                await SignInManager.SignOutAsync();
                errorMessage = "Access restricted to authorised staff. Contact your administrator.";
                isSubmitting = false;
                return;
            }

            // SuperAdmin on a system tenant → platform control panel
            var tenant = await TenantService.ResolveBySlugAsync(TenantCtx.TenantSlug);
            if (tenant?.IsSystem == true && await UserManager.IsInRoleAsync(user, "SuperAdmin"))
            {
                Nav.NavigateTo("/superadmin/dashboard", forceLoad: true);
                return;
            }

            var redirect = !string.IsNullOrEmpty(ReturnUrl) && ReturnUrl.StartsWith('/')
                ? ReturnUrl
                : $"{TenantCtx.RouteBase}/dashboard";
            Nav.NavigateTo(redirect, forceLoad: true);
        }
        else if (result.IsLockedOut)
        {
            errorMessage = "Account locked after too many failed attempts. Please try again later.";
        }
        else
        {
            errorMessage = "Invalid email or password.";
        }

        isSubmitting = false;
    }

    private sealed class LoginInput
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}
