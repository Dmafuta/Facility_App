@page "/superadmin/tenants"
@rendermode InteractiveServer
@layout SuperAdminLayout
@attribute [Authorize(Roles = "SuperAdmin")]
@inject AppDbContext Db
@inject NavigationManager Nav

<PageTitle>Tenants — Super Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-grid me-2 text-primary"></i>All Tenants</h4>
        <small class="text-muted">Manage all facilities in this installation</small>
    </div>
    <a href="/superadmin/tenants/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Tenant
    </a>
</div>

@if (_tenants is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_tenants.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-buildings fs-1 d-block mb-2 opacity-25"></i>
        No tenants yet. <a href="/superadmin/tenants/create">Create the first one</a>.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>Slug</th>
                        <th class="text-center">Status</th>
                        <th>Created</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _tenants)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@t.Name</td>
                            <td><code class="small">@t.Slug</code></td>
                            <td class="text-center">
                                @if (t.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-muted small">@t.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                            <td class="text-end pe-3">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/@t.Slug/dashboard" target="_blank"
                                       class="btn btn-sm btn-outline-primary" title="Open tenant portal">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                    <button class="btn btn-sm @(t.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            @onclick="() => ToggleAsync(t)"
                                            title="@(t.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi bi-@(t.IsActive ? "pause" : "play")"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 text-muted small">@_tenants.Count tenant(s) total</div>
}

@code {
    private List<Data.Models.Tenant>? _tenants;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _tenants = await Db.Tenants
            .IgnoreQueryFilters()
            .OrderBy(t => t.Name)
            .ToListAsync();
    }

    private async Task ToggleAsync(Data.Models.Tenant t)
    {
        t.IsActive = !t.IsActive;
        await Db.SaveChangesAsync();
    }
}
