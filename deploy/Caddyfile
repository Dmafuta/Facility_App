# ── FacilityApp Caddyfile ──────────────────────────────────────────────────
#
# Caddy automatically provisions and renews Let's Encrypt SSL certificates
# for every domain listed here. No manual cert management needed.
#
# Usage:
#   1. Point your domain(s) DNS A record → your server IP
#   2. Update the domain names below
#   3. Run: docker compose up -d
#
# ──────────────────────────────────────────────────────────────────────────

# Add one block per domain this server should serve.
# Caddy automatically provisions Let's Encrypt SSL for each.
# Replace / add domains below as needed.

greatwallgardens.estate {
    reverse_proxy app:8080 {
        # Preserve the original public hostname so ASP.NET Core sees
        # Host: greatwallgardens.estate — required for SignalR WebSocket
        # origin validation (Origin header must match Host header or the
        # /_blazor circuit is rejected with 403 and all buttons go dead).
        header_up Host {host}

        # Pass real client IP and protocol for rate limiting / HTTPS awareness
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    encode gzip
    header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}

