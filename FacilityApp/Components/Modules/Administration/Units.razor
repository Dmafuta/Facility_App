@page "/{TenantSlug}/admin/units"
@page "/admin/units"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanManageUnits")]

@inject IUnitService UnitSvc
@inject TenantContext TenantCtx
@inject ITenantService TenantSvc
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Unit Management</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Unit Management</h4>
        <small class="text-muted">Manage house units and assign owners / occupants</small>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddUnit">
        <i class="bi bi-plus-lg me-1"></i> Add Unit
    </button>
</div>

@if (_units is null)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2"></div> Loading units…
    </div>
}
else if (_units.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-house-door fs-1 d-block mb-2 opacity-25"></i>
        No units yet. Click <strong>Add Unit</strong> to get started.
    </div>
}
else
{
    <!-- Summary bar -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-primary">@_units.Count</div>
                <div class="text-muted small">Total Units</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-success">@_units.Count(u => u.Unit.IsOccupied)</div>
                <div class="text-muted small">Occupied</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary">@_units.Count(u => !u.Unit.IsOccupied)</div>
                <div class="text-muted small">Vacant</div>
            </div>
        </div>
    </div>

    <!-- Search -->
    <div class="mb-3">
        <input class="form-control" placeholder="Search by unit number, block or floor…"
               @bind="_search" @bind:event="oninput" />
    </div>

    <!-- Units table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Unit</th>
                        <th>Block / Floor</th>
                        <th>Owner (HomeOwner)</th>
                        <th>Occupant</th>
                        <th class="text-center">Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Filtered)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold">#@d.Unit.UnitNumber</span>
                                @if (!string.IsNullOrEmpty(d.Unit.Description))
                                {
                                    <div class="text-muted small">@d.Unit.Description</div>
                                }
                            </td>
                            <td class="text-muted small">
                                @if (!string.IsNullOrEmpty(d.Unit.Block)) { <span>Block @d.Unit.Block</span> }
                                @if (!string.IsNullOrEmpty(d.Unit.Block) && !string.IsNullOrEmpty(d.Unit.Floor)) { <span> · </span> }
                                @if (!string.IsNullOrEmpty(d.Unit.Floor)) { <span>Floor @d.Unit.Floor</span> }
                                @if (string.IsNullOrEmpty(d.Unit.Block) && string.IsNullOrEmpty(d.Unit.Floor)) { <span>—</span> }
                            </td>
                            <td>
                                @if (d.Owner is not null)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="unit-avatar owner-avatar">@d.Owner.FullName.FirstOrDefault()</div>
                                        <div>
                                            <div class="small fw-medium">@d.Owner.FullName</div>
                                            <div class="text-muted" style="font-size:0.72rem;">@d.Owner.Email</div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenAssign(d, AssignMode.Owner)">
                                        <i class="bi bi-person-plus me-1"></i> Assign
                                    </button>
                                }
                            </td>
                            <td>
                                @if (d.Occupant is not null)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="unit-avatar occupant-avatar">@d.Occupant.FullName.FirstOrDefault()</div>
                                        <div>
                                            <div class="small fw-medium">@d.Occupant.FullName</div>
                                            <div class="text-muted" style="font-size:0.72rem;">@d.Occupant.UserType</div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenAssign(d, AssignMode.Occupant)">
                                        <i class="bi bi-person-plus me-1"></i> Assign
                                    </button>
                                }
                            </td>
                            <td class="text-center">
                                @if (d.Unit.IsOccupied)
                                {
                                    <span class="badge bg-success-subtle text-success">Occupied</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">Vacant</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-ghost" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <button class="dropdown-item" @onclick="() => OpenEditUnit(d)">
                                                <i class="bi bi-pencil me-2"></i> Edit Unit
                                            </button>
                                        </li>
                                        @if (d.Owner is not null)
                                        {
                                            <li>
                                                <button class="dropdown-item" @onclick="() => OpenAssign(d, AssignMode.Owner)">
                                                    <i class="bi bi-arrow-repeat me-2"></i> Change Owner
                                                </button>
                                            </li>
                                            <li>
                                                <button class="dropdown-item text-danger" @onclick="() => RemoveOwnerAsync(d)">
                                                    <i class="bi bi-person-dash me-2"></i> Remove Owner
                                                </button>
                                            </li>
                                        }
                                        @if (d.Occupant is not null)
                                        {
                                            <li>
                                                <button class="dropdown-item" @onclick="() => OpenAssign(d, AssignMode.Occupant)">
                                                    <i class="bi bi-arrow-repeat me-2"></i> Change Occupant
                                                </button>
                                            </li>
                                            <li>
                                                <button class="dropdown-item text-danger" @onclick="() => RemoveOccupantAsync(d)">
                                                    <i class="bi bi-person-dash me-2"></i> Remove Occupant
                                                </button>
                                            </li>
                                        }
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <button class="dropdown-item text-danger" @onclick="() => OpenDeleteUnit(d)">
                                                <i class="bi bi-trash me-2"></i> Delete Unit
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ===================== ADD / EDIT UNIT MODAL ===================== -->
@if (_showUnitModal)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-panel card shadow-lg">
        <div class="card-header border-0 pb-0 pt-4 px-4">
            <h5 class="fw-bold mb-0">@(_editingUnit is null ? "Add Unit" : "Edit Unit")</h5>
        </div>
        <div class="card-body px-4">
            <EditForm Model="_unitForm" OnValidSubmit="SaveUnitAsync">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label fw-medium">Unit Number <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="_unitForm.UnitNumber" placeholder="e.g. 101, A-01" />
                    <ValidationMessage For="() => _unitForm.UnitNumber" class="text-danger small" />
                </div>

                <div class="row g-2 mb-3">
                    <div class="col">
                        <label class="form-label fw-medium">Block</label>
                        <InputText class="form-control" @bind-Value="_unitForm.Block" placeholder="e.g. A, B, North" />
                    </div>
                    <div class="col">
                        <label class="form-label fw-medium">Floor</label>
                        <InputText class="form-control" @bind-Value="_unitForm.Floor" placeholder="e.g. 1, Ground" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium">Description</label>
                    <InputTextArea class="form-control" @bind-Value="_unitForm.Description" rows="2"
                                   placeholder="Optional notes about this unit" />
                </div>

                @if (!string.IsNullOrEmpty(_unitError))
                {
                    <div class="alert alert-danger py-2 small">@_unitError</div>
                }

                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editingUnit is null ? "Add Unit" : "Save Changes")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- ===================== ASSIGN USER MODAL ===================== -->
@if (_showAssignModal)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-panel card shadow-lg">
        <div class="card-header border-0 pb-0 pt-4 px-4">
            <h5 class="fw-bold mb-0">
                @(_assignMode == AssignMode.Owner ? "Assign Owner" : "Assign Occupant")
                — Unit #@_assignTarget?.Unit.UnitNumber
            </h5>
            <p class="text-muted small mb-0 mt-1">
                @(_assignMode == AssignMode.Owner
                    ? "Select a HomeOwner or create a new one for this unit."
                    : "Select a Resident or HomeOwner who will occupy this unit.")
            </p>
        </div>
        <div class="card-body px-4">

            @* Tab toggle (Owner mode only — residents can self-register in future) *@
            @if (_assignMode == AssignMode.Owner)
            {
                <div class="assign-tabs mb-3">
                    <button class="assign-tab @(_createOwnerMode ? "" : "active")"
                            @onclick="() => { _createOwnerMode = false; _assignError = null; }">
                        <i class="bi bi-person-lines-fill me-1"></i> Select Existing
                    </button>
                    <button class="assign-tab @(_createOwnerMode ? "active" : "")"
                            @onclick="() => { _createOwnerMode = true; _assignError = null; }">
                        <i class="bi bi-person-plus me-1"></i> Add New Owner
                    </button>
                </div>
            }

            @if (_createOwnerMode && _assignMode == AssignMode.Owner)
            {
                @* ── Create new HomeOwner form ── *@
                <EditForm Model="_newOwnerForm" OnValidSubmit="CreateOwnerAndAssignAsync">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fw-medium small">Full Name <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="_newOwnerForm.FullName" placeholder="Jane Doe" />
                        <ValidationMessage For="() => _newOwnerForm.FullName" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium small">Email Address <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="_newOwnerForm.Email" placeholder="jane@example.com" autocomplete="off" />
                        <ValidationMessage For="() => _newOwnerForm.Email" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium small">Password <span class="text-danger">*</span></label>
                        <InputText type="password" class="form-control" @bind-Value="_newOwnerForm.Password"
                                   placeholder="Min. 8 characters, 1 digit" autocomplete="new-password" />
                        <ValidationMessage For="() => _newOwnerForm.Password" class="text-danger small" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium small">Confirm Password <span class="text-danger">*</span></label>
                        <InputText type="password" class="form-control" @bind-Value="_newOwnerForm.ConfirmPassword"
                                   placeholder="Repeat password" autocomplete="new-password" />
                        <ValidationMessage For="() => _newOwnerForm.ConfirmPassword" class="text-danger small" />
                    </div>

                    @if (!string.IsNullOrEmpty(_assignError))
                    {
                        <div class="alert alert-danger py-2 small">@_assignError</div>
                    }

                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseModals">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Create &amp; Assign
                        </button>
                    </div>
                </EditForm>
            }
            else
            {
                @* ── Select existing user ── *@
                @if (_assignableUsers is null)
                {
                    <div class="text-center py-3 text-muted">
                        <div class="spinner-border spinner-border-sm me-2"></div> Loading…
                    </div>
                }
                else if (_assignableUsers.Count == 0)
                {
                    <div class="alert alert-info small">
                        No eligible users found.
                        @if (_assignMode == AssignMode.Owner)
                        {
                            <span> Switch to the <strong>Add New Owner</strong> tab to create one.</span>
                        }
                        else
                        {
                            <span> Add Resident or HomeOwner accounts first.</span>
                        }
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <input class="form-control form-control-sm" placeholder="Search…"
                               @bind="_assignSearch" @bind:event="oninput" />
                    </div>
                    <div class="assign-list">
                        @foreach (var u in FilteredAssignable)
                        {
                            var isSelected = _selectedUserId == u.Id;
                            <div class="assign-row @(isSelected ? "assign-row-selected" : "")"
                                 @onclick="() => _selectedUserId = u.Id">
                                <div class="unit-avatar @(u.UserType == UserType.HomeOwner ? "owner-avatar" : "occupant-avatar") me-2">
                                    @u.FullName.FirstOrDefault()
                                </div>
                                <div class="flex-grow-1">
                                    <div class="small fw-medium">@u.FullName</div>
                                    <div class="text-muted" style="font-size:0.72rem;">@u.Email · @u.UserType</div>
                                </div>
                                @if (isSelected)
                                {
                                    <i class="bi bi-check-circle-fill text-primary ms-2"></i>
                                }
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(_assignError))
                {
                    <div class="alert alert-danger py-2 small mt-3">@_assignError</div>
                }

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-primary" disabled="@(string.IsNullOrEmpty(_selectedUserId) || _saving)"
                            @onclick="ConfirmAssignAsync">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Assign
                    </button>
                </div>
            }

        </div>
    </div>
}

<!-- ===================== DELETE UNIT MODAL ===================== -->
@if (_deleteUnitTarget is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-panel card shadow-lg" style="max-width: 420px;">
        <div class="card-body px-4 py-4">
            <h5 class="fw-bold mb-2"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Unit?</h5>
            <p class="text-muted mb-4">
                Are you sure you want to delete unit <strong>#@_deleteUnitTarget.Unit.UnitNumber</strong>?
                This cannot be undone. Units with an active occupant cannot be deleted.
            </p>
            @if (!string.IsNullOrEmpty(_unitError))
            {
                <div class="alert alert-danger py-2 small mb-3">@_unitError</div>
            }
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-outline-secondary" @onclick="CloseModals">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmDeleteUnitAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    // ── State ─────────────────────────────────────────────────────────────
    private List<UnitDetails>? _units;
    private string _search = "";

    private bool _showUnitModal;
    private bool _showAssignModal;
    private bool _saving;
    private string? _unitError;
    private string? _assignError;
    private UnitDetails? _deleteUnitTarget;

    private Unit? _editingUnit;
    private UnitForm _unitForm = new();

    private enum AssignMode { Owner, Occupant }
    private AssignMode _assignMode;
    private UnitDetails? _assignTarget;
    private List<ApplicationUser>? _assignableUsers;
    private string? _selectedUserId;
    private string _assignSearch = "";
    private bool _createOwnerMode;
    private NewOwnerForm _newOwnerForm = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        await LoadUnitsAsync();
    }

    private async Task LoadUnitsAsync()
    {
        _units = await UnitSvc.GetAllAsync();
    }

    // ── Filtering ─────────────────────────────────────────────────────────
    private IEnumerable<UnitDetails> Filtered =>
        _units?.Where(d =>
            string.IsNullOrWhiteSpace(_search) ||
            d.Unit.UnitNumber.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (d.Unit.Block?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (d.Unit.Floor?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (d.Owner?.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (d.Occupant?.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
        ) ?? Enumerable.Empty<UnitDetails>();

    private IEnumerable<ApplicationUser> FilteredAssignable =>
        _assignableUsers?.Where(u =>
            string.IsNullOrWhiteSpace(_assignSearch) ||
            u.FullName.Contains(_assignSearch, StringComparison.OrdinalIgnoreCase) ||
            (u.Email?.Contains(_assignSearch, StringComparison.OrdinalIgnoreCase) ?? false)
        ) ?? Enumerable.Empty<ApplicationUser>();

    // ── Add / Edit Unit ───────────────────────────────────────────────────
    private void OpenAddUnit()
    {
        _editingUnit = null;
        _unitForm = new();
        _unitError = null;
        _showUnitModal = true;
    }

    private void OpenEditUnit(UnitDetails d)
    {
        _editingUnit = d.Unit;
        _unitForm = new UnitForm
        {
            UnitNumber  = d.Unit.UnitNumber,
            Block       = d.Unit.Block,
            Floor       = d.Unit.Floor,
            Description = d.Unit.Description
        };
        _unitError = null;
        _showUnitModal = true;
    }

    private async Task SaveUnitAsync()
    {
        _saving = true;
        _unitError = null;
        try
        {
            if (_editingUnit is null)
                await UnitSvc.CreateAsync(_unitForm.UnitNumber, _unitForm.Block, _unitForm.Floor, _unitForm.Description);
            else
                await UnitSvc.UpdateAsync(_editingUnit.Id, _unitForm.UnitNumber, _unitForm.Block, _unitForm.Floor, _unitForm.Description);

            CloseModals();
            await LoadUnitsAsync();
        }
        catch (Exception ex)
        {
            _unitError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Assign ────────────────────────────────────────────────────────────
    private async Task OpenAssign(UnitDetails d, AssignMode mode)
    {
        _assignTarget     = d;
        _assignMode       = mode;
        _selectedUserId   = null;
        _assignSearch     = "";
        _assignError      = null;
        _assignableUsers  = null;
        _createOwnerMode  = false;
        _newOwnerForm     = new();
        _showAssignModal  = true;

        var linkType = mode == AssignMode.Owner ? UnitLinkType.Owner : UnitLinkType.Occupant;
        _assignableUsers = await UnitSvc.GetAssignableUsersAsync(linkType);
    }

    private async Task CreateOwnerAndAssignAsync()
    {
        if (_assignTarget is null) return;
        _saving = true;
        _assignError = null;
        try
        {
            var user = new ApplicationUser
            {
                UserName = _newOwnerForm.Email,
                Email    = _newOwnerForm.Email,
                FullName = _newOwnerForm.FullName,
                TenantId = TenantCtx.TenantId,
                UserType = UserType.HomeOwner
            };

            var result = await UserManager.CreateAsync(user, _newOwnerForm.Password);
            if (!result.Succeeded)
            {
                _assignError = string.Join(" ", result.Errors.Select(e => e.Description));
                return;
            }

            await UnitSvc.AssignOwnerAsync(_assignTarget.Unit.Id, user.Id);
            CloseModals();
            await LoadUnitsAsync();
        }
        catch (Exception ex)
        {
            _assignError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmAssignAsync()
    {
        if (_assignTarget is null || string.IsNullOrEmpty(_selectedUserId)) return;
        _saving = true;
        _assignError = null;
        try
        {
            if (_assignMode == AssignMode.Owner)
                await UnitSvc.AssignOwnerAsync(_assignTarget.Unit.Id, _selectedUserId);
            else
                await UnitSvc.AssignOccupantAsync(_assignTarget.Unit.Id, _selectedUserId);

            CloseModals();
            await LoadUnitsAsync();
        }
        catch (Exception ex)
        {
            _assignError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Delete Unit ───────────────────────────────────────────────────────
    private void OpenDeleteUnit(UnitDetails d) { _deleteUnitTarget = d; _unitError = null; }

    private async Task ConfirmDeleteUnitAsync()
    {
        if (_deleteUnitTarget is null) return;
        _saving = true;
        _unitError = null;
        try
        {
            await UnitSvc.DeleteAsync(_deleteUnitTarget.Unit.Id);
            CloseModals();
            await LoadUnitsAsync();
        }
        catch (Exception ex) { _unitError = ex.Message; }
        finally { _saving = false; }
    }

    // ── Remove ────────────────────────────────────────────────────────────
    private async Task RemoveOwnerAsync(UnitDetails d)
    {
        await UnitSvc.RemoveOwnerAsync(d.Unit.Id);
        await LoadUnitsAsync();
    }

    private async Task RemoveOccupantAsync(UnitDetails d)
    {
        await UnitSvc.RemoveOccupantAsync(d.Unit.Id);
        await LoadUnitsAsync();
    }

    // ── Helpers ───────────────────────────────────────────────────────────
    private void CloseModals()
    {
        _showUnitModal    = false;
        _showAssignModal  = false;
        _deleteUnitTarget = null;
    }

    // ── Form models ───────────────────────────────────────────────────────
    private class NewOwnerForm
    {
        [Required(ErrorMessage = "Full name is required.")]
        [MaxLength(100)]
        public string FullName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm the password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }

    private class UnitForm
    {
        [Required(ErrorMessage = "Unit number is required.")]
        [StringLength(20)]
        public string UnitNumber { get; set; } = "";

        [StringLength(50)]
        public string? Block { get; set; }

        [StringLength(20)]
        public string? Floor { get; set; }

        [StringLength(200)]
        public string? Description { get; set; }
    }
}
