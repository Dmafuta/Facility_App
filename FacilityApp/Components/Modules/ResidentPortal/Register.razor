@page "/{TenantSlug}/resident/register"
@page "/resident/register"
@layout AuthLayout
@inject UserManager<ApplicationUser> UserManager
@inject ITenantService TenantService
@inject TenantContext TenantCtx
@inject NavigationManager Nav

<PageTitle>Resident Registration — @(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</PageTitle>

<div class="auth-split">

    <!-- Left branding panel -->
    <div class="auth-brand d-none d-lg-flex">
        <div class="deco-circle"></div>
        <div class="brand-inner">
            <div class="brand-logo mb-4">
                <i class="bi bi-house-door-fill"></i>
            </div>
            <h1 class="brand-title">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</h1>
            <p class="brand-subtitle">Resident Portal</p>

            <hr class="brand-divider my-4" />

            <ul class="brand-features list-unstyled">
                <li>
                    <div class="feat-icon"><i class="bi bi-person-plus-fill"></i></div>
                    <span>Pre-register visitors before they arrive</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-qr-code"></i></div>
                    <span>Share QR codes for seamless gate entry</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-clock-history"></i></div>
                    <span>View and manage your full visit history</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-house-check-fill"></i></div>
                    <span>Manage your unit's access easily</span>
                </li>
            </ul>

            <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year @(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp"). All rights reserved.</p>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-wrap">

            <!-- Mobile logo -->
            <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                <div class="mobile-logo"><i class="bi bi-house-door-fill"></i></div>
                <div>
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</div>
                    <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;">Resident Portal</div>
                </div>
            </div>

            <!-- Form card -->
            <div class="login-card">
                <h2 class="form-heading">Create account</h2>
                <p class="form-subheading">Register as a resident to manage your visitor access.</p>

                @if (_error is not null)
                {
                    <div class="alert alert-danger alert-signin d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                        <span>@_error</span>
                    </div>
                }

                @if (_success)
                {
                    <div class="alert alert-success" style="border-radius:10px;font-size:0.88rem;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-check-circle-fill fs-5"></i>
                            <strong>Account created successfully!</strong>
                        </div>
                        <p class="mb-2 small">An administrator will assign you to your unit shortly.</p>
                        <a href="@(TenantCtx.RouteBase)/resident/login" class="btn btn-success btn-sm">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Sign in now
                        </a>
                    </div>
                }
                else
                {
                    <EditForm Model="_form" OnValidSubmit="HandleRegisterAsync" FormName="residentRegister" method="post">
                        <DataAnnotationsValidator />
                        <AntiForgeryToken />

                        <!-- Full Name -->
                        <div class="mb-3">
                            <label class="field-label">Full Name</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-person field-icon"></i>
                                <InputText @bind-Value="_form.FullName"
                                           class="form-control"
                                           style="padding-left:2.4rem;"
                                           placeholder="Jane Doe"
                                           autocomplete="name" />
                            </div>
                            <ValidationMessage For="() => _form.FullName" class="text-danger small mt-1" />
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label class="field-label">Email Address</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-envelope field-icon"></i>
                                <InputText @bind-Value="_form.Email"
                                           class="form-control"
                                           style="padding-left:2.4rem;"
                                           placeholder="jane@example.com"
                                           autocomplete="email" />
                            </div>
                            <ValidationMessage For="() => _form.Email" class="text-danger small mt-1" />
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label class="field-label">Password</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-lock field-icon"></i>
                                <InputText type="@(_showPassword ? "text" : "password")"
                                           @bind-Value="_form.Password"
                                           class="form-control"
                                           style="padding-left:2.4rem;padding-right:2.75rem;"
                                           placeholder="Min. 8 characters, 1 digit"
                                           autocomplete="new-password" />
                                <button type="button" class="btn-pw-toggle"
                                        @onclick="() => _showPassword = !_showPassword"
                                        tabindex="-1"
                                        title="@(_showPassword ? "Hide password" : "Show password")">
                                    <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="() => _form.Password" class="text-danger small mt-1" />
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-4">
                            <label class="field-label">Confirm Password</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-lock-fill field-icon"></i>
                                <InputText type="@(_showConfirm ? "text" : "password")"
                                           @bind-Value="_form.ConfirmPassword"
                                           class="form-control"
                                           style="padding-left:2.4rem;padding-right:2.75rem;"
                                           placeholder="Repeat password"
                                           autocomplete="new-password" />
                                <button type="button" class="btn-pw-toggle"
                                        @onclick="() => _showConfirm = !_showConfirm"
                                        tabindex="-1"
                                        title="@(_showConfirm ? "Hide password" : "Show password")">
                                    <i class="bi @(_showConfirm ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="() => _form.ConfirmPassword" class="text-danger small mt-1" />
                        </div>

                        <!-- Submit -->
                        <button type="submit" class="btn-signin" disabled="@_submitting">
                            @if (_submitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Creating account…</span>
                            }
                            else
                            {
                                <i class="bi bi-person-plus me-2"></i>
                                <span>Create Account</span>
                            }
                        </button>
                    </EditForm>

                    <hr class="form-divider" />

                    <p class="text-center small text-muted mb-0">
                        Already have an account?
                        <a href="@(TenantCtx.RouteBase)/resident/login" class="link-em">Sign in here</a>
                    </p>
                }
            </div>

            <!-- Staff notice -->
            <div class="staff-notice">
                <i class="bi bi-info-circle me-1"></i>
                This portal is for <strong>residents &amp; homeowners</strong> only.
                Staff should use the <a href="@(TenantCtx.RouteBase)/login" class="link-em">staff login</a>.
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = string.Empty;

    [SupplyParameterFromForm]
    private RegisterInput _form { get; set; } = new();

    private string? _error;
    private bool _submitting;
    private bool _success;
    private bool _showPassword;
    private bool _showConfirm;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantService.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
    }

    private async Task HandleRegisterAsync()
    {
        _submitting = true;
        _error      = null;

        if (!TenantCtx.IsResolved)
        {
            _error = "Facility not found. Check the URL and try again.";
            _submitting = false;
            return;
        }

        var user = new ApplicationUser
        {
            UserName = _form.Email,
            Email    = _form.Email,
            FullName = _form.FullName,
            TenantId = TenantCtx.TenantId,
            UserType = UserType.Resident
        };

        var result = await UserManager.CreateAsync(user, _form.Password);
        if (!result.Succeeded)
        {
            _error = string.Join(" ", result.Errors.Select(e => e.Description));
            _submitting = false;
            return;
        }

        _success    = true;
        _submitting = false;
    }

    private sealed class RegisterInput
    {
        [Required(ErrorMessage = "Full name is required.")]
        [MaxLength(100)]
        public string FullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
