@page "/{TenantSlug}/admin/unit-requests"
@page "/admin/unit-requests"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanManageUnits")]
@inject IUnitRequestService RequestSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState

<PageTitle>Unit Requests — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-house-check me-2 text-primary"></i>Unit Requests</h4>
        <small class="text-muted">Review and approve resident unit assignment requests</small>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_requests.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
            <h5>No pending requests</h5>
            <p class="mb-0 small">Resident unit assignment requests will appear here for review.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center gap-2">
            <h6 class="mb-0 fw-semibold">Pending Requests</h6>
            <span class="badge bg-warning text-dark">@_requests.Count</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Resident</th>
                            <th>Requested Unit</th>
                            <th>Note</th>
                            <th>Submitted</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in _requests)
                        {
                            var unitLabel = req.Unit.Block is not null
                                ? $"Unit {req.Unit.Block}-{req.Unit.UnitNumber}"
                                : $"Unit {req.Unit.UnitNumber}";

                            <tr>
                                <td class="ps-3">
                                    <div class="fw-medium">@req.Resident.FullName</div>
                                    <small class="text-muted">@req.Resident.Email</small>
                                </td>
                                <td>
                                    <span class="fw-medium">@unitLabel</span>
                                    @if (!string.IsNullOrEmpty(req.Unit.Description))
                                    {
                                        <br /><small class="text-muted">@req.Unit.Description</small>
                                    }
                                    @if (req.Unit.IsOccupied)
                                    {
                                        <br /><span class="badge bg-warning text-dark small">Currently occupied</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(req.Note))
                                    {
                                        <span class="text-muted small fst-italic">@req.Note</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="small text-muted">@req.RequestedAt.ToLocalTime().ToString("MMM d, yyyy")<br />@req.RequestedAt.ToLocalTime().ToString("h:mm tt")</td>
                                <td class="text-end pe-3">
                                    @if (_rejectingId == req.Id)
                                    {
                                        <div class="d-flex align-items-center gap-2 justify-content-end">
                                            <input class="form-control form-control-sm" style="width:200px;"
                                                   placeholder="Rejection reason (optional)"
                                                   @bind="_rejectNote" />
                                            <button class="btn btn-danger btn-sm" @onclick="() => ConfirmRejectAsync(req.Id)"
                                                    disabled="@_busy">
                                                Confirm
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelReject"
                                                    disabled="@_busy">
                                                Cancel
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex gap-2 justify-content-end">
                                            <button class="btn btn-success btn-sm" @onclick="() => ApproveAsync(req.Id)"
                                                    disabled="@_busy">
                                                <i class="bi bi-check-lg me-1"></i>Approve
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => StartReject(req.Id)"
                                                    disabled="@_busy">
                                                <i class="bi bi-x-lg me-1"></i>Reject
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>

                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<UnitRequest> _requests = [];
    private bool _loading = true;
    private bool _busy;
    private Guid? _rejectingId;
    private string _rejectNote = "";
    private string? _toast;
    private string _toastType = "success";
    private string _reviewerId = "";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _reviewerId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _requests = await RequestSvc.GetPendingAsync();
        _loading = false;
    }

    private async Task ApproveAsync(Guid requestId)
    {
        _busy = true;
        try
        {
            await RequestSvc.ApproveAsync(requestId, _reviewerId);
            ShowToast("Request approved — unit assigned successfully.", "success");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowToast(ex.Message, "danger");
        }
        finally { _busy = false; }
    }

    private void StartReject(Guid requestId)
    {
        _rejectingId = requestId;
        _rejectNote = "";
    }

    private void CancelReject() => _rejectingId = null;

    private async Task ConfirmRejectAsync(Guid requestId)
    {
        _busy = true;
        try
        {
            await RequestSvc.RejectAsync(requestId, _reviewerId, _rejectNote);
            _rejectingId = null;
            ShowToast("Request rejected.", "warning");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowToast(ex.Message, "danger");
        }
        finally { _busy = false; }
    }

    private void ShowToast(string message, string type)
    {
        _toast = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            _toast = null;
            InvokeAsync(StateHasChanged);
        });
    }
}
