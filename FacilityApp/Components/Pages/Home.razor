@page "/"
@layout AuthLayout
@inject TenantContext TenantCtx

@if (TenantCtx.IsCustomDomain && TenantCtx.IsResolved)
{
    <PageTitle>@TenantCtx.TenantName</PageTitle>

    <div class="auth-split" style="min-height:100vh;">

        <div class="auth-brand d-none d-lg-flex">
            <div class="brand-inner">
                @if (!string.IsNullOrEmpty(TenantCtx.LogoUrl))
                {
                    <img src="@TenantCtx.LogoUrl" alt="@TenantCtx.TenantName"
                         style="height:56px;width:auto;object-fit:contain;border-radius:8px;margin-bottom:1.5rem;" />
                }
                else
                {
                    <div class="brand-logo mb-4"><i class="bi bi-buildings"></i></div>
                }
                <h1 class="brand-title">@TenantCtx.TenantName</h1>
                <p class="brand-subtitle">Visitor &amp; Resident Management</p>

                <hr class="brand-divider my-4" />

                <ul class="brand-features list-unstyled">
                    <li><i class="bi bi-person-badge-fill"></i><span>Visitor check-in &amp; pre-registration</span></li>
                    <li><i class="bi bi-house-check-fill"></i><span>Unit &amp; occupant management</span></li>
                    <li><i class="bi bi-bar-chart-fill"></i><span>Real-time dashboards &amp; reports</span></li>
                    <li><i class="bi bi-shield-lock-fill"></i><span>Role-based access control</span></li>
                </ul>

                <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year @TenantCtx.TenantName. All rights reserved.</p>
            </div>
        </div>

        <div class="auth-form-panel d-flex align-items-center justify-content-center">
            <div class="auth-form-wrap">

                <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                    @if (!string.IsNullOrEmpty(TenantCtx.LogoUrl))
                    {
                        <img src="@TenantCtx.LogoUrl" alt="@TenantCtx.TenantName"
                             style="height:32px;width:auto;object-fit:contain;border-radius:4px;" />
                    }
                    else
                    {
                        <div class="mobile-logo"><i class="bi bi-buildings"></i></div>
                    }
                    <div>
                        <div class="fw-bold text-dark" style="font-size:1.1rem;">@TenantCtx.TenantName</div>
                        <div class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;">Visitor Management</div>
                    </div>
                </div>

                <h2 class="form-heading">Welcome</h2>
                <p class="form-subheading">Select your portal to continue.</p>

                <div class="d-grid gap-3 mt-4">
                    <a href="@(TenantCtx.RouteBase)/login" class="btn btn-primary btn-lg py-3">
                        <i class="bi bi-person-badge me-2"></i>Staff Login
                        <div class="small fw-normal opacity-75 mt-1">Receptionists, security &amp; management</div>
                    </a>
                    <a href="@(TenantCtx.RouteBase)/resident/login" class="btn btn-outline-primary btn-lg py-3">
                        <i class="bi bi-house-door me-2"></i>Resident Portal
                        <div class="small fw-normal opacity-75 mt-1">Homeowners &amp; residents</div>
                    </a>
                </div>

            </div>
        </div>

    </div>
}
else
{
    <PageTitle>FacilityApp</PageTitle>

    <div class="auth-form-panel d-flex align-items-center justify-content-center" style="min-height:100vh;">
        <div class="auth-form-wrap text-center">
            <div class="brand-logo mb-4 mx-auto" style="width:72px;height:72px;font-size:2rem;">
                <i class="bi bi-buildings"></i>
            </div>
            <h1 class="fw-bold mb-2" style="font-size:2rem;">FacilityApp</h1>
            <p class="text-muted lead mb-4">Visitor &amp; Resident Management Platform</p>
            <p class="text-muted small">
                Please contact your facility manager for your login link,<br />
                or navigate to <code>yourfacility.com/login</code>.
            </p>
        </div>
    </div>
}
