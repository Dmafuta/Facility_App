@page "/{TenantSlug}/visitors/{VisitId:guid}/badge"
@page "/visitors/{VisitId:guid}/badge"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanCheckInVisitors")]
@using QRCoder
@inject IVisitorService VisitorSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject IJSRuntime JS

<PageTitle>Visitor Badge</PageTitle>

@if (_visit is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <!-- Screen controls — hidden on print -->
    <div class="d-print-none mb-3 d-flex gap-2">
        <a href="@(TenantCtx.RouteBase)/visitors" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
        <button class="btn btn-sm btn-primary" @onclick="PrintAsync">
            <i class="bi bi-printer me-1"></i>Print Badge
        </button>
    </div>

    <!-- Badge — centred, print-optimised -->
    <div class="badge-sheet">
        <div class="visitor-badge">

            <!-- Facility header band -->
            <div class="badge-header">
                <span class="badge-facility">@TenantCtx.TenantName</span>
                <span class="badge-type">VISITOR</span>
            </div>

            <!-- Photo -->
            <div class="badge-photo-wrap">
                @if (!string.IsNullOrEmpty(_visit.Visitor.PhotoUrl))
                {
                    <img class="badge-photo" src="@_visit.Visitor.PhotoUrl" alt="Photo" />
                }
                else
                {
                    <div class="badge-photo badge-initials">
                        @(_visit.Visitor.FullName.Length > 0
                            ? _visit.Visitor.FullName[0].ToString().ToUpper()
                            : "?")
                    </div>
                }
            </div>

            <!-- Visitor details -->
            <div class="badge-name">@_visit.Visitor.FullName</div>
            @if (!string.IsNullOrEmpty(_visit.Visitor.Company))
            {
                <div class="badge-company">@_visit.Visitor.Company</div>
            }

            <div class="badge-detail-row">
                <span class="badge-label">Purpose</span>
                <span class="badge-value">@_visit.Purpose</span>
            </div>
            <div class="badge-detail-row">
                <span class="badge-label">Host</span>
                <span class="badge-value">@(_visit.Host?.FullName ?? "—")</span>
            </div>
            <div class="badge-detail-row">
                <span class="badge-label">Date</span>
                <span class="badge-value">@(_visit.CheckedInAt?.ToLocalTime().ToString("MMM d, yyyy h:mm tt") ?? "—")</span>
            </div>
            @if (_visit.EntryEntrance is not null)
            {
                <div class="badge-detail-row">
                    <span class="badge-label">Gate</span>
                    <span class="badge-value"><i class="bi bi-door-open me-1"></i>@_visit.EntryEntrance.Name</span>
                </div>
            }

            <!-- QR code -->
            <div class="badge-qr-wrap">
                <img class="badge-qr" src="data:image/png;base64,@_qrBase64" alt="QR" />
                <div class="badge-qr-label">Scan to verify</div>
            </div>

            <!-- Visit ID footer -->
            <div class="badge-footer">
                ID: @_visit.Id.ToString()[..8].ToUpper()
            </div>

        </div>
    </div>
}

<style>
    .badge-sheet {
        display: flex;
        justify-content: center;
        padding: 2rem;
    }

    .visitor-badge {
        width: 3.5in;
        min-height: 5in;
        border: 2px solid #1b6ec2;
        border-radius: 12px;
        overflow: hidden;
        font-family: Arial, sans-serif;
        background: #fff;
        box-shadow: 0 4px 20px rgba(0,0,0,.15);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-bottom: 12px;
    }

    .badge-header {
        width: 100%;
        background: #1b6ec2;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
    }

    .badge-facility { font-size: 13px; font-weight: 700; }
    .badge-type     { font-size: 11px; letter-spacing: .1em; opacity: .85; }

    .badge-photo-wrap { margin-top: 16px; }

    .badge-photo {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #1b6ec2;
    }

    .badge-initials {
        background: #e3ecf8;
        color: #1b6ec2;
        font-size: 36px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .badge-name    { font-size: 20px; font-weight: 700; margin-top: 10px; text-align: center; padding: 0 12px; }
    .badge-company { font-size: 12px; color: #555; margin-top: 2px; }

    .badge-detail-row {
        display: flex;
        justify-content: space-between;
        width: calc(100% - 28px);
        margin-top: 8px;
        font-size: 12px;
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 4px;
    }

    .badge-label { color: #888; }
    .badge-value { font-weight: 600; text-align: right; max-width: 60%; }

    .badge-qr-wrap {
        margin-top: 14px;
        text-align: center;
    }

    .badge-qr       { width: 80px; height: 80px; }
    .badge-qr-label { font-size: 10px; color: #aaa; margin-top: 2px; }

    .badge-footer {
        font-size: 10px;
        color: #bbb;
        margin-top: auto;
        padding-top: 8px;
        letter-spacing: .08em;
    }

    @@media print {
        .badge-sheet { padding: 0; }
        .visitor-badge { box-shadow: none; border-color: #ccc; }
    }
</style>

@code {
    [Parameter] public string TenantSlug { get; set; } = "";
    [Parameter] public Guid VisitId { get; set; }

    private Visit? _visit;
    private string _qrBase64 = "";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        // Load visit
        var (items, _) = await VisitorSvc.GetVisitsAsync("all", null, 1, int.MaxValue);
        _visit = items.FirstOrDefault(v => v.Id == VisitId);

        if (_visit is not null)
            _qrBase64 = GenerateQr(VisitId.ToString());
    }

    private static string GenerateQr(string text)
    {
        using var qrGenerator = new QRCodeGenerator();
        using var qrData      = qrGenerator.CreateQrCode(text, QRCodeGenerator.ECCLevel.M);
        using var qrCode      = new PngByteQRCode(qrData);
        var bytes = qrCode.GetGraphic(4);
        return Convert.ToBase64String(bytes);
    }

    private async Task PrintAsync() =>
        await JS.InvokeVoidAsync("printBadge");
}
