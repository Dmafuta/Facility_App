@page "/{TenantSlug}/resident/register"
@page "/resident/register"
@layout AuthLayout
@inject UserManager<ApplicationUser> UserManager
@inject ITenantService TenantService
@inject TenantContext TenantCtx
@inject NavigationManager Nav

<PageTitle>Resident Registration — @(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</PageTitle>

<div class="auth-split">

    <div class="auth-brand d-none d-lg-flex">
        <div class="brand-inner">
            <div class="brand-logo mb-4"><i class="bi bi-buildings"></i></div>
            <h1 class="brand-title">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</h1>
            <p class="brand-subtitle">Resident Portal</p>
            <hr class="brand-divider my-4" />
            <ul class="brand-features list-unstyled">
                <li><i class="bi bi-calendar-check-fill"></i><span>Pre-register visitors before they arrive</span></li>
                <li><i class="bi bi-clock-history"></i><span>View your complete visit history</span></li>
                <li><i class="bi bi-house-check-fill"></i><span>Manage your unit's access easily</span></li>
            </ul>
            <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year FacilityApp. All rights reserved.</p>
        </div>
    </div>

    <div class="auth-form-panel d-flex align-items-center justify-content-center">
        <div class="auth-form-wrap">

            <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                <div class="mobile-logo"><i class="bi bi-buildings"></i></div>
                <div>
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</div>
                    <div class="text-muted" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;">Resident Portal</div>
                </div>
            </div>

            <h2 class="form-heading">Create account</h2>
            <p class="form-subheading">Register as a resident to manage visitor access.</p>

            @if (_error is not null)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 small">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                    <span>@_error</span>
                </div>
            }
            @if (_success)
            {
                <div class="alert alert-success py-3 small">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <strong>Account created!</strong> You can now
                    <a href="@(TenantCtx.RouteBase)/resident/login" class="fw-semibold">sign in</a>.
                    An administrator will assign you to your unit to enable pre-registrations.
                </div>
            }
            else
            {
                <EditForm Model="_form" OnValidSubmit="HandleRegisterAsync" FormName="residentRegister" method="post">
                    <DataAnnotationsValidator />
                    <AntiForgeryToken />

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                            <InputText @bind-Value="_form.FullName" class="form-control border-start-0 ps-0"
                                       placeholder="Jane Doe" autocomplete="name" />
                        </div>
                        <ValidationMessage For="() => _form.FullName" class="text-danger small mt-1" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <InputText @bind-Value="_form.Email" class="form-control border-start-0 ps-0"
                                       placeholder="jane@example.com" autocomplete="email" />
                        </div>
                        <ValidationMessage For="() => _form.Email" class="text-danger small mt-1" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                            <InputText type="password" @bind-Value="_form.Password"
                                       class="form-control border-start-0 ps-0"
                                       placeholder="Min. 8 characters, 1 digit" autocomplete="new-password" />
                        </div>
                        <ValidationMessage For="() => _form.Password" class="text-danger small mt-1" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock-fill text-muted"></i></span>
                            <InputText type="password" @bind-Value="_form.ConfirmPassword"
                                       class="form-control border-start-0 ps-0"
                                       placeholder="Repeat password" autocomplete="new-password" />
                        </div>
                        <ValidationMessage For="() => _form.ConfirmPassword" class="text-danger small mt-1" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Creating account…</span>
                        }
                        else
                        {
                            <i class="bi bi-person-plus me-2"></i>
                            <span>Create Account</span>
                        }
                    </button>
                </EditForm>

                <div class="text-center mt-4 small text-muted">
                    Already have an account?
                    <a href="@(TenantCtx.RouteBase)/resident/login" class="fw-semibold">Sign in here</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = string.Empty;

    [SupplyParameterFromForm]
    private RegisterInput _form { get; set; } = new();

    private string? _error;
    private bool _submitting;
    private bool _success;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantService.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
    }

    private async Task HandleRegisterAsync()
    {
        _submitting = true;
        _error      = null;

        if (!TenantCtx.IsResolved)
        {
            _error = "Facility not found. Check the URL and try again.";
            _submitting = false;
            return;
        }

        var user = new ApplicationUser
        {
            UserName = _form.Email,
            Email    = _form.Email,
            FullName = _form.FullName,
            TenantId = TenantCtx.TenantId,
            UserType = UserType.Resident
        };

        var result = await UserManager.CreateAsync(user, _form.Password);
        if (!result.Succeeded)
        {
            _error = string.Join(" ", result.Errors.Select(e => e.Description));
            _submitting = false;
            return;
        }

        _success    = true;
        _submitting = false;
    }

    private sealed class RegisterInput
    {
        [Required(ErrorMessage = "Full name is required.")]
        [MaxLength(100)]
        public string FullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
