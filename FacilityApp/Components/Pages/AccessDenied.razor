@page "/{tenantSlug}/access-denied"
@page "/access-denied"
@inject TenantContext TenantCtx
@inject IJSRuntime JS

<PageTitle>Access Denied — 403</PageTitle>

<div class="ad-root">

    <!-- Animated background shapes -->
    <div class="ad-shape ad-shape-1"></div>
    <div class="ad-shape ad-shape-2"></div>
    <div class="ad-shape ad-shape-3"></div>
    <div class="ad-shape ad-shape-4"></div>

    <!-- Floating particles -->
    <div class="ad-particles">
        @for (int i = 1; i <= 12; i++)
        {
            <div class="ad-particle ad-particle-@i"></div>
        }
    </div>

    <div class="ad-content">

        <!-- Icon cluster -->
        <div class="ad-icon-wrap">
            <div class="ad-icon-ring ad-ring-3"></div>
            <div class="ad-icon-ring ad-ring-2"></div>
            <div class="ad-icon-ring ad-ring-1"></div>
            <div class="ad-icon-core">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
        </div>

        <!-- Error code -->
        <div class="ad-code-wrap">
            <span class="ad-code">4</span>
            <span class="ad-code ad-code-mid">0</span>
            <span class="ad-code">3</span>
        </div>

        <!-- Divider line -->
        <div class="ad-divider">
            <span class="ad-divider-dot"></span>
            <span class="ad-divider-line"></span>
            <span class="ad-divider-dot"></span>
        </div>

        <!-- Title & message -->
        <h1 class="ad-title">Access Denied</h1>
        <p class="ad-message">
            You don't have permission to view this page.<br class="d-none d-md-inline" />
            Please contact your administrator if you believe this is a mistake.
        </p>

        <!-- Info badge -->
        <div class="ad-badge">
            <i class="bi bi-info-circle me-2"></i>
            Your account may not have the required role for this area.
        </div>

        <!-- Actions -->
        <div class="ad-actions">
            <button class="ad-btn-primary" @onclick="GoBack">
                <i class="bi bi-arrow-left me-2"></i>Go Back
            </button>
            <a class="ad-btn-secondary" href="@(TenantCtx.IsResolved ? TenantCtx.RouteBase + "/login" : "/")">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </a>
        </div>

        <!-- Footer -->
        <div class="ad-footer">
            @if (TenantCtx.IsResolved)
            {
                <span>@TenantCtx.TenantName</span>
                <span class="ad-footer-sep">&middot;</span>
            }
            <span>Powered by <strong>FacilityApp</strong></span>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? TenantSlug { get; set; }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");
}

<style>
    /* ── Root ───────────────────────────────────────────────── */
    .ad-root {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #1a1a3e 40%, #0f2744 80%, #0a1628 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        font-family: inherit;
    }

    /* ── Decorative shapes ──────────────────────────────────── */
    .ad-shape {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        animation: adFloat 8s ease-in-out infinite alternate;
    }
    .ad-shape-1 {
        width: 700px; height: 700px;
        background: radial-gradient(circle, rgba(239,68,68,.12), transparent 70%);
        top: -250px; right: -200px;
        animation-duration: 9s;
    }
    .ad-shape-2 {
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(99,102,241,.1), transparent 70%);
        bottom: -150px; left: -150px;
        animation-duration: 11s;
    }
    .ad-shape-3 {
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(248,113,113,.08), transparent 70%);
        top: 40%; left: 25%;
        animation-duration: 13s;
    }
    .ad-shape-4 {
        width: 200px; height: 200px;
        background: radial-gradient(circle, rgba(167,139,250,.08), transparent 70%);
        top: 10%; left: 10%;
        animation-duration: 7s;
    }

    @@keyframes adFloat {
        from { transform: translateY(0) scale(1); }
        to   { transform: translateY(-30px) scale(1.04); }
    }

    /* ── Particles ──────────────────────────────────────────── */
    .ad-particles {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }
    .ad-particle {
        position: absolute;
        width: 3px; height: 3px;
        border-radius: 50%;
        background: rgba(248,113,113,.5);
        animation: adParticleDrift linear infinite;
    }
    /* stagger position + timing per particle */
    .ad-particle-1  { left:  8%; top: 20%; animation-duration: 14s; animation-delay: 0s;    width:2px;height:2px; }
    .ad-particle-2  { left: 18%; top: 70%; animation-duration: 18s; animation-delay: 1s;    background:rgba(167,139,250,.5); }
    .ad-particle-3  { left: 30%; top: 10%; animation-duration: 12s; animation-delay: 2s;    }
    .ad-particle-4  { left: 45%; top: 85%; animation-duration: 16s; animation-delay: .5s;   background:rgba(99,102,241,.5); }
    .ad-particle-5  { left: 60%; top: 25%; animation-duration: 20s; animation-delay: 3s;    width:4px;height:4px; }
    .ad-particle-6  { left: 72%; top: 60%; animation-duration: 11s; animation-delay: 1.5s;  background:rgba(167,139,250,.4); }
    .ad-particle-7  { left: 85%; top: 15%; animation-duration: 17s; animation-delay: .8s;   }
    .ad-particle-8  { left: 92%; top: 75%; animation-duration: 15s; animation-delay: 4s;    background:rgba(99,102,241,.5); width:2px;height:2px; }
    .ad-particle-9  { left: 55%; top: 50%; animation-duration: 22s; animation-delay: 2.5s;  }
    .ad-particle-10 { left: 25%; top: 45%; animation-duration: 13s; animation-delay: 1.2s;  background:rgba(248,113,113,.3); }
    .ad-particle-11 { left: 78%; top: 38%; animation-duration: 19s; animation-delay: 3.5s;  width:2px;height:2px; }
    .ad-particle-12 { left: 40%; top: 92%; animation-duration: 10s; animation-delay: .3s;   background:rgba(167,139,250,.5); }

    @@keyframes adParticleDrift {
        0%   { transform: translateY(0)     opacity(1); opacity: .8; }
        50%  { opacity: .3; }
        100% { transform: translateY(-120px); opacity: 0; }
    }

    /* ── Content card ───────────────────────────────────────── */
    .ad-content {
        position: relative;
        z-index: 10;
        text-align: center;
        padding: 3rem 2rem;
        max-width: 520px;
        width: 100%;
        animation: adFadeUp .6s ease both;
    }

    @@keyframes adFadeUp {
        from { opacity: 0; transform: translateY(28px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Icon cluster ───────────────────────────────────────── */
    .ad-icon-wrap {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 2rem;
    }
    .ad-icon-ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(239,68,68,.2);
        animation: adPulse 3s ease-in-out infinite;
    }
    .ad-ring-1 { width: 80px;  height: 80px;  animation-delay: 0s; }
    .ad-ring-2 { width: 110px; height: 110px; animation-delay: .4s; border-color: rgba(239,68,68,.13); }
    .ad-ring-3 { width: 140px; height: 140px; animation-delay: .8s; border-color: rgba(239,68,68,.07); }

    @@keyframes adPulse {
        0%, 100% { transform: scale(1);    opacity: 1; }
        50%       { transform: scale(1.08); opacity: .5; }
    }

    .ad-icon-core {
        width: 64px; height: 64px;
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(239,68,68,.25), rgba(185,28,28,.35));
        border: 1px solid rgba(239,68,68,.4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: #f87171;
        box-shadow: 0 0 32px rgba(239,68,68,.2), inset 0 1px 0 rgba(255,255,255,.07);
        position: relative;
        z-index: 2;
    }

    /* ── Error code ─────────────────────────────────────────── */
    .ad-code-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .15em;
        line-height: 1;
        margin-bottom: 1rem;
    }
    .ad-code {
        font-size: clamp(4.5rem, 14vw, 7.5rem);
        font-weight: 900;
        letter-spacing: -.04em;
        background: linear-gradient(135deg, #fca5a5 0%, #ef4444 45%, #991b1b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: none;
        display: inline-block;
        animation: adCodeGlow 4s ease-in-out infinite alternate;
    }
    .ad-code-mid {
        background: linear-gradient(135deg, #fff 0%, #fca5a5 60%, #ef4444 100%);
        -webkit-background-clip: text;
        background-clip: text;
    }

    @@keyframes adCodeGlow {
        from { filter: drop-shadow(0 0  6px rgba(239,68,68,.3)); }
        to   { filter: drop-shadow(0 0 18px rgba(239,68,68,.6)); }
    }

    /* ── Divider ────────────────────────────────────────────── */
    .ad-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        margin-bottom: 1.4rem;
    }
    .ad-divider-line {
        width: 60px;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(239,68,68,.5), transparent);
    }
    .ad-divider-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        background: rgba(239,68,68,.6);
    }

    /* ── Title & message ────────────────────────────────────── */
    .ad-title {
        font-size: clamp(1.5rem, 4vw, 2.2rem);
        font-weight: 800;
        letter-spacing: -.02em;
        color: #fff;
        margin-bottom: .75rem;
    }
    .ad-message {
        font-size: .95rem;
        color: rgba(255,255,255,.55);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    /* ── Info badge ─────────────────────────────────────────── */
    .ad-badge {
        display: inline-flex;
        align-items: center;
        font-size: .78rem;
        font-weight: 500;
        color: #fca5a5;
        background: rgba(239,68,68,.1);
        border: 1px solid rgba(239,68,68,.25);
        padding: .45rem 1rem;
        border-radius: 50px;
        margin-bottom: 2rem;
    }

    /* ── Action buttons ─────────────────────────────────────── */
    .ad-actions {
        display: flex;
        gap: .75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 2.5rem;
    }
    .ad-btn-primary, .ad-btn-secondary {
        display: inline-flex;
        align-items: center;
        padding: .65rem 1.4rem;
        border-radius: 10px;
        font-size: .9rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: transform .18s, box-shadow .18s, background .18s;
    }
    .ad-btn-primary {
        background: linear-gradient(135deg, #ef4444, #b91c1c);
        color: #fff;
        box-shadow: 0 4px 16px rgba(239,68,68,.35);
    }
    .ad-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(239,68,68,.5);
        background: linear-gradient(135deg, #f87171, #dc2626);
        color: #fff;
    }
    .ad-btn-secondary {
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.15);
        color: rgba(255,255,255,.8);
    }
    .ad-btn-secondary:hover {
        background: rgba(255,255,255,.13);
        transform: translateY(-2px);
        color: #fff;
        text-decoration: none;
    }

    /* ── Footer ─────────────────────────────────────────────── */
    .ad-footer {
        font-size: .75rem;
        color: rgba(255,255,255,.25);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
    }
    .ad-footer strong { color: rgba(255,255,255,.35); }
    .ad-footer-sep { color: rgba(255,255,255,.2); }

    /* ── Responsive ─────────────────────────────────────────── */
    @@media (max-width: 480px) {
        .ad-content { padding: 2rem 1.25rem; }
        .ad-actions  { flex-direction: column; align-items: stretch; }
        .ad-btn-primary, .ad-btn-secondary { justify-content: center; }
    }
</style>
