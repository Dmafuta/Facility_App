@page "/{TenantSlug}/maintenance"
@page "/maintenance"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Manager,Receptionist,Security")]
@inject IMaintenanceService MaintenanceSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx

@using FacilityApp.Data.Models

<PageTitle>Maintenance — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-tools me-2 text-primary"></i>Maintenance Requests</h4>
        <small class="text-muted">Review and manage resident maintenance requests</small>
    </div>
</div>

<!-- Status filter tabs -->
<ul class="nav nav-tabs mb-3">
    @foreach (var tab in _tabs)
    {
        <li class="nav-item">
            <button class="nav-link @(tab == _activeTab ? "active" : "")"
                    @onclick="() => SetTab(tab)">
                @tab
                @if (tab == "Open" && _openCount > 0)
                {
                    <span class="badge bg-primary ms-1">@_openCount</span>
                }
            </button>
        </li>
    }
</ul>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_requests.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-tools fs-1 d-block mb-3 opacity-25"></i>
            <h5>No requests</h5>
            <p class="mb-0 small">No maintenance requests found for this filter.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Resident</th>
                            <th>Unit</th>
                            <th>Issue</th>
                            <th>Category</th>
                            <th>Priority</th>
                            <th>Submitted</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _requests)
                        {
                            var unitLabel = r.Unit is null ? "—"
                                : r.Unit.Block is not null ? $"{r.Unit.Block}-{r.Unit.UnitNumber}"
                                : r.Unit.UnitNumber;

                            <tr>
                                <td class="ps-3">
                                    <div class="fw-medium">@r.Resident.FullName</div>
                                    <small class="text-muted">@r.Resident.Email</small>
                                </td>
                                <td class="small">@unitLabel</td>
                                <td>
                                    <div class="fw-medium">@r.Title</div>
                                    <small class="text-muted">@r.Description</small>
                                </td>
                                <td><span class="badge bg-light text-dark border">@r.Category</span></td>
                                <td>@((MarkupString)PriorityBadge(r.Priority))</td>
                                <td class="small text-muted">
                                    @r.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")<br />
                                    @r.CreatedAt.ToLocalTime().ToString("h:mm tt")
                                </td>
                                <td>@((MarkupString)StatusBadge(r.Status))</td>
                                <td class="text-end pe-3">
                                    @if (_editingId == r.Id)
                                    {
                                        <div class="d-flex flex-column gap-2 align-items-end" style="min-width:220px;">
                                            <select class="form-select form-select-sm" @bind="_editStatus">
                                                @foreach (var s in Enum.GetValues<MaintenanceStatus>())
                                                {
                                                    <option value="@s">@s</option>
                                                }
                                            </select>
                                            <input class="form-control form-control-sm"
                                                   placeholder="Staff note (optional)"
                                                   @bind="_editNote" />
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-primary btn-sm"
                                                        @onclick="() => SaveUpdateAsync(r.Id)"
                                                        disabled="@_busy">
                                                    Save
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm"
                                                        @onclick="CancelEdit"
                                                        disabled="@_busy">
                                                    Cancel
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary btn-sm"
                                                @onclick="() => StartEdit(r)">
                                            <i class="bi bi-pencil me-1"></i>Update
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private static readonly string[] _tabs = ["All", "Open", "In Progress", "Resolved", "Closed"];
    private string _activeTab = "Open";

    private List<MaintenanceRequest> _requests = [];
    private int _openCount;
    private bool _loading = true;
    private bool _busy;

    private Guid? _editingId;
    private MaintenanceStatus _editStatus;
    private string _editNote = "";

    private string? _toast;
    private string _toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _requests  = await MaintenanceSvc.GetAllAsync(TabToStatus(_activeTab));
        _openCount = await MaintenanceSvc.GetOpenCountAsync();
        _loading = false;
    }

    private async Task SetTab(string tab)
    {
        _activeTab = tab;
        _editingId = null;
        await LoadAsync();
    }

    private void StartEdit(MaintenanceRequest r)
    {
        _editingId  = r.Id;
        _editStatus = r.Status;
        _editNote   = r.StaffNote ?? "";
    }

    private void CancelEdit() => _editingId = null;

    private async Task SaveUpdateAsync(Guid id)
    {
        _busy = true;
        try
        {
            await MaintenanceSvc.UpdateStatusAsync(id, _editStatus, _editNote);
            _editingId = null;
            await LoadAsync();
            ShowToast("Request updated.", "success");
        }
        catch (Exception ex)
        {
            ShowToast(ex.Message, "danger");
        }
        finally { _busy = false; }
    }

    private void ShowToast(string message, string type)
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            _toast = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private static MaintenanceStatus? TabToStatus(string tab) => tab switch
    {
        "Open"        => MaintenanceStatus.Open,
        "In Progress" => MaintenanceStatus.InProgress,
        "Resolved"    => MaintenanceStatus.Resolved,
        "Closed"      => MaintenanceStatus.Closed,
        _             => null
    };

    private static string PriorityBadge(MaintenancePriority p) => p switch
    {
        MaintenancePriority.Low    => "<span class=\"badge bg-secondary\">Low</span>",
        MaintenancePriority.Medium => "<span class=\"badge bg-info text-dark\">Medium</span>",
        MaintenancePriority.High   => "<span class=\"badge bg-warning text-dark\">High</span>",
        MaintenancePriority.Urgent => "<span class=\"badge bg-danger\">Urgent</span>",
        _                          => "<span class=\"badge bg-light text-dark\">—</span>"
    };

    private static string StatusBadge(MaintenanceStatus s) => s switch
    {
        MaintenanceStatus.Open       => "<span class=\"badge bg-primary\">Open</span>",
        MaintenanceStatus.InProgress => "<span class=\"badge bg-warning text-dark\">In Progress</span>",
        MaintenanceStatus.Resolved   => "<span class=\"badge bg-success\">Resolved</span>",
        MaintenanceStatus.Closed     => "<span class=\"badge bg-secondary\">Closed</span>",
        _                            => "<span class=\"badge bg-light text-dark\">—</span>"
    };
}
