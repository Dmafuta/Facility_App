@page "/setup"
@layout AuthLayout
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>FacilityApp Setup</PageTitle>

<div class="auth-split">

    <div class="auth-brand d-none d-lg-flex">
        <div class="brand-inner">
            <div class="brand-logo mb-4"><i class="bi bi-buildings"></i></div>
            <h1 class="brand-title">FacilityApp</h1>
            <p class="brand-subtitle">First-time setup</p>
            <hr class="brand-divider my-4" />
            <ul class="brand-features list-unstyled">
                <li><i class="bi bi-building-fill"></i><span>Create your facility profile</span></li>
                <li><i class="bi bi-person-badge-fill"></i><span>Set up your first admin account</span></li>
                <li><i class="bi bi-shield-lock-fill"></i><span>Get started in under 2 minutes</span></li>
            </ul>
            <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year FacilityApp.</p>
        </div>
    </div>

    <div class="auth-form-panel d-flex align-items-center justify-content-center">
        <div class="auth-form-wrap">

            @if (_alreadySetup)
            {
                <div class="text-center">
                    <div class="mb-3" style="font-size:3rem;"><i class="bi bi-check-circle-fill text-success"></i></div>
                    <h4 class="fw-bold">Already configured</h4>
                    <p class="text-muted">This instance has already been set up. Sign in to continue.</p>
                    <a href="/" class="btn btn-primary mt-2">Go to Login</a>
                </div>
            }
            else if (_done)
            {
                <div class="text-center">
                    <div class="mb-3" style="font-size:3rem;"><i class="bi bi-check-circle-fill text-success"></i></div>
                    <h4 class="fw-bold">Setup complete!</h4>
                    <p class="text-muted mb-1">Your facility <strong>@_form.FacilityName</strong> is ready.</p>
                    <p class="text-muted small mb-4">Sign in with <strong>@_form.AdminEmail</strong>.</p>
                    <a href="/@_createdSlug/login" class="btn btn-primary w-100">Sign In Now</a>
                </div>
            }
            else
            {
                <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                    <div class="mobile-logo"><i class="bi bi-buildings"></i></div>
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">FacilityApp Setup</div>
                </div>

                <h2 class="form-heading">Welcome</h2>
                <p class="form-subheading mb-4">Create your facility and first admin account to get started.</p>

                @if (_error is not null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 small mb-3">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                        <span>@_error</span>
                    </div>
                }

                <EditForm Model="_form" OnValidSubmit="HandleSetupAsync" FormName="setup">
                    <DataAnnotationsValidator />

                    <p class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em;">Facility</p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Facility Name</label>
                        <InputText @bind-Value="_form.FacilityName" class="form-control"
                                   placeholder="e.g. Sunrise Towers" />
                        <ValidationMessage For="() => _form.FacilityName" class="text-danger small mt-1" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold small">URL Slug</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted" style="font-size:.85rem;">
                                @Nav.BaseUri
                            </span>
                            <InputText @bind-Value="_form.Slug" class="form-control"
                                       placeholder="sunrise-towers" />
                        </div>
                        <div class="form-text">Lowercase letters, numbers and hyphens only. Cannot be changed later.</div>
                        <ValidationMessage For="() => _form.Slug" class="text-danger small mt-1" />
                    </div>

                    <hr class="my-3" />
                    <p class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em;">Admin Account</p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Full Name</label>
                        <InputText @bind-Value="_form.AdminName" class="form-control" placeholder="Jane Smith" />
                        <ValidationMessage For="() => _form.AdminName" class="text-danger small mt-1" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Email Address</label>
                        <InputText @bind-Value="_form.AdminEmail" class="form-control"
                                   placeholder="admin@facility.com" autocomplete="email" />
                        <ValidationMessage For="() => _form.AdminEmail" class="text-danger small mt-1" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Password</label>
                        <InputText type="password" @bind-Value="_form.Password" class="form-control"
                                   placeholder="Min. 8 characters, 1 digit" autocomplete="new-password" />
                        <ValidationMessage For="() => _form.Password" class="text-danger small mt-1" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold small">Confirm Password</label>
                        <InputText type="password" @bind-Value="_form.ConfirmPassword" class="form-control"
                                   placeholder="Repeat password" autocomplete="new-password" />
                        <ValidationMessage For="() => _form.ConfirmPassword" class="text-danger small mt-1" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Setting up…</span>
                        }
                        else
                        {
                            <i class="bi bi-rocket-takeoff me-2"></i>
                            <span>Create Facility &amp; Admin</span>
                        }
                    </button>
                </EditForm>
            }

        </div>
    </div>
</div>

@code {
    private SetupForm _form = new();
    private string? _error;
    private bool _busy;
    private bool _done;
    private bool _alreadySetup;
    private string _createdSlug = "";

    protected override async Task OnInitializedAsync()
    {
        _alreadySetup = await Db.Tenants.IgnoreQueryFilters().AnyAsync();
    }

    private async Task HandleSetupAsync()
    {
        _busy  = true;
        _error = null;

        try
        {
            // Double-check: abort if tenants already exist
            if (await Db.Tenants.IgnoreQueryFilters().AnyAsync())
            {
                _alreadySetup = true;
                return;
            }

            var slug = _form.Slug.Trim().ToLower();

            var tenant = new Tenant
            {
                Id        = Guid.NewGuid(),
                Name      = _form.FacilityName.Trim(),
                Slug      = slug,
                IsActive  = true,
                CreatedAt = DateTime.UtcNow
            };
            Db.Tenants.Add(tenant);
            await Db.SaveChangesAsync();

            var user = new ApplicationUser
            {
                UserName = _form.AdminEmail,
                Email    = _form.AdminEmail,
                FullName = _form.AdminName.Trim(),
                TenantId = tenant.Id,
                UserType = UserType.Staff
            };

            var result = await UserManager.CreateAsync(user, _form.Password);
            if (!result.Succeeded)
            {
                // Roll back tenant
                Db.Tenants.Remove(tenant);
                await Db.SaveChangesAsync();
                _error = string.Join(" ", result.Errors.Select(e => e.Description));
                return;
            }

            await UserManager.AddToRoleAsync(user, Program.RoleAdmin);

            _createdSlug = slug;
            _done        = true;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private sealed class SetupForm
    {
        [Required(ErrorMessage = "Facility name is required.")]
        [MaxLength(100)]
        public string FacilityName { get; set; } = "";

        [Required(ErrorMessage = "Slug is required.")]
        [RegularExpression(@"^[a-z0-9\-]+$", ErrorMessage = "Only lowercase letters, numbers and hyphens.")]
        [MaxLength(60)]
        public string Slug { get; set; } = "";

        [Required(ErrorMessage = "Full name is required.")]
        [MaxLength(100)]
        public string AdminName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string AdminEmail { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
