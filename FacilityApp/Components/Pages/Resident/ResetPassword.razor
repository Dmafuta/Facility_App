@page "/{TenantSlug}/resident/reset-password"
@page "/resident/reset-password"
@layout AuthLayout
@inject UserManager<ApplicationUser> UserManager
@inject TenantContext TenantCtx

<PageTitle>Reset Password — FacilityApp</PageTitle>

<div class="auth-split">

    <div class="auth-brand d-none d-lg-flex">
        <div class="brand-inner">
            <div class="brand-logo mb-4"><i class="bi bi-buildings"></i></div>
            <h1 class="brand-title">FacilityApp</h1>
            <p class="brand-subtitle">Resident Portal</p>
        </div>
    </div>

    <div class="auth-form-panel d-flex align-items-center justify-content-center">
        <div class="auth-form-wrap">

            <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                <div class="mobile-logo"><i class="bi bi-buildings"></i></div>
                <div class="fw-bold text-dark" style="font-size:1.1rem;">Resident Portal</div>
            </div>

            @if (_done)
            {
                <div class="text-center">
                    <div class="mb-3" style="font-size:3rem;"><i class="bi bi-check-circle-fill text-success"></i></div>
                    <h4 class="fw-bold">Password updated!</h4>
                    <p class="text-muted">You can now sign in with your new password.</p>
                    <a href="@(TenantCtx.RouteBase)/resident/login" class="btn btn-primary mt-2">Sign In</a>
                </div>
            }
            else if (_invalidLink)
            {
                <div class="text-center">
                    <div class="mb-3" style="font-size:3rem;"><i class="bi bi-x-circle-fill text-danger"></i></div>
                    <h4 class="fw-bold">Invalid or expired link</h4>
                    <p class="text-muted">This password reset link is no longer valid.</p>
                    <a href="@(TenantCtx.RouteBase)/resident/forgot-password" class="btn btn-primary mt-2">Request a new link</a>
                </div>
            }
            else
            {
                <h2 class="form-heading">Reset Password</h2>
                <p class="form-subheading mb-4">Enter your new password below.</p>

                @if (_error is not null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 small mb-3">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                        <span>@_error</span>
                    </div>
                }

                <EditForm Model="_form" OnValidSubmit="HandleAsync" FormName="resident-reset-password">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">New Password</label>
                        <InputText type="password" @bind-Value="_form.Password" class="form-control"
                                   placeholder="Min. 8 characters, 1 digit" autocomplete="new-password" />
                        <ValidationMessage For="() => _form.Password" class="text-danger small mt-1" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold small">Confirm Password</label>
                        <InputText type="password" @bind-Value="_form.ConfirmPassword" class="form-control"
                                   placeholder="Repeat password" autocomplete="new-password" />
                        <ValidationMessage For="() => _form.ConfirmPassword" class="text-danger small mt-1" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Saving…</span>
                        }
                        else
                        {
                            <i class="bi bi-lock me-2"></i>
                            <span>Set New Password</span>
                        }
                    </button>
                </EditForm>
            }

        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = "";
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private ResetForm _form = new();
    private bool _busy;
    private bool _done;
    private bool _invalidLink;
    private string? _error;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
            _invalidLink = true;
    }

    private async Task HandleAsync()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            _invalidLink = true; return;
        }

        _busy = true; _error = null;
        try
        {
            var user = await UserManager.FindByEmailAsync(Email);
            if (user is null) { _invalidLink = true; return; }

            var result = await UserManager.ResetPasswordAsync(user, Token, _form.Password);
            if (result.Succeeded)
            {
                _done = true;
            }
            else
            {
                var errs = result.Errors.Select(e => e.Description).ToList();
                if (errs.Any(e => e.Contains("Invalid token", StringComparison.OrdinalIgnoreCase)))
                    _invalidLink = true;
                else
                    _error = string.Join(" ", errs);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private sealed class ResetForm
    {
        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
