@page "/{TenantSlug}/access/blacklist"
@page "/access/blacklist"
@layout MainLayout
@attribute [Authorize(Policy = "CanManageAccess")]
@inject IBlacklistService BlacklistSvc
@inject AuthenticationStateProvider AuthState

<PageTitle>Blacklist / Watchlist — FacilityApp</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Blacklist &amp; Watchlist</h4>
        <small class="text-muted">Control visitor access — block or flag individuals</small>
    </div>
    <button class="btn btn-danger" @onclick="() => _showForm = true">
        <i class="bi bi-person-x me-1"></i> Add Entry
    </button>
</div>

<!-- Add Entry Form -->
@if (_showForm)
{
    <div class="card border-danger border-0 shadow mb-4">
        <div class="card-header bg-danger text-white fw-semibold">
            <i class="bi bi-person-x me-2"></i>New Blacklist / Watchlist Entry
        </div>
        <div class="card-body">
            <EditForm Model="_form" OnValidSubmit="SaveEntryAsync">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="_form.FullName" placeholder="John Doe" />
                        <ValidationMessage For="() => _form.FullName" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="_form.Email" placeholder="john@example.com" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Phone</label>
                        <InputText class="form-control" @bind-Value="_form.Phone" placeholder="555-1234" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="_form.Reason" placeholder="e.g. Trespassing, theft…" />
                        <ValidationMessage For="() => _form.Reason" class="text-danger small" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Entry Type</label>
                        <InputSelect class="form-select" @bind-Value="_form.EntryType">
                            <option value="@FacilityApp.Data.Models.BlacklistType.Blacklisted">Blacklisted (Block)</option>
                            <option value="@FacilityApp.Data.Models.BlacklistType.Watchlisted">Watchlisted (Alert)</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Expires</label>
                        <InputDate class="form-control" @bind-Value="_form.ExpiresAt" />
                        <small class="text-muted">Leave blank = permanent</small>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notes</label>
                        <InputTextArea class="form-control" @bind-Value="_form.Notes" rows="2"
                                       placeholder="Additional context…" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger mt-3 py-2">@_formError</div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-danger" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Add to List
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <input class="form-control form-control-sm" placeholder="Search name, email, phone, reason…"
                       @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
            </div>
            <div class="col-auto">
                <select class="form-select form-select-sm" @bind="_typeFilter" @bind:after="LoadAsync">
                    <option value="">All Entries</option>
                    <option value="blacklisted">Blacklisted</option>
                    <option value="watchlisted">Watchlisted</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
}
else if (_items.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-shield-check display-4 d-block mb-2 text-success"></i>
        No entries found. The list is clear.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Type</th>
                        <th>Reason</th>
                        <th>Added By</th>
                        <th>Added</th>
                        <th>Expires</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in _items)
                    {
                        <tr class="@(e.EntryType == FacilityApp.Data.Models.BlacklistType.Blacklisted ? "table-danger" : "table-warning")">
                            <td class="fw-semibold">@e.FullName</td>
                            <td>@(e.Email ?? "—")</td>
                            <td>@(e.Phone ?? "—")</td>
                            <td>
                                @if (e.EntryType == FacilityApp.Data.Models.BlacklistType.Blacklisted)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-octagon me-1"></i>Blacklisted</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-eye me-1"></i>Watchlisted</span>
                                }
                            </td>
                            <td>@e.Reason</td>
                            <td>@e.AddedByName</td>
                            <td class="text-nowrap">@e.AddedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="text-nowrap">
                                @(e.ExpiresAt.HasValue
                                    ? e.ExpiresAt.Value.ToLocalTime().ToString("dd MMM yyyy")
                                    : "Permanent")
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => RemoveEntry(e.Id)">
                                    <i class="bi bi-trash me-1"></i>Remove
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (_totalPages > 1)
    {
        <nav class="mt-3 d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @((_page-1)*_pageSize+1)–@(Math.Min(_page*_pageSize,_total)) of @_total</small>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(_page==1?"disabled":"")">
                    <button class="page-link" @onclick="PrevPage">‹</button>
                </li>
                @for (var i = 1; i <= _totalPages; i++)
                {
                    var p = i;
                    <li class="page-item @(_page==p?"active":"")">
                        <button class="page-link" @onclick="() => GoToPage(p)">@p</button>
                    </li>
                }
                <li class="page-item @(_page==_totalPages?"disabled":"")">
                    <button class="page-link" @onclick="NextPage">›</button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<FacilityApp.Data.Models.BlacklistEntry> _items = [];
    private bool _loading = true;
    private string? _search;
    private string? _typeFilter;
    private int _page = 1, _pageSize = 25, _total, _totalPages;

    private bool _showForm;
    private bool _saving;
    private string? _formError;
    private BlacklistForm _form = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _formError = null;
        try
        {
            (_items, _total) = await BlacklistSvc.GetEntriesAsync(_search, _typeFilter, _page, _pageSize);
            _totalPages = (int)Math.Ceiling(_total / (double)_pageSize);
        }
        catch (Exception)
        {
            _formError = "Failed to load entries. Please refresh the page.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadAsync(); }
    }

    private async Task SaveEntryAsync()
    {
        _saving = true;
        _formError = null;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var user = auth.User;
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
            var userName = user.Identity?.Name ?? "Unknown";

            DateTime? expiresUtc = _form.ExpiresAt.HasValue
                ? DateTime.SpecifyKind(_form.ExpiresAt.Value, DateTimeKind.Local).ToUniversalTime()
                : null;

            await BlacklistSvc.AddAsync(
                _form.FullName!, _form.Email, _form.Phone,
                _form.Reason!, _form.EntryType, expiresUtc, _form.Notes,
                userId, userName);

            _form = new();
            _showForm = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task RemoveEntry(Guid id)
    {
        try
        {
            await BlacklistSvc.RemoveAsync(id);
            await LoadAsync();
        }
        catch (Exception)
        {
            _formError = "Failed to remove entry. Please try again.";
        }
    }

    private void CancelForm() { _showForm = false; _form = new(); _formError = null; }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadAsync(); } }
    private async Task GoToPage(int p) { _page = p; await LoadAsync(); }

    private class BlacklistForm
    {
        [Required] public string? FullName { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        [Required] public string? Reason { get; set; }
        public FacilityApp.Data.Models.BlacklistType EntryType { get; set; } = FacilityApp.Data.Models.BlacklistType.Blacklisted;
        public DateTime? ExpiresAt { get; set; }
        public string? Notes { get; set; }
    }
}
