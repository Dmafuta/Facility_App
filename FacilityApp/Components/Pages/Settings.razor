@page "/{TenantSlug}/settings"
@page "/settings"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanManageUnits")]
@inject ISettingsService SettingsSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject IWebHostEnvironment Env

<PageTitle>Settings — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-gear me-2 text-primary"></i>Settings</h4>
        <small class="text-muted">Manage facility information and preferences</small>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-building me-2 text-primary"></i>Facility Information</h6>
                </div>
                <div class="card-body">
                    <EditForm Model="_form" OnValidSubmit="SaveAsync" FormName="settings">
                        <DataAnnotationsValidator />

                        @if (_error is not null)
                        {
                            <div class="alert alert-danger py-2 small">@_error</div>
                        }
                        @if (_saved)
                        {
                            <div class="alert alert-success py-2 small">
                                <i class="bi bi-check-circle me-1"></i>Settings saved successfully.
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-medium small">Facility Name <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_form.Name" placeholder="e.g. Sunrise Towers" />
                            <ValidationMessage For="() => _form.Name" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Contact Email</label>
                            <InputText class="form-control" @bind-Value="_form.ContactEmail" placeholder="info@facility.com" />
                            <ValidationMessage For="() => _form.ContactEmail" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Contact Phone</label>
                            <InputText class="form-control" @bind-Value="_form.ContactPhone" placeholder="+1 555 000 0000" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Address</label>
                            <InputTextArea class="form-control" @bind-Value="_form.Address" rows="2"
                                           placeholder="123 Main Street, City, Country" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Website</label>
                            <InputText class="form-control" @bind-Value="_form.Website" placeholder="https://www.facility.com" />
                            <ValidationMessage For="() => _form.Website" class="text-danger small" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-medium small">Custom Domain</label>
                            <InputText class="form-control" @bind-Value="_form.CustomDomain" placeholder="e.g. greatwallgardens.estate" />
                            <div class="form-text">When set, residents and staff can access the app directly on this domain without a URL slug.</div>
                        </div>

                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Save Changes
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 bg-light">
                <div class="card-body py-4">
                    <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>About Settings</h6>
                    <ul class="list-unstyled small text-muted mb-0">
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Facility name appears on reports and the resident portal.</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Contact details are visible to residents.</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Changes take effect immediately across all pages.</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Only Admins and Managers can change these settings.</li>
                    </ul>

                    @if (_tenant is not null)
                    {
                        <hr class="my-3" />
                        <div class="small text-muted">
                            <div><strong>Slug:</strong> <code>@_tenant.Slug</code></div>
                            <div class="mt-1"><strong>Created:</strong> @_tenant.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Branding -->
    <div class="row g-4 mt-1">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-palette me-2 text-primary"></i>Branding</h6>
                </div>
                <div class="card-body">
                    @if (_brandError is not null)
                    {
                        <div class="alert alert-danger py-2 small">@_brandError</div>
                    }
                    @if (_brandSaved)
                    {
                        <div class="alert alert-success py-2 small"><i class="bi bi-check-circle me-1"></i>Branding saved.</div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-medium small">Sidebar Logo</label>
                        @if (!string.IsNullOrEmpty(_tenant?.LogoUrl))
                        {
                            <div class="mb-2 d-flex align-items-center gap-3">
                                <img src="@_tenant.LogoUrl" alt="Logo" style="height:48px;object-fit:contain;border-radius:6px;border:1px solid #dee2e6;" />
                                <button class="btn btn-sm btn-outline-danger" @onclick="RemoveLogoAsync">
                                    <i class="bi bi-trash me-1"></i>Remove
                                </button>
                            </div>
                        }
                        <InputFile OnChange="OnLogoSelected" accept="image/*" class="form-control" />
                        <div class="form-text">PNG or SVG recommended. Max 2 MB. Displayed in the sidebar header.</div>
                        @if (_logoError is not null)
                        {
                            <div class="text-danger small mt-1">@_logoError</div>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium small">Primary Colour</label>
                        <div class="d-flex align-items-center gap-3">
                            <input type="color" class="form-control form-control-color"
                                   @bind="_primaryColour" style="width:60px;height:38px;" />
                            <input type="text" class="form-control" style="max-width:120px;"
                                   @bind="_primaryColour" placeholder="#1b6ec2" />
                            <span class="badge" style="background:@_primaryColour;padding:.5em 1em;">Preview</span>
                        </div>
                        <div class="form-text">Applied to the sidebar gradient. Leave blank for the default blue.</div>
                    </div>

                    <button class="btn btn-primary" @onclick="SaveBrandingAsync" disabled="@_brandSaving">
                        @if (_brandSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save Branding
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private SettingsForm _form = new();
    private Data.Models.Tenant? _tenant;
    private bool _loading = true;
    private bool _saving;
    private bool _saved;
    private string? _error;

    // Branding
    private string _primaryColour = "#1b6ec2";
    private IBrowserFile? _logoFile;
    private string? _logoError;
    private bool _brandSaving;
    private bool _brandSaved;
    private string? _brandError;
    private const long MaxLogoBytes = 2 * 1024 * 1024;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var t = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (t is not null)
            {
                TenantCtx.TenantId   = t.Id;
                TenantCtx.TenantSlug = t.Slug;
                TenantCtx.TenantName = t.Name;
                TenantCtx.IsResolved = true;
            }
        }

        _tenant = await SettingsSvc.GetAsync();
        if (_tenant is not null)
        {
            _form = new SettingsForm
            {
                Name         = _tenant.Name,
                ContactEmail = _tenant.ContactEmail,
                ContactPhone = _tenant.ContactPhone,
                Address      = _tenant.Address,
                Website      = _tenant.Website,
                CustomDomain = _tenant.CustomDomain
            };
        }
        _loading = false;

        if (_tenant?.PrimaryColour is not null) _primaryColour = _tenant.PrimaryColour;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error  = null;
        _saved  = false;
        try
        {
            await SettingsSvc.UpdateAsync(
                _form.Name, _form.ContactEmail, _form.ContactPhone,
                _form.Address, _form.Website, _form.CustomDomain);
            _saved = true;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private void OnLogoSelected(InputFileChangeEventArgs e)
    {
        _logoError = null;
        if (e.File.Size > MaxLogoBytes) { _logoError = "Logo must be under 2 MB."; return; }
        _logoFile = e.File;
    }

    private async Task SaveBrandingAsync()
    {
        _brandSaving = true; _brandError = null; _brandSaved = false;
        try
        {
            string? logoUrl = _tenant?.LogoUrl;

            if (_logoFile is not null)
            {
                var slug = TenantCtx.TenantSlug;
                var dir = Path.Combine(Env.WebRootPath, "uploads", slug, "branding");
                Directory.CreateDirectory(dir);
                var ext  = Path.GetExtension(_logoFile.Name).ToLowerInvariant();
                var name = $"logo{ext}";
                var path = Path.Combine(dir, name);
                await using var fs     = new FileStream(path, FileMode.Create);
                await using var stream = _logoFile.OpenReadStream(MaxLogoBytes);
                await stream.CopyToAsync(fs);
                logoUrl = $"/uploads/{slug}/branding/{name}";
            }

            var colour = string.IsNullOrWhiteSpace(_primaryColour) ? null : _primaryColour.Trim();
            await SettingsSvc.UpdateBrandingAsync(logoUrl, colour);

            if (_tenant is not null)
            {
                _tenant.LogoUrl       = logoUrl;
                _tenant.PrimaryColour = colour;
            }
            _brandSaved = true;
        }
        catch (Exception ex) { _brandError = ex.Message; }
        finally { _brandSaving = false; }
    }

    private async Task RemoveLogoAsync()
    {
        await SettingsSvc.UpdateBrandingAsync(null, _tenant?.PrimaryColour);
        if (_tenant is not null) _tenant.LogoUrl = null;
    }

    private sealed class SettingsForm
    {
        [Required(ErrorMessage = "Facility name is required.")]
        [MaxLength(100)]
        public string Name { get; set; } = "";

        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        [MaxLength(200)]
        public string? ContactEmail { get; set; }

        [MaxLength(30)]
        public string? ContactPhone { get; set; }

        [MaxLength(300)]
        public string? Address { get; set; }

        [Url(ErrorMessage = "Enter a valid URL (e.g. https://example.com).")]
        [MaxLength(200)]
        public string? Website { get; set; }

        [MaxLength(253)]
        public string? CustomDomain { get; set; }
    }
}
