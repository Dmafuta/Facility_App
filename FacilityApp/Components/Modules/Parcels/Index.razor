@page "/{TenantSlug}/parcels"
@page "/parcels"
@layout MainLayout
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanCheckInVisitors")]
@inject IParcelService ParcelSvc
@inject IUnitService UnitSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState

@using FacilityApp.Data.Models

<PageTitle>Parcels — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>Parcel &amp; Delivery Tracking</h4>
        <small class="text-muted">Log incoming deliveries and track collection status</small>
    </div>
    @if (!_showForm)
    {
        <button class="btn btn-primary" @onclick="() => _showForm = true">
            <i class="bi bi-plus-lg me-1"></i>Log Delivery
        </button>
    }
</div>

@if (_showForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-2 text-primary"></i>Log Incoming Parcel</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-medium">Recipient Name <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="Full name of recipient" @bind="_recipientName" maxlength="120" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Unit</label>
                    <select class="form-select" @bind="_selectedUnitId">
                        <option value="">— Select unit (optional) —</option>
                        @foreach (var u in _units)
                        {
                            <option value="@u.Unit.Id">
                                @(u.Unit.Block is not null ? $"{u.Unit.Block}-{u.Unit.UnitNumber}" : u.Unit.UnitNumber)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Courier / Carrier</label>
                    <input class="form-control" placeholder="e.g. DHL, FedEx, Amazon" @bind="_courierName" maxlength="80" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Description <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="e.g. Small brown box, envelope" @bind="_description" maxlength="200" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-medium">Notes <span class="text-muted fw-normal">(optional)</span></label>
                    <input class="form-control" placeholder="Any additional notes" @bind="_notes" maxlength="300" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger mt-3 mb-0">@_formError</div>
            }
        </div>
        <div class="card-footer bg-white border-top d-flex gap-2 justify-content-end">
            <button class="btn btn-outline-secondary" @onclick="CancelForm" disabled="@_busy">Cancel</button>
            <button class="btn btn-primary" @onclick="ReceiveAsync" disabled="@_busy">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Log Parcel
            </button>
        </div>
    </div>
}

<!-- Tabs -->
<ul class="nav nav-tabs mb-3 flex-nowrap overflow-auto">
    <li class="nav-item">
        <button class="nav-link @(_tab == "pending" ? "active" : "")" @onclick='() => SetTab("pending")'>
            Pending
            @if (_pendingCount > 0)
            {
                <span class="badge bg-warning text-dark ms-1">@_pendingCount</span>
            }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == "collected" ? "active" : "")" @onclick='() => SetTab("collected")'>Collected</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == "returned" ? "active" : "")" @onclick='() => SetTab("returned")'>Returned</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_tab == "all" ? "active" : "")" @onclick='() => SetTab("all")'>All</button>
    </li>
</ul>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_parcels.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-box-seam fs-1 d-block mb-3 opacity-25"></i>
            <h5>No parcels found</h5>
            <p class="mb-0 small">@(_tab == "pending" ? "No pending deliveries at the moment." : $"No {_tab} parcels.")</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Recipient</th>
                            <th>Unit</th>
                            <th>Courier</th>
                            <th>Description</th>
                            <th>Received</th>
                            <th>Collected By</th>
                            <th class="text-center">Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _parcels)
                        {
                            <tr>
                                <td class="ps-3 fw-medium">@p.RecipientName</td>
                                <td class="small text-muted">
                                    @if (p.Unit is not null)
                                    {
                                        @(p.Unit.Block is not null
                                            ? $"{p.Unit.Block}-{p.Unit.UnitNumber}"
                                            : p.Unit.UnitNumber)
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td class="small">@(p.CourierName ?? "—")</td>
                                <td class="small text-muted" style="max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @p.Description
                                    @if (!string.IsNullOrEmpty(p.Notes))
                                    {
                                        <div class="text-muted fst-italic" style="font-size:0.75rem;">@p.Notes</div>
                                    }
                                </td>
                                <td class="small text-muted">
                                    @p.ReceivedAt.ToLocalTime().ToString("MMM d, yyyy")<br />
                                    @p.ReceivedAt.ToLocalTime().ToString("h:mm tt")
                                </td>
                                <td class="small text-muted">
                                    @if (p.Status == ParcelStatus.Collected && p.CollectedAt.HasValue)
                                    {
                                        <div>@p.CollectedByName</div>
                                        <div class="opacity-75">@p.CollectedAt.Value.ToLocalTime().ToString("MMM d, h:mm tt")</div>
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                </td>
                                <td class="text-center">@((MarkupString)StatusBadge(p.Status))</td>
                                <td class="text-end pe-3">
                                    @if (p.Status == ParcelStatus.Pending)
                                    {
                                        <div class="d-flex gap-1 justify-content-end flex-wrap">
                                            <button class="btn btn-sm btn-success" @onclick="() => OpenCollectModal(p)"
                                                    disabled="@_busy" title="Mark Collected">
                                                <i class="bi bi-check2-circle me-1"></i>Collected
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ReturnAsync(p.Id)"
                                                    disabled="@_busy" title="Mark Returned">
                                                <i class="bi bi-arrow-return-left"></i>
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Collect modal -->
@if (_collectParcel is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseCollectModal"></div>
    <div class="modal-panel card border-0 shadow-lg p-4" style="max-width:420px;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1055;">
        <h6 class="fw-semibold mb-3"><i class="bi bi-check2-circle me-2 text-success"></i>Mark as Collected</h6>
        <p class="small text-muted mb-3">Parcel for <strong>@_collectParcel.RecipientName</strong></p>
        <label class="form-label fw-medium">Collected By <span class="text-danger">*</span></label>
        <input class="form-control mb-3" placeholder="Name of person collecting" @bind="_collectedByName" />
        @if (!string.IsNullOrEmpty(_collectError))
        {
            <div class="alert alert-danger py-2 mb-3">@_collectError</div>
        }
        <div class="d-flex gap-2 justify-content-end">
            <button class="btn btn-outline-secondary btn-sm" @onclick="CloseCollectModal" disabled="@_busy">Cancel</button>
            <button class="btn btn-success btn-sm" @onclick="ConfirmCollectAsync" disabled="@_busy">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Confirm
            </button>
        </div>
    </div>
}

@if (_toast is not null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
        <div class="toast show align-items-center text-bg-@_toastType border-0 shadow">
            <div class="d-flex">
                <div class="toast-body">@_toast</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => _toast = null"></button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Parcel> _parcels = [];
    private List<UnitDetails> _units = [];
    private bool _loading = true;
    private bool _busy;
    private string _tab = "pending";
    private int _pendingCount;
    private string _staffUserId = "";

    // Form fields
    private bool _showForm;
    private string _recipientName = "";
    private string _selectedUnitId = "";
    private string _courierName = "";
    private string _description = "";
    private string _notes = "";
    private string _formError = "";

    // Collect modal
    private Parcel? _collectParcel;
    private string _collectedByName = "";
    private string _collectError = "";

    private string? _toast;
    private string _toastType = "success";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _staffUserId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        _units        = await UnitSvc.GetAllAsync();
        _pendingCount = await ParcelSvc.GetPendingCountAsync();
        await LoadParcelsAsync();
        _loading = false;
    }

    private async Task LoadParcelsAsync()
    {
        _parcels = _tab switch
        {
            "pending"   => await ParcelSvc.GetAllAsync(ParcelStatus.Pending),
            "collected" => await ParcelSvc.GetAllAsync(ParcelStatus.Collected),
            "returned"  => await ParcelSvc.GetAllAsync(ParcelStatus.Returned),
            _           => await ParcelSvc.GetAllAsync()
        };
        _pendingCount = await ParcelSvc.GetPendingCountAsync();
    }

    private async Task SetTab(string tab)
    {
        _tab = tab;
        await LoadParcelsAsync();
    }

    private async Task ReceiveAsync()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_recipientName)) { _formError = "Recipient name is required."; return; }
        if (string.IsNullOrWhiteSpace(_description))   { _formError = "Description is required."; return; }

        _busy = true;
        try
        {
            Guid? unitId = Guid.TryParse(_selectedUnitId, out var uid) ? uid : null;
            await ParcelSvc.ReceiveAsync(unitId, _recipientName, _courierName, _description, _staffUserId, _notes);
            await LoadParcelsAsync();
            CancelForm();
            ShowToast("Parcel logged successfully.", "success");
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task ReturnAsync(Guid id)
    {
        _busy = true;
        try
        {
            await ParcelSvc.MarkReturnedAsync(id);
            await LoadParcelsAsync();
            ShowToast("Parcel marked as returned.", "secondary");
        }
        catch (Exception ex) { ShowToast(ex.Message, "danger"); }
        finally { _busy = false; }
    }

    private void OpenCollectModal(Parcel p)
    {
        _collectParcel    = p;
        _collectedByName  = "";
        _collectError     = "";
    }

    private void CloseCollectModal()
    {
        _collectParcel   = null;
        _collectedByName = "";
        _collectError    = "";
    }

    private async Task ConfirmCollectAsync()
    {
        if (string.IsNullOrWhiteSpace(_collectedByName)) { _collectError = "Please enter who collected the parcel."; return; }

        _busy = true;
        try
        {
            await ParcelSvc.MarkCollectedAsync(_collectParcel!.Id, _collectedByName);
            CloseCollectModal();
            await LoadParcelsAsync();
            ShowToast("Parcel marked as collected.", "success");
        }
        catch (Exception ex) { _collectError = ex.Message; }
        finally { _busy = false; }
    }

    private void CancelForm()
    {
        _showForm      = false;
        _recipientName = "";
        _selectedUnitId = "";
        _courierName   = "";
        _description   = "";
        _notes         = "";
        _formError     = "";
    }

    private void ShowToast(string message, string type)
    {
        _toast     = message;
        _toastType = type;
        _ = Task.Delay(4000).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }

    private static string StatusBadge(ParcelStatus s) => s switch
    {
        ParcelStatus.Pending   => "<span class=\"badge bg-warning text-dark\">Pending</span>",
        ParcelStatus.Collected => "<span class=\"badge bg-success\">Collected</span>",
        ParcelStatus.Returned  => "<span class=\"badge bg-secondary\">Returned</span>",
        _                      => "<span class=\"badge bg-light text-dark\">—</span>"
    };
}
