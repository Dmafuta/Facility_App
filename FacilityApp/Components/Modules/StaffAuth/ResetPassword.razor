@page "/{TenantSlug}/reset-password"
@page "/reset-password"
@layout AuthLayout
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@inject TenantContext TenantCtx

<PageTitle>Reset Password — FacilityApp</PageTitle>

<div class="auth-split">

    <!-- Left branding panel -->
    <div class="auth-brand d-none d-lg-flex">
        <div class="deco-circle"></div>
        <div class="brand-inner">
            <div class="brand-logo mb-4"><i class="bi bi-buildings"></i></div>
            <h1 class="brand-title">FacilityApp</h1>
            <p class="brand-subtitle">Set New Password</p>

            <hr class="brand-divider my-4" />

            <ul class="brand-features list-unstyled">
                <li>
                    <div class="feat-icon"><i class="bi bi-shield-lock-fill"></i></div>
                    <span>Choose a strong password with at least 8 characters</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-key-fill"></i></div>
                    <span>Include a mix of letters, numbers and symbols</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-check-circle-fill"></i></div>
                    <span>You'll be signed in automatically after resetting</span>
                </li>
            </ul>

            <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year FacilityApp. All rights reserved.</p>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-wrap">

            <!-- Mobile logo -->
            <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                <div class="mobile-logo"><i class="bi bi-buildings"></i></div>
                <div>
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">FacilityApp</div>
                    <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;">Set New Password</div>
                </div>
            </div>

            <div class="login-card">
                @if (_done)
                {
                    <div class="text-center py-2">
                        <div class="mb-3" style="font-size:3.5rem;line-height:1;">
                            <i class="bi bi-check-circle-fill text-success"></i>
                        </div>
                        <h4 class="fw-bold mb-2">Password updated!</h4>
                        <p class="text-muted small mb-4">Your password has been reset successfully. You can now sign in with your new password.</p>
                        <a href="@(TenantCtx.RouteBase)/login" class="btn-signin d-inline-flex align-items-center justify-content-center gap-2" style="text-decoration:none;">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In
                        </a>
                    </div>
                }
                else if (_invalidLink)
                {
                    <div class="text-center py-2">
                        <div class="mb-3" style="font-size:3.5rem;line-height:1;">
                            <i class="bi bi-x-circle-fill text-danger"></i>
                        </div>
                        <h4 class="fw-bold mb-2">Link expired</h4>
                        <p class="text-muted small mb-4">This password reset link is invalid or has expired. Please request a new one.</p>
                        <a href="@(TenantCtx.RouteBase)/forgot-password" class="btn-signin d-inline-flex align-items-center justify-content-center gap-2" style="text-decoration:none;">
                            <i class="bi bi-arrow-repeat"></i> Request a new link
                        </a>
                    </div>
                }
                else
                {
                    <h2 class="form-heading">Set new password</h2>
                    <p class="form-subheading">Enter and confirm your new password below.</p>

                    @if (_error is not null)
                    {
                        <div class="alert alert-danger alert-signin d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                            <span>@_error</span>
                        </div>
                    }

                    <EditForm Model="_form" OnValidSubmit="HandleAsync" FormName="reset-password">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="field-label">New Password</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-lock field-icon"></i>
                                <InputText type="@(_showPassword ? "text" : "password")"
                                           @bind-Value="_form.Password"
                                           class="form-control"
                                           style="padding-left:2.4rem;padding-right:2.75rem;"
                                           placeholder="Min. 8 characters, 1 digit"
                                           autocomplete="new-password" />
                                <button type="button" class="btn-pw-toggle"
                                        @onclick="() => _showPassword = !_showPassword"
                                        tabindex="-1"
                                        title="@(_showPassword ? "Hide password" : "Show password")">
                                    <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="() => _form.Password" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-4">
                            <label class="field-label">Confirm Password</label>
                            <div class="input-icon-wrap">
                                <i class="bi bi-lock-fill field-icon"></i>
                                <InputText type="@(_showConfirm ? "text" : "password")"
                                           @bind-Value="_form.ConfirmPassword"
                                           class="form-control"
                                           style="padding-left:2.4rem;padding-right:2.75rem;"
                                           placeholder="Repeat password"
                                           autocomplete="new-password" />
                                <button type="button" class="btn-pw-toggle"
                                        @onclick="() => _showConfirm = !_showConfirm"
                                        tabindex="-1"
                                        title="@(_showConfirm ? "Hide password" : "Show password")">
                                    <i class="bi @(_showConfirm ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="() => _form.ConfirmPassword" class="text-danger small mt-1" />
                        </div>

                        <button type="submit" class="btn-signin" disabled="@_busy">
                            @if (_busy)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Saving…</span>
                            }
                            else
                            {
                                <i class="bi bi-lock me-2"></i>
                                <span>Set New Password</span>
                            }
                        </button>
                    </EditForm>
                }
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = "";
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private ResetForm _form = new();
    private bool _busy;
    private bool _done;
    private bool _invalidLink;
    private string? _error;
    private bool _showPassword;
    private bool _showConfirm;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
            _invalidLink = true;
    }

    private async Task HandleAsync()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            _invalidLink = true; return;
        }

        _busy = true; _error = null;
        try
        {
            var user = await UserManager.FindByEmailAsync(Email);
            if (user is null) { _invalidLink = true; return; }

            var result = await UserManager.ResetPasswordAsync(user, Token, _form.Password);
            if (result.Succeeded)
            {
                _done = true;
            }
            else
            {
                var errs = result.Errors.Select(e => e.Description).ToList();
                if (errs.Any(e => e.Contains("Invalid token", StringComparison.OrdinalIgnoreCase)))
                    _invalidLink = true;
                else
                    _error = string.Join(" ", errs);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private sealed class ResetForm
    {
        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
