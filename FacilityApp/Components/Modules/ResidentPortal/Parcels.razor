@page "/{TenantSlug}/resident/parcels"
@page "/resident/parcels"
@layout ResidentLayout
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject IParcelService ParcelSvc
@inject IUnitService UnitSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState

@using FacilityApp.Data.Models

<PageTitle>My Parcels — @TenantCtx.TenantName</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>My Parcels</h4>
        <small class="text-muted">Track deliveries and parcels received on your behalf</small>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_unitId is null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-house-x fs-1 d-block mb-3 opacity-25"></i>
            <h5>No unit assigned</h5>
            <p class="small mb-0">You need to be assigned to a unit before parcels can be tracked for you.</p>
        </div>
    </div>
}
else if (_parcels.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-box-seam fs-1 d-block mb-3 opacity-25"></i>
            <h5>No parcels yet</h5>
            <p class="small mb-0">When the reception logs a delivery for your unit, it will appear here.</p>
        </div>
    </div>
}
else
{
    @if (_pendingParcels.Count > 0)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-4 shadow-sm">
            <i class="bi bi-bell-fill fs-5"></i>
            <div>
                <strong>@_pendingParcels.Count pending @(_pendingParcels.Count == 1 ? "parcel" : "parcels") awaiting collection.</strong>
                Please collect from reception at your earliest convenience.
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3">
            <h6 class="mb-0 fw-semibold">Delivery History</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Description</th>
                            <th>Courier</th>
                            <th>Received</th>
                            <th>Collected By</th>
                            <th class="text-center pe-3">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _parcels)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-medium">@p.Description</div>
                                    @if (!string.IsNullOrEmpty(p.Notes))
                                    {
                                        <small class="text-muted fst-italic">@p.Notes</small>
                                    }
                                </td>
                                <td class="small text-muted">@(p.CourierName ?? "—")</td>
                                <td class="small text-muted">
                                    @p.ReceivedAt.ToLocalTime().ToString("MMM d, yyyy")<br />
                                    @p.ReceivedAt.ToLocalTime().ToString("h:mm tt")
                                </td>
                                <td class="small text-muted">
                                    @if (p.Status == ParcelStatus.Collected && p.CollectedAt.HasValue)
                                    {
                                        <div>@p.CollectedByName</div>
                                        <div class="opacity-75">@p.CollectedAt.Value.ToLocalTime().ToString("MMM d, h:mm tt")</div>
                                    }
                                    else { <span>—</span> }
                                </td>
                                <td class="text-center pe-3">@((MarkupString)StatusBadge(p.Status))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private List<Parcel> _parcels = [];
    private List<Parcel> _pendingParcels = [];
    private Guid? _unitId;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth   = await AuthState.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (!string.IsNullOrEmpty(userId))
        {
            var units = await UnitSvc.GetForUserAsync(userId);
            _unitId = units.FirstOrDefault().Unit?.Id;

            if (_unitId.HasValue)
            {
                _parcels        = await ParcelSvc.GetForUnitAsync(_unitId.Value);
                _pendingParcels = _parcels.Where(p => p.Status == ParcelStatus.Pending).ToList();
            }
        }

        _loading = false;
    }

    private static string StatusBadge(ParcelStatus s) => s switch
    {
        ParcelStatus.Pending   => "<span class=\"badge bg-warning text-dark\">Pending</span>",
        ParcelStatus.Collected => "<span class=\"badge bg-success\">Collected</span>",
        ParcelStatus.Returned  => "<span class=\"badge bg-secondary\">Returned</span>",
        _                      => "<span class=\"badge bg-light text-dark\">—</span>"
    };
}
