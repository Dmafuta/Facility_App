@page "/{TenantSlug}/resident/login"
@page "/resident/login"
@layout AuthLayout
@rendermode InteractiveServer
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ITenantService TenantService
@inject TenantContext TenantCtx
@inject NavigationManager Nav

<PageTitle>Resident Sign In — @(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</PageTitle>

<div class="auth-split">

    <!-- Left branding panel -->
    <div class="auth-brand d-none d-lg-flex">
        <div class="deco-circle"></div>
        <div class="brand-inner">
            <div class="brand-logo mb-4">
                <i class="bi bi-house-door-fill"></i>
            </div>
            <h1 class="brand-title">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</h1>
            <p class="brand-subtitle">Resident Portal</p>

            <hr class="brand-divider my-4" />

            <ul class="brand-features list-unstyled">
                <li>
                    <div class="feat-icon"><i class="bi bi-person-plus-fill"></i></div>
                    <span>Pre-register visitors before they arrive</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-qr-code"></i></div>
                    <span>Share QR codes for seamless gate entry</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-clock-history"></i></div>
                    <span>View and manage your full visit history</span>
                </li>
                <li>
                    <div class="feat-icon"><i class="bi bi-bell-fill"></i></div>
                    <span>Stay informed when your guest checks in</span>
                </li>
            </ul>

            <p class="brand-footer mt-auto">&copy; @DateTime.Now.Year @(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp"). All rights reserved.</p>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-wrap">

            <!-- Mobile logo -->
            <div class="d-flex d-lg-none align-items-center gap-2 mb-4">
                <div class="mobile-logo"><i class="bi bi-house-door-fill"></i></div>
                <div>
                    <div class="fw-bold text-dark" style="font-size:1.1rem;">@(TenantCtx.IsResolved ? TenantCtx.TenantName : "FacilityApp")</div>
                    <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;">Resident Portal</div>
                </div>
            </div>

            <!-- Form card -->
            <div class="login-card">
                <h2 class="form-heading">Welcome home</h2>
                <p class="form-subheading">Sign in to your resident account to manage your visitors.</p>

                @if (_error is not null)
                {
                    <div class="alert alert-danger alert-signin d-flex align-items-center gap-2" role="alert">
                        <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                        <span>@_error</span>
                    </div>
                }

                <EditForm Model="_input" OnValidSubmit="HandleLoginAsync" FormName="residentLogin" method="post">
                    <DataAnnotationsValidator />
                    <AntiForgeryToken />

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="field-label">Email address</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-envelope field-icon"></i>
                            <InputText @bind-Value="_input.Email"
                                       class="form-control"
                                       style="padding-left:2.4rem;"
                                       placeholder="username@gmail.com"
                                       autocomplete="email" />
                        </div>
                        <ValidationMessage For="() => _input.Email" class="text-danger small mt-1" />
                    </div>

                    <!-- Password -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="field-label mb-0">Password</label>
                            <a href="@(TenantCtx.RouteBase)/resident/forgot-password" class="link-em" style="font-size:0.8rem;">
                                Forgot password?
                            </a>
                        </div>
                        <div class="input-icon-wrap">
                            <i class="bi bi-lock field-icon"></i>
                            <InputText type="@(_showPassword ? "text" : "password")"
                                       @bind-Value="_input.Password"
                                       class="form-control"
                                       style="padding-left:2.4rem;padding-right:2.75rem;"
                                       placeholder="••••••••"
                                       autocomplete="current-password" />
                            <button type="button" class="btn-pw-toggle"
                                    @onclick="() => _showPassword = !_showPassword"
                                    tabindex="-1"
                                    title="@(_showPassword ? "Hide password" : "Show password")">
                                <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        <ValidationMessage For="() => _input.Password" class="text-danger small mt-1" />
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn-signin" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Signing in…</span>
                        }
                        else
                        {
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            <span>Sign In</span>
                        }
                    </button>
                </EditForm>

                <hr class="form-divider" />

                <p class="text-center small text-muted mb-0">
                    New resident?
                    <a href="@(TenantCtx.RouteBase)/resident/register" class="link-em">Create an account</a>
                </p>
            </div>

            <!-- Staff notice -->
            <div class="staff-notice">
                <i class="bi bi-info-circle me-1"></i>
                This portal is for <strong>residents &amp; homeowners</strong> only.
                Staff should use the <a href="@(TenantCtx.RouteBase)/login" class="link-em">staff login</a>.
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter] public string TenantSlug { get; set; } = string.Empty;

    [SupplyParameterFromForm]
    private LoginInput _input { get; set; } = new();

    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private string? _error;
    private bool _submitting;
    private bool _showPassword;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantService.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }
    }

    private async Task HandleLoginAsync()
    {
        _submitting = true;
        _error      = null;

        if (!TenantCtx.IsResolved)
        {
            _error = "Facility not found. Check the URL and try again.";
            _submitting = false;
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(
            _input.Email, _input.Password, isPersistent: true, lockoutOnFailure: true);

        if (result.Succeeded)
        {
            var user = await UserManager.FindByEmailAsync(_input.Email);
            if (user is null || user.UserType == UserType.Staff)
            {
                await SignInManager.SignOutAsync();
                _error = "This account is not a resident account. Use the staff login instead.";
                _submitting = false;
                return;
            }

            var redirect = !string.IsNullOrEmpty(ReturnUrl) && ReturnUrl.StartsWith('/')
                ? ReturnUrl
                : $"{TenantCtx.RouteBase}/resident";
            Nav.NavigateTo(redirect, forceLoad: true);
        }
        else if (result.IsLockedOut)
        {
            _error = "Account locked after too many failed attempts. Please try again later.";
        }
        else
        {
            _error = "Invalid email or password.";
        }

        _submitting = false;
    }

    private sealed class LoginInput
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = string.Empty;
    }
}
