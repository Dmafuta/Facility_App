@page "/{TenantSlug}/resident/request-unit"
@page "/resident/request-unit"
@layout ResidentLayout
@rendermode InteractiveServer
@attribute [Authorize(Policy = "CanViewOwnHistory")]
@inject IUnitRequestService RequestSvc
@inject IUnitService UnitSvc
@inject ITenantService TenantSvc
@inject TenantContext TenantCtx
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Request Unit — @TenantCtx.TenantName</PageTitle>

<div class="d-flex align-items-center gap-2 mb-4">
    <a href="@(TenantCtx.RouteBase)/resident" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-house-add me-2 text-primary"></i>Request Unit</h4>
        <small class="text-muted">Submit a request to be assigned to your unit</small>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2"></div>
        <p>Loading…</p>
    </div>
}
else if (_existingRequest is not null)
{
    <!-- Show current request status -->
    @if (_existingRequest.Status == UnitRequestStatus.Pending)
    {
        <div class="card border-0 shadow-sm border-start border-warning border-4">
            <div class="card-body py-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 text-warning d-flex align-items-center justify-content-center"
                         style="width:48px;height:48px;font-size:1.4rem;">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Request Pending</h5>
                        <small class="text-muted">Submitted @_existingRequest.RequestedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</small>
                    </div>
                </div>
                <p class="mb-2">
                    Your request for <strong>
                        @(_existingRequest.Unit.Block is not null
                            ? $"Unit {_existingRequest.Unit.Block}-{_existingRequest.Unit.UnitNumber}"
                            : $"Unit {_existingRequest.Unit.UnitNumber}")
                    </strong> is awaiting review by a facility manager.
                </p>
                @if (!string.IsNullOrEmpty(_existingRequest.Note))
                {
                    <p class="text-muted small mb-0"><i class="bi bi-chat-left-text me-1"></i>Your note: <em>@_existingRequest.Note</em></p>
                }
                <hr />
                <p class="text-muted small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    You'll be notified once an administrator reviews your request. No action needed on your part.
                </p>
            </div>
        </div>
    }
    else if (_existingRequest.Status == UnitRequestStatus.Approved)
    {
        <div class="card border-0 shadow-sm border-start border-success border-4">
            <div class="card-body py-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle bg-success bg-opacity-10 text-success d-flex align-items-center justify-content-center"
                         style="width:48px;height:48px;font-size:1.4rem;">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-success">Request Approved!</h5>
                        <small class="text-muted">Approved @_existingRequest.ReviewedAt?.ToLocalTime().ToString("MMM d, yyyy")</small>
                    </div>
                </div>
                <p class="mb-3">
                    You have been assigned to <strong>
                        @(_existingRequest.Unit.Block is not null
                            ? $"Unit {_existingRequest.Unit.Block}-{_existingRequest.Unit.UnitNumber}"
                            : $"Unit {_existingRequest.Unit.UnitNumber}")
                    </strong>. You can now pre-register visitors.
                </p>
                <a href="@(TenantCtx.RouteBase)/resident" class="btn btn-success">
                    <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
                </a>
            </div>
        </div>
    }
    else if (_existingRequest.Status == UnitRequestStatus.Rejected)
    {
        <div class="card border-0 shadow-sm border-start border-danger border-4 mb-4">
            <div class="card-body py-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 text-danger d-flex align-items-center justify-content-center"
                         style="width:48px;height:48px;font-size:1.4rem;">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-danger">Request Rejected</h5>
                        <small class="text-muted">Reviewed @_existingRequest.ReviewedAt?.ToLocalTime().ToString("MMM d, yyyy")</small>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_existingRequest.ReviewNote))
                {
                    <p class="mb-2">
                        <strong>Reason:</strong> @_existingRequest.ReviewNote
                    </p>
                }
                <p class="text-muted small mb-0">You may submit a new request below.</p>
            </div>
        </div>

        <!-- Allow re-submission after rejection -->
        @RenderRequestForm()
    }
}
else
{
    @RenderRequestForm()
}

@code {
    [Parameter] public string TenantSlug { get; set; } = "";

    private bool _loading = true;
    private bool _submitting;
    private string? _error;
    private string _userId = "";
    private UnitRequest? _existingRequest;
    private List<UnitDetails> _units = [];
    private Guid _selectedUnitId;
    private string _note = "";

    protected override async Task OnInitializedAsync()
    {
        if (!TenantCtx.IsResolved)
        {
            var tenant = await TenantSvc.ResolveBySlugAsync(TenantSlug);
            if (tenant is not null)
            {
                TenantCtx.TenantId   = tenant.Id;
                TenantCtx.TenantSlug = tenant.Slug;
                TenantCtx.TenantName = tenant.Name;
                TenantCtx.IsResolved = true;
            }
        }

        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        // If already assigned a unit, redirect back to dashboard
        if (!string.IsNullOrEmpty(_userId))
        {
            var myUnits = await UnitSvc.GetForUserAsync(_userId);
            if (myUnits.Any(u => u.LinkType == UnitLinkType.Occupant))
            {
                Nav.NavigateTo($"{TenantCtx.RouteBase}/resident", replace: true);
                return;
            }

            _existingRequest = await RequestSvc.GetForResidentAsync(_userId);
            _units = await UnitSvc.GetAllAsync();
        }

        _loading = false;
    }

    private async Task SubmitAsync()
    {
        if (_selectedUnitId == Guid.Empty)
        {
            _error = "Please select a unit.";
            return;
        }

        _submitting = true;
        _error = null;

        try
        {
            _existingRequest = await RequestSvc.SubmitAsync(_userId, _selectedUnitId, _note);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }

    private RenderFragment RenderRequestForm() => __builder =>
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-house-door me-2 text-primary"></i>Select Your Unit
                </h6>
                <small class="text-muted">Choose the unit you occupy and submit a request for admin approval</small>
            </div>
            <div class="card-body">
                @if (_error is not null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 small">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                        <span>@_error</span>
                    </div>
                }

                @if (_units.Count == 0)
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-building-x fs-1 d-block mb-2 opacity-25"></i>
                        No units are available. Contact your facility manager.
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Unit</label>
                        <select class="form-select" @bind="_selectedUnitId">
                            <option value="@Guid.Empty">— Select a unit —</option>
                            @foreach (var u in _units)
                            {
                                var label = u.Unit.Block is not null
                                    ? $"Unit {u.Unit.Block}-{u.Unit.UnitNumber}"
                                    : $"Unit {u.Unit.UnitNumber}";
                                if (!string.IsNullOrEmpty(u.Unit.Description))
                                    label += $" — {u.Unit.Description}";
                                if (u.Occupant is not null)
                                    label += " (occupied)";
                                <option value="@u.Unit.Id">@label</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold small">Note <span class="text-muted fw-normal">(optional)</span></label>
                        <textarea class="form-control" rows="2" placeholder="e.g. Move-in date, lease reference, or any relevant detail"
                                  @bind="_note" maxlength="300"></textarea>
                    </div>

                    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@(_submitting || _selectedUnitId == Guid.Empty)">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Submitting…</span>
                        }
                        else
                        {
                            <i class="bi bi-send me-2"></i>
                            <span>Submit Request</span>
                        }
                    </button>
                }
            </div>
        </div>
    };
}
